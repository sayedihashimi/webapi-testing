@baseUrl = http://localhost:5050

### =============================================
### Membership Plans
### =============================================

### List all active membership plans
GET {{baseUrl}}/api/membership-plans

### Get a specific membership plan (Basic)
GET {{baseUrl}}/api/membership-plans/1

### Create a new membership plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students",
  "durationMonths": 3,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a membership plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Access to standard classes - Updated",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false
}

### Deactivate a membership plan
DELETE {{baseUrl}}/api/membership-plans/4

### =============================================
### Members
### =============================================

### List all members (default pagination)
GET {{baseUrl}}/api/members

### List members with search
GET {{baseUrl}}/api/members?search=alice&page=1&pageSize=10

### List active members only
GET {{baseUrl}}/api/members?isActive=true

### Get member details (Alice - has Premium membership)
GET {{baseUrl}}/api/members/1

### Get member details (Brian - has Basic membership)
GET {{baseUrl}}/api/members/2

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Sophia",
  "lastName": "Garcia",
  "email": "sophia.garcia@email.com",
  "phone": "555-0901",
  "dateOfBirth": "1998-06-20",
  "emergencyContactName": "Carlos Garcia",
  "emergencyContactPhone": "555-0902"
}

### Update a member
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0111",
  "emergencyContactName": "Bob Johnson",
  "emergencyContactPhone": "555-0112"
}

### Deactivate a member (Grace - no active bookings, should succeed)
DELETE {{baseUrl}}/api/members/7

### Get member bookings (Alice)
GET {{baseUrl}}/api/members/1/bookings

### Get member bookings filtered by status
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed&page=1&pageSize=5

### Get upcoming bookings for Alice
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get membership history for Alice
GET {{baseUrl}}/api/members/1/memberships

### Get membership history for Grace (has expired membership)
GET {{baseUrl}}/api/members/7/memberships

### =============================================
### Memberships
### =============================================

### Create a membership for Grace (member 7 - has expired membership)
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 7,
  "membershipPlanId": 1,
  "startDate": "2025-07-01",
  "paymentStatus": "Paid"
}

### Get membership details
GET {{baseUrl}}/api/memberships/1

### Cancel a membership
POST {{baseUrl}}/api/memberships/8/cancel

### Freeze a membership (member 4's Premium membership)
POST {{baseUrl}}/api/memberships/4/freeze
Content-Type: application/json

{
  "freezeDurationDays": 14
}

### Unfreeze a membership
POST {{baseUrl}}/api/memberships/4/unfreeze

### Renew an expired membership (Grace's expired membership)
POST {{baseUrl}}/api/memberships/7/renew

### =============================================
### Instructors
### =============================================

### List all instructors
GET {{baseUrl}}/api/instructors

### List instructors filtered by specialization
GET {{baseUrl}}/api/instructors?specialization=Yoga

### List active instructors only
GET {{baseUrl}}/api/instructors?isActive=true

### Get instructor details (Sarah Chen)
GET {{baseUrl}}/api/instructors/1

### Create a new instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Rachel",
  "lastName": "Kim",
  "email": "rachel.kim@zenithstudio.com",
  "phone": "555-1005",
  "bio": "Certified Zumba and dance fitness instructor",
  "specializations": "Zumba, Dance, HIIT",
  "hireDate": "2025-01-15"
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Chen",
  "email": "sarah.chen@zenithstudio.com",
  "phone": "555-1001",
  "bio": "Senior yoga instructor with 12 years of experience",
  "specializations": "Yoga, Pilates, Meditation, Barre"
}

### Get instructor schedule (Sarah Chen)
GET {{baseUrl}}/api/instructors/1/schedule

### Get instructor schedule with date range
GET {{baseUrl}}/api/instructors/1/schedule?fromDate=2025-07-01&toDate=2025-07-10

### =============================================
### Class Types
### =============================================

### List all class types
GET {{baseUrl}}/api/class-types

### List premium class types only
GET {{baseUrl}}/api/class-types?isPremium=true

### List class types by difficulty
GET {{baseUrl}}/api/class-types?difficulty=Advanced

### Get class type details (Yoga)
GET {{baseUrl}}/api/class-types/1

### Create a new class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Zumba",
  "description": "Latin-inspired dance fitness",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 400,
  "difficultyLevel": "AllLevels"
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Relaxing yoga sessions for all levels - improved curriculum",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 280,
  "difficultyLevel": "AllLevels"
}

### =============================================
### Class Schedules
### =============================================

### List all scheduled classes (default pagination)
GET {{baseUrl}}/api/classes

### List classes with filters
GET {{baseUrl}}/api/classes?classTypeId=1&page=1&pageSize=10

### List classes by instructor
GET {{baseUrl}}/api/classes?instructorId=1

### List only available classes
GET {{baseUrl}}/api/classes?available=true

### Get available classes in next 7 days
GET {{baseUrl}}/api/classes/available

### Get class details (first Yoga class)
GET {{baseUrl}}/api/classes/1

### Get class details (Meditation - full with waitlist)
GET {{baseUrl}}/api/classes/6

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 3,
  "startTime": "2025-07-25T16:00:00",
  "durationMinutes": 60,
  "capacity": 20,
  "room": "Studio A"
}

### Update a class schedule
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 1,
  "startTime": "2025-07-25T09:00:00",
  "durationMinutes": 75,
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class (cascade cancels all bookings)
PATCH {{baseUrl}}/api/classes/9/cancel

### Get class roster (Yoga tomorrow - has 3 confirmed)
GET {{baseUrl}}/api/classes/1/roster

### Get class waitlist (Meditation - has 1 waitlisted)
GET {{baseUrl}}/api/classes/6/waitlist

### =============================================
### Bookings
### =============================================

### Create a booking (Emma for Yoga tomorrow - should succeed)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 1,
  "memberId": 5
}

### Create a booking for the full Meditation class (should go to waitlist)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 6,
  "memberId": 4
}

### Try booking a premium class as a Basic member (Brian=member 2, Boxing=schedule 5 - should fail)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 5,
  "memberId": 2
}

### Try booking as member with expired membership (Grace=member 7 - should fail)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 1,
  "memberId": 7
}

### Get booking details
GET {{baseUrl}}/api/bookings/1

### Cancel a booking
POST {{baseUrl}}/api/bookings/1/cancel
Content-Type: application/json

{
  "reason": "Schedule conflict"
}

### Check in for a class (will only work during check-in window)
POST {{baseUrl}}/api/bookings/2/check-in

### Mark booking as no-show (will only work 15 min after class start)
POST {{baseUrl}}/api/bookings/3/no-show
