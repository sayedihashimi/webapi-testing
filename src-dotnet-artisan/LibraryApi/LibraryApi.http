@baseUrl = http://localhost:5000

### ========== AUTHORS ==========

### Get all authors
GET {{baseUrl}}/api/authors?page=1&pageSize=10

### Search authors by name
GET {{baseUrl}}/api/authors?search=Orwell

### Get author by ID (includes books)
GET {{baseUrl}}/api/authors/1

### Create a new author
POST {{baseUrl}}/api/authors
Content-Type: application/json

{
  "firstName": "Margaret",
  "lastName": "Atwood",
  "biography": "Canadian poet, novelist, literary critic, essayist, and environmental activist.",
  "birthDate": "1939-11-18",
  "country": "Canada"
}

### Update an author
PUT {{baseUrl}}/api/authors/1
Content-Type: application/json

{
  "firstName": "George",
  "lastName": "Orwell",
  "biography": "English novelist, essayist, journalist, and critic. Best known for 1984 and Animal Farm.",
  "birthDate": "1903-06-25",
  "country": "United Kingdom"
}

### Delete an author (will fail if has books)
DELETE {{baseUrl}}/api/authors/1

### ========== CATEGORIES ==========

### Get all categories
GET {{baseUrl}}/api/categories

### Get category by ID (includes book count)
GET {{baseUrl}}/api/categories/1

### Create a new category
POST {{baseUrl}}/api/categories
Content-Type: application/json

{
  "name": "Philosophy",
  "description": "Works exploring fundamental questions about existence, knowledge, and ethics"
}

### Update a category
PUT {{baseUrl}}/api/categories/1
Content-Type: application/json

{
  "name": "Fiction",
  "description": "Literary works created from the imagination, not based strictly on history or fact"
}

### Delete a category (will fail if has books)
DELETE {{baseUrl}}/api/categories/6

### ========== BOOKS ==========

### Get all books with pagination
GET {{baseUrl}}/api/books?page=1&pageSize=5

### Search books by title
GET {{baseUrl}}/api/books?search=1984

### Search books by author name
GET {{baseUrl}}/api/books?search=Asimov

### Filter books by category
GET {{baseUrl}}/api/books?category=Science%20Fiction

### Filter available books
GET {{baseUrl}}/api/books?available=true

### Sort books by title descending
GET {{baseUrl}}/api/books?sortBy=title&sortDirection=desc

### Sort books by publication year
GET {{baseUrl}}/api/books?sortBy=year&sortDirection=asc

### Get book by ID (includes authors, categories, availability)
GET {{baseUrl}}/api/books/1

### Create a new book
POST {{baseUrl}}/api/books
Content-Type: application/json

{
  "title": "Brave New World",
  "isbn": "978-0060850524",
  "publisher": "Harper Perennial",
  "publicationYear": 1932,
  "description": "A dystopian novel set in a futuristic World State.",
  "pageCount": 288,
  "language": "English",
  "totalCopies": 3,
  "authorIds": [1],
  "categoryIds": [1, 2]
}

### Update a book
PUT {{baseUrl}}/api/books/1
Content-Type: application/json

{
  "title": "1984",
  "isbn": "978-0451524935",
  "publisher": "Signet Classics",
  "publicationYear": 1949,
  "description": "A dystopian social science fiction novel and cautionary tale about the dangers of totalitarianism.",
  "pageCount": 328,
  "language": "English",
  "totalCopies": 6,
  "authorIds": [1],
  "categoryIds": [1, 2]
}

### Delete a book (will fail if has active loans)
DELETE {{baseUrl}}/api/books/12

### Get book loan history
GET {{baseUrl}}/api/books/1/loans

### Get book active reservations
GET {{baseUrl}}/api/books/5/reservations

### ========== PATRONS ==========

### Get all patrons
GET {{baseUrl}}/api/patrons?page=1&pageSize=10

### Search patrons by name
GET {{baseUrl}}/api/patrons?search=Alice

### Search patrons by email
GET {{baseUrl}}/api/patrons?search=bob.smith

### Filter by membership type
GET {{baseUrl}}/api/patrons?membershipType=Premium

### Get patron by ID (includes active loans count, unpaid fines balance)
GET {{baseUrl}}/api/patrons/1

### Create a new patron
POST {{baseUrl}}/api/patrons
Content-Type: application/json

{
  "firstName": "Grace",
  "lastName": "Lee",
  "email": "grace.lee@email.com",
  "phone": "555-0107",
  "address": "111 Willow Way",
  "membershipType": "Standard"
}

### Update a patron
PUT {{baseUrl}}/api/patrons/2
Content-Type: application/json

{
  "firstName": "Bob",
  "lastName": "Smith",
  "email": "bob.smith@email.com",
  "phone": "555-0102",
  "address": "456 Elm Avenue, Apt 2B",
  "membershipType": "Premium"
}

### Deactivate a patron (will fail if has active loans)
DELETE {{baseUrl}}/api/patrons/6

### Get patron's loans
GET {{baseUrl}}/api/patrons/1/loans

### Get patron's loans filtered by status
GET {{baseUrl}}/api/patrons/2/loans?status=Active

### Get patron's reservations
GET {{baseUrl}}/api/patrons/2/reservations

### Get patron's fines
GET {{baseUrl}}/api/patrons/4/fines

### Get patron's unpaid fines
GET {{baseUrl}}/api/patrons/4/fines?status=Unpaid

### ========== LOANS ==========

### Get all loans with pagination
GET {{baseUrl}}/api/loans?page=1&pageSize=10

### Filter loans by status
GET {{baseUrl}}/api/loans?status=Active

### Filter overdue loans
GET {{baseUrl}}/api/loans?overdue=true

### Filter loans by date range
GET {{baseUrl}}/api/loans?fromDate=2024-01-01&toDate=2025-12-31

### Get overdue loans endpoint
GET {{baseUrl}}/api/loans/overdue

### Get loan by ID
GET {{baseUrl}}/api/loans/1

### Checkout a book (create loan) — Standard patron
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 12,
  "patronId": 2
}

### Checkout — will fail: inactive patron
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 12,
  "patronId": 6
}

### Return a book
POST {{baseUrl}}/api/loans/1/return

### Renew a loan
POST {{baseUrl}}/api/loans/2/renew

### Renew — will fail if overdue
POST {{baseUrl}}/api/loans/8/renew

### ========== RESERVATIONS ==========

### Get all reservations
GET {{baseUrl}}/api/reservations?page=1&pageSize=10

### Filter reservations by status
GET {{baseUrl}}/api/reservations?status=Pending

### Get reservation by ID
GET {{baseUrl}}/api/reservations/1

### Create a reservation
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 1,
  "patronId": 5
}

### Create reservation — will fail: book already on active loan by patron
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 1,
  "patronId": 1
}

### Cancel a reservation
POST {{baseUrl}}/api/reservations/1/cancel

### Fulfill a reservation (creates loan)
POST {{baseUrl}}/api/reservations/3/fulfill

### ========== FINES ==========

### Get all fines
GET {{baseUrl}}/api/fines?page=1&pageSize=10

### Filter fines by status
GET {{baseUrl}}/api/fines?status=Unpaid

### Get fine by ID
GET {{baseUrl}}/api/fines/1

### Pay a fine
POST {{baseUrl}}/api/fines/1/pay

### Waive a fine
POST {{baseUrl}}/api/fines/3/waive
