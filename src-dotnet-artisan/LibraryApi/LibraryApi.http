@baseUrl = http://localhost:5164

##############################################
### Authors
##############################################

### List all authors
GET {{baseUrl}}/api/authors?page=1&pageSize=10
Accept: application/json

### Search authors by name
GET {{baseUrl}}/api/authors?search=Austen&page=1&pageSize=10
Accept: application/json

### Get author by ID (Jane Austen)
GET {{baseUrl}}/api/authors/3
Accept: application/json

### Create a new author
POST {{baseUrl}}/api/authors
Content-Type: application/json

{
  "firstName": "Mark",
  "lastName": "Twain",
  "biography": "American writer, humorist, and lecturer.",
  "birthDate": "1835-11-30",
  "country": "United States"
}

### Update an author
PUT {{baseUrl}}/api/authors/1
Content-Type: application/json

{
  "firstName": "Harper",
  "lastName": "Lee",
  "biography": "American novelist best known for To Kill a Mockingbird, published in 1960.",
  "birthDate": "1926-04-28",
  "country": "United States"
}

### Delete an author (should fail — has books)
DELETE {{baseUrl}}/api/authors/1

##############################################
### Categories
##############################################

### List all categories
GET {{baseUrl}}/api/categories?page=1&pageSize=10
Accept: application/json

### Get category by ID (Fiction)
GET {{baseUrl}}/api/categories/1
Accept: application/json

### Create a new category
POST {{baseUrl}}/api/categories
Content-Type: application/json

{
  "name": "Philosophy",
  "description": "Works exploring fundamental questions about existence and knowledge"
}

### Update a category
PUT {{baseUrl}}/api/categories/1
Content-Type: application/json

{
  "name": "Fiction",
  "description": "Literary works created from the imagination, including novels and short stories"
}

### Delete a category (should fail — has books)
DELETE {{baseUrl}}/api/categories/1

##############################################
### Books
##############################################

### List all books
GET {{baseUrl}}/api/books?page=1&pageSize=10
Accept: application/json

### Search books by title
GET {{baseUrl}}/api/books?search=1984&page=1&pageSize=10
Accept: application/json

### Filter books by category
GET {{baseUrl}}/api/books?category=Science+Fiction&page=1&pageSize=10
Accept: application/json

### Filter available books only
GET {{baseUrl}}/api/books?available=true&page=1&pageSize=10
Accept: application/json

### Filter unavailable books
GET {{baseUrl}}/api/books?available=false&page=1&pageSize=10
Accept: application/json

### Sort books by year
GET {{baseUrl}}/api/books?sortBy=year&page=1&pageSize=10
Accept: application/json

### Get book by ID (1984)
GET {{baseUrl}}/api/books/2
Accept: application/json

### Create a new book
POST {{baseUrl}}/api/books
Content-Type: application/json

{
  "title": "Brave New World",
  "isbn": "978-0060850524",
  "publisher": "Harper Perennial",
  "publicationYear": 1932,
  "description": "A dystopian novel about a technologically advanced future society.",
  "pageCount": 288,
  "language": "English",
  "totalCopies": 3,
  "authorIds": [],
  "categoryIds": [1, 2]
}

### Update a book
PUT {{baseUrl}}/api/books/1
Content-Type: application/json

{
  "title": "To Kill a Mockingbird",
  "isbn": "978-0061120084",
  "publisher": "Harper Perennial Modern Classics",
  "publicationYear": 1960,
  "description": "A novel about racial injustice in the American Deep South.",
  "pageCount": 336,
  "language": "English",
  "totalCopies": 4,
  "authorIds": [1],
  "categoryIds": [1, 6]
}

### Delete a book (should fail — has active loans)
DELETE {{baseUrl}}/api/books/1

### Get book loan history
GET {{baseUrl}}/api/books/2/loans?page=1&pageSize=10
Accept: application/json

### Get book reservations queue
GET {{baseUrl}}/api/books/8/reservations?page=1&pageSize=10
Accept: application/json

##############################################
### Patrons
##############################################

### List all patrons
GET {{baseUrl}}/api/patrons?page=1&pageSize=10
Accept: application/json

### Search patrons by name
GET {{baseUrl}}/api/patrons?search=Alice&page=1&pageSize=10
Accept: application/json

### Filter patrons by membership type
GET {{baseUrl}}/api/patrons?membershipType=Premium&page=1&pageSize=10
Accept: application/json

### Get patron by ID (Alice Johnson — Premium)
GET {{baseUrl}}/api/patrons/1
Accept: application/json

### Create a new patron
POST {{baseUrl}}/api/patrons
Content-Type: application/json

{
  "firstName": "Grace",
  "lastName": "Hopper",
  "email": "grace.hopper@email.com",
  "phone": "555-0200",
  "address": "100 Navy Way",
  "membershipType": "Standard"
}

### Update a patron
PUT {{baseUrl}}/api/patrons/2
Content-Type: application/json

{
  "firstName": "Bob",
  "lastName": "Smith",
  "email": "bob.smith@email.com",
  "phone": "555-0102",
  "address": "456 Oak Ave, Apt 2B",
  "membershipType": "Premium"
}

### Deactivate a patron (should fail — has active loans)
DELETE {{baseUrl}}/api/patrons/1

### Deactivate an inactive patron (Frank Miller — already inactive, no active loans)
DELETE {{baseUrl}}/api/patrons/6

### Get patron's loans
GET {{baseUrl}}/api/patrons/1/loans?page=1&pageSize=10
Accept: application/json

### Get patron's active loans
GET {{baseUrl}}/api/patrons/1/loans?status=Active&page=1&pageSize=10
Accept: application/json

### Get patron's reservations
GET {{baseUrl}}/api/patrons/1/reservations?page=1&pageSize=10
Accept: application/json

### Get patron's fines
GET {{baseUrl}}/api/patrons/4/fines?page=1&pageSize=10
Accept: application/json

### Get patron's unpaid fines
GET {{baseUrl}}/api/patrons/4/fines?status=Unpaid&page=1&pageSize=10
Accept: application/json

##############################################
### Loans
##############################################

### List all loans
GET {{baseUrl}}/api/loans?page=1&pageSize=10
Accept: application/json

### List active loans
GET {{baseUrl}}/api/loans?status=Active&page=1&pageSize=10
Accept: application/json

### List overdue loans
GET {{baseUrl}}/api/loans/overdue?page=1&pageSize=10
Accept: application/json

### Get loan by ID
GET {{baseUrl}}/api/loans/1
Accept: application/json

### Checkout a book (valid — patron 5, book 10)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 10,
  "patronId": 5
}

### Checkout — should fail: inactive patron (Frank Miller)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 4,
  "patronId": 6
}

### Checkout — should fail: no available copies (The End of Eternity, book 8)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 8,
  "patronId": 5
}

### Return a book (loan 1)
POST {{baseUrl}}/api/loans/1/return

### Renew a loan (loan 2 — active)
POST {{baseUrl}}/api/loans/2/renew

### Renew — should fail: overdue loan (loan 5)
POST {{baseUrl}}/api/loans/5/renew

##############################################
### Reservations
##############################################

### List all reservations
GET {{baseUrl}}/api/reservations?page=1&pageSize=10
Accept: application/json

### List pending reservations
GET {{baseUrl}}/api/reservations?status=Pending&page=1&pageSize=10
Accept: application/json

### Get reservation by ID
GET {{baseUrl}}/api/reservations/1
Accept: application/json

### Create a reservation (patron 2, book 8 — no copies available)
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 8,
  "patronId": 2
}

### Create reservation — should fail: patron already has active loan (patron 2, book 2)
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 2,
  "patronId": 2
}

### Cancel a reservation (reservation 2)
POST {{baseUrl}}/api/reservations/2/cancel

### Fulfill a ready reservation (reservation 3 — Ready status)
POST {{baseUrl}}/api/reservations/3/fulfill

##############################################
### Fines
##############################################

### List all fines
GET {{baseUrl}}/api/fines?page=1&pageSize=10
Accept: application/json

### List unpaid fines
GET {{baseUrl}}/api/fines?status=Unpaid&page=1&pageSize=10
Accept: application/json

### Get fine by ID
GET {{baseUrl}}/api/fines/1
Accept: application/json

### Pay a fine
POST {{baseUrl}}/api/fines/1/pay

### Waive a fine
POST {{baseUrl}}/api/fines/3/waive
