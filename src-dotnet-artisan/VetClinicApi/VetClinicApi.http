@baseUrl = http://localhost:5048

### ===========================
### OWNERS
### ===========================

### List all owners
GET {{baseUrl}}/api/owners?page=1&pageSize=10
Accept: application/json

### Search owners by name
GET {{baseUrl}}/api/owners?search=johnson&page=1&pageSize=10
Accept: application/json

### Get owner by ID (includes pets)
GET {{baseUrl}}/api/owners/1
Accept: application/json

### Create a new owner
POST {{baseUrl}}/api/owners
Content-Type: application/json

{
  "firstName": "David",
  "lastName": "Martinez",
  "email": "david.martinez@email.com",
  "phone": "555-0106",
  "address": "100 Cedar Court",
  "city": "Chicago",
  "state": "IL",
  "zipCode": "60601"
}

### Update an owner
PUT {{baseUrl}}/api/owners/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Johnson-Smith",
  "email": "sarah.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Oak Street",
  "city": "Springfield",
  "state": "IL",
  "zipCode": "62701"
}

### Delete an owner (fails if has active pets)
DELETE {{baseUrl}}/api/owners/5

### Get owner's pets
GET {{baseUrl}}/api/owners/1/pets
Accept: application/json

### Get owner's appointments
GET {{baseUrl}}/api/owners/1/appointments
Accept: application/json

### ===========================
### PETS
### ===========================

### List all active pets
GET {{baseUrl}}/api/pets?page=1&pageSize=10
Accept: application/json

### Search pets by name
GET {{baseUrl}}/api/pets?search=buddy&page=1&pageSize=10
Accept: application/json

### Search pets including inactive
GET {{baseUrl}}/api/pets?includeInactive=true&page=1&pageSize=10
Accept: application/json

### Get pet by ID (includes owner)
GET {{baseUrl}}/api/pets/1
Accept: application/json

### Create a new pet
POST {{baseUrl}}/api/pets
Content-Type: application/json

{
  "name": "Daisy",
  "species": "Dog",
  "breed": "Poodle",
  "dateOfBirth": "2023-06-15",
  "weight": 8.5,
  "color": "White",
  "microchipNumber": "MC-009-2023",
  "ownerId": 1
}

### Update a pet (owner transfer example)
PUT {{baseUrl}}/api/pets/1
Content-Type: application/json

{
  "name": "Buddy",
  "species": "Dog",
  "breed": "Golden Retriever",
  "dateOfBirth": "2020-03-15",
  "weight": 33.0,
  "color": "Golden",
  "microchipNumber": "MC-001-2020",
  "ownerId": 2
}

### Soft delete a pet
DELETE {{baseUrl}}/api/pets/1

### Get pet's medical records
GET {{baseUrl}}/api/pets/1/medical-records
Accept: application/json

### Get pet's vaccinations
GET {{baseUrl}}/api/pets/1/vaccinations
Accept: application/json

### Get pet's upcoming/overdue vaccinations
GET {{baseUrl}}/api/pets/3/vaccinations/upcoming
Accept: application/json

### Get pet's active prescriptions
GET {{baseUrl}}/api/pets/3/prescriptions/active
Accept: application/json

### ===========================
### VETERINARIANS
### ===========================

### List all veterinarians
GET {{baseUrl}}/api/veterinarians?page=1&pageSize=10
Accept: application/json

### Filter by specialization
GET {{baseUrl}}/api/veterinarians?specialization=surgery&page=1&pageSize=10
Accept: application/json

### Filter by availability
GET {{baseUrl}}/api/veterinarians?isAvailable=true
Accept: application/json

### Get veterinarian by ID
GET {{baseUrl}}/api/veterinarians/1
Accept: application/json

### Create a new veterinarian
POST {{baseUrl}}/api/veterinarians
Content-Type: application/json

{
  "firstName": "Dr. Jennifer",
  "lastName": "Park",
  "email": "jennifer.park@happypaws.com",
  "phone": "555-0204",
  "specialization": "Dermatology",
  "licenseNumber": "VET-2022-004",
  "hireDate": "2022-01-15"
}

### Update a veterinarian
PUT {{baseUrl}}/api/veterinarians/1
Content-Type: application/json

{
  "firstName": "Dr. Amanda",
  "lastName": "Foster",
  "email": "amanda.foster@happypaws.com",
  "phone": "555-0201",
  "specialization": "General Practice",
  "licenseNumber": "VET-2015-001",
  "isAvailable": true
}

### Get veterinarian's schedule for today
GET {{baseUrl}}/api/veterinarians/1/schedule
Accept: application/json

### Get veterinarian's schedule for a specific date
GET {{baseUrl}}/api/veterinarians/1/schedule?date=2025-04-01
Accept: application/json

### Get veterinarian's appointments with status filter
GET {{baseUrl}}/api/veterinarians/1/appointments?status=Scheduled&page=1&pageSize=10
Accept: application/json

### ===========================
### APPOINTMENTS
### ===========================

### List all appointments
GET {{baseUrl}}/api/appointments?page=1&pageSize=10
Accept: application/json

### Filter by date range
GET {{baseUrl}}/api/appointments?fromDate=2025-01-01&toDate=2025-12-31&page=1&pageSize=10
Accept: application/json

### Filter by status
GET {{baseUrl}}/api/appointments?status=Scheduled&page=1&pageSize=10
Accept: application/json

### Filter by vet and pet
GET {{baseUrl}}/api/appointments?vetId=1&petId=1&page=1&pageSize=10
Accept: application/json

### Get today's appointments
GET {{baseUrl}}/api/appointments/today
Accept: application/json

### Get appointment by ID (includes pet, vet, medical record)
GET {{baseUrl}}/api/appointments/1
Accept: application/json

### Create a new appointment
POST {{baseUrl}}/api/appointments
Content-Type: application/json

{
  "petId": 4,
  "veterinarianId": 1,
  "appointmentDate": "2025-12-20T10:00:00Z",
  "durationMinutes": 30,
  "reason": "Annual wellness checkup",
  "notes": "First visit for this pet"
}

### Update an appointment
PUT {{baseUrl}}/api/appointments/7
Content-Type: application/json

{
  "petId": 1,
  "veterinarianId": 1,
  "appointmentDate": "2025-12-22T14:00:00Z",
  "durationMinutes": 45,
  "reason": "Vaccination booster and checkup",
  "notes": "Extended appointment for full checkup"
}

### Update appointment status — Check in
PATCH {{baseUrl}}/api/appointments/7/status
Content-Type: application/json

{
  "newStatus": "CheckedIn"
}

### Update appointment status — Start
PATCH {{baseUrl}}/api/appointments/7/status
Content-Type: application/json

{
  "newStatus": "InProgress"
}

### Update appointment status — Complete
PATCH {{baseUrl}}/api/appointments/7/status
Content-Type: application/json

{
  "newStatus": "Completed"
}

### Update appointment status — Cancel (requires reason)
PATCH {{baseUrl}}/api/appointments/8/status
Content-Type: application/json

{
  "newStatus": "Cancelled",
  "cancellationReason": "Pet is feeling better, owner cancelled"
}

### ===========================
### MEDICAL RECORDS
### ===========================

### Get medical record by ID (includes prescriptions)
GET {{baseUrl}}/api/medical-records/1
Accept: application/json

### Create a medical record (appointment must be Completed or InProgress)
POST {{baseUrl}}/api/medical-records
Content-Type: application/json

{
  "appointmentId": 1,
  "diagnosis": "Healthy - annual wellness exam",
  "treatment": "Routine vaccinations administered",
  "notes": "Dog is in excellent health",
  "followUpDate": "2026-03-15"
}

### Update a medical record
PUT {{baseUrl}}/api/medical-records/1
Content-Type: application/json

{
  "diagnosis": "Healthy - annual wellness exam (updated)",
  "treatment": "Routine vaccinations administered, heartworm test performed",
  "notes": "Dog is in excellent health. Heartworm test negative.",
  "followUpDate": "2026-03-15"
}

### ===========================
### PRESCRIPTIONS
### ===========================

### Get prescription by ID
GET {{baseUrl}}/api/prescriptions/1
Accept: application/json

### Create a prescription
POST {{baseUrl}}/api/prescriptions
Content-Type: application/json

{
  "medicalRecordId": 1,
  "medicationName": "Apoquel",
  "dosage": "16mg once daily",
  "durationDays": 30,
  "startDate": "2025-03-20",
  "instructions": "Give with morning meal"
}

### ===========================
### VACCINATIONS
### ===========================

### Get vaccination by ID
GET {{baseUrl}}/api/vaccinations/1
Accept: application/json

### Create a vaccination
POST {{baseUrl}}/api/vaccinations
Content-Type: application/json

{
  "petId": 1,
  "vaccineName": "Leptospirosis",
  "dateAdministered": "2025-03-18",
  "expirationDate": "2026-03-18",
  "batchNumber": "LEP-2025-5001",
  "administeredByVetId": 1,
  "notes": "Annual leptospirosis booster"
}
