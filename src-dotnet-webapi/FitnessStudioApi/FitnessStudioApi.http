@baseUrl = http://localhost:5066

#############################
# MEMBERSHIP PLANS
#############################

### List all active membership plans
GET {{baseUrl}}/api/membership-plans

### Get membership plan by ID
GET {{baseUrl}}/api/membership-plans/1

### Get non-existent plan (404)
GET {{baseUrl}}/api/membership-plans/999

### Create a new membership plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students",
  "durationMonths": 6,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a membership plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Basic membership - updated description",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false,
  "isActive": true
}

### Deactivate a membership plan (soft delete)
DELETE {{baseUrl}}/api/membership-plans/1

#############################
# MEMBERS
#############################

### List all members (paginated)
GET {{baseUrl}}/api/members?page=1&pageSize=10

### List active members only
GET {{baseUrl}}/api/members?isActive=true

### Search members by name
GET {{baseUrl}}/api/members?search=alice

### Search members by email
GET {{baseUrl}}/api/members?search=marcus.chen

### Get member details (includes active membership & booking stats)
GET {{baseUrl}}/api/members/1

### Get inactive member
GET {{baseUrl}}/api/members/8

### Get non-existent member (404)
GET {{baseUrl}}/api/members/999

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Zara",
  "lastName": "Khan",
  "email": "zara.khan@email.com",
  "phone": "555-0200",
  "dateOfBirth": "2000-06-15",
  "emergencyContactName": "Imran Khan",
  "emergencyContactPhone": "555-0201"
}

### Try to register an underage member (400)
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Young",
  "lastName": "Person",
  "email": "young@email.com",
  "phone": "555-0300",
  "dateOfBirth": "2015-01-01",
  "emergencyContactName": "Parent",
  "emergencyContactPhone": "555-0301"
}

### Update a member
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0101-new",
  "emergencyContactName": "Bob Johnson",
  "emergencyContactPhone": "555-0102"
}

### Deactivate a member
DELETE {{baseUrl}}/api/members/8

### Get member bookings (paginated, filtered)
GET {{baseUrl}}/api/members/1/bookings?page=1&pageSize=10

### Get member bookings filtered by status
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed

### Get member upcoming confirmed bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get member membership history
GET {{baseUrl}}/api/members/1/memberships

### Get member 4 memberships (has both expired and active)
GET {{baseUrl}}/api/members/4/memberships

#############################
# MEMBERSHIPS
#############################

### Create a new membership
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 7,
  "membershipPlanId": 2,
  "startDate": "2025-01-15",
  "paymentStatus": "Paid"
}

### Get membership details
GET {{baseUrl}}/api/memberships/1

### Get expired membership
GET {{baseUrl}}/api/memberships/4

### Cancel a membership
POST {{baseUrl}}/api/memberships/3/cancel

### Freeze a membership (7-30 days)
POST {{baseUrl}}/api/memberships/1/freeze
Content-Type: application/json

{
  "freezeStartDate": "2025-08-01",
  "freezeEndDate": "2025-08-15"
}

### Unfreeze a membership
POST {{baseUrl}}/api/memberships/1/unfreeze

### Renew an expired membership
POST {{baseUrl}}/api/memberships/4/renew

### Try to freeze too short (400)
POST {{baseUrl}}/api/memberships/2/freeze
Content-Type: application/json

{
  "freezeStartDate": "2025-08-01",
  "freezeEndDate": "2025-08-03"
}

#############################
# INSTRUCTORS
#############################

### List all instructors
GET {{baseUrl}}/api/instructors?page=1&pageSize=10

### List instructors by specialization
GET {{baseUrl}}/api/instructors?specialization=Yoga

### List active instructors only
GET {{baseUrl}}/api/instructors?isActive=true

### Get instructor details
GET {{baseUrl}}/api/instructors/1

### Create a new instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Kim",
  "email": "sarah.kim@zenith.com",
  "phone": "555-0205",
  "bio": "Dance fitness instructor specializing in Zumba and contemporary dance",
  "specializations": "Dance,Zumba,Cardio",
  "hireDate": "2025-01-01"
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Maya",
  "lastName": "Singh",
  "email": "maya.singh@zenith.com",
  "phone": "555-0201-new",
  "bio": "Certified yoga and pilates instructor with 10+ years of experience - updated bio",
  "specializations": "Yoga,Pilates,Meditation,Flexibility",
  "isActive": true
}

### Get instructor schedule
GET {{baseUrl}}/api/instructors/1/schedule

### Get instructor schedule with date filter
GET {{baseUrl}}/api/instructors/2/schedule?fromDate=2025-01-01&toDate=2025-12-31

#############################
# CLASS TYPES
#############################

### List all class types
GET {{baseUrl}}/api/class-types?page=1&pageSize=10

### List premium class types
GET {{baseUrl}}/api/class-types?isPremium=true

### List class types by difficulty
GET {{baseUrl}}/api/class-types?difficulty=Advanced

### Get class type details
GET {{baseUrl}}/api/class-types/1

### Create a new class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Zumba",
  "description": "Dance-based fitness class with Latin music",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 30,
  "isPremium": false,
  "caloriesPerSession": 400,
  "difficultyLevel": "AllLevels"
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Traditional yoga combining poses, breathing exercises, and meditation - updated",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 250,
  "difficultyLevel": "AllLevels",
  "isActive": true
}

#############################
# CLASS SCHEDULES
#############################

### List all class schedules (paginated)
GET {{baseUrl}}/api/classes?page=1&pageSize=20

### Filter classes by class type
GET {{baseUrl}}/api/classes?classTypeId=1

### Filter classes by instructor
GET {{baseUrl}}/api/classes?instructorId=1

### Filter available classes only
GET {{baseUrl}}/api/classes?available=true

### Get class schedule details
GET {{baseUrl}}/api/classes/1

### Get full class (has waitlist)
GET {{baseUrl}}/api/classes/2

### Get cancelled class
GET {{baseUrl}}/api/classes/13

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 4,
  "startTime": "2025-07-25T16:00:00",
  "endTime": "2025-07-25T17:00:00",
  "capacity": 20,
  "room": "Studio C"
}

### Update a class schedule
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "instructorId": 1,
  "startTime": "2025-07-20T07:30:00",
  "endTime": "2025-07-20T08:30:00",
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class (cascades to bookings)
PATCH {{baseUrl}}/api/classes/1/cancel
Content-Type: application/json

{
  "reason": "Instructor sick leave"
}

### Get class roster (confirmed members)
GET {{baseUrl}}/api/classes/1/roster

### Get class waitlist
GET {{baseUrl}}/api/classes/2/waitlist

### Get available classes next 7 days
GET {{baseUrl}}/api/classes/available

#############################
# BOOKINGS
#############################

### Create a booking
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 6,
  "memberId": 1
}

### Get booking details
GET {{baseUrl}}/api/bookings/1

### Get waitlisted booking
GET {{baseUrl}}/api/bookings/7

### Cancel a booking
POST {{baseUrl}}/api/bookings/1/cancel
Content-Type: application/json

{
  "reason": "Schedule conflict"
}

### Check in for a class
POST {{baseUrl}}/api/bookings/1/check-in

### Mark booking as no-show
POST {{baseUrl}}/api/bookings/1/no-show

### Try to book a class for non-existent member (404)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 1,
  "memberId": 999
}

### Try to double book same class (409)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 1,
  "memberId": 1
}
