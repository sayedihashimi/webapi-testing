@baseUrl = http://localhost:5058

### ===========================
### MEMBERSHIP PLANS
### ===========================

### List all active membership plans
GET {{baseUrl}}/api/membership-plans

### Get membership plan by ID
GET {{baseUrl}}/api/membership-plans/1

### Get non-existent plan (404)
GET {{baseUrl}}/api/membership-plans/999

### Create a new membership plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students with valid ID",
  "durationMonths": 6,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a membership plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Access to standard classes, 3 bookings per week - Updated",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false,
  "isActive": true
}

### Deactivate a membership plan
DELETE {{baseUrl}}/api/membership-plans/1

### ===========================
### MEMBERS
### ===========================

### List all members (paginated)
GET {{baseUrl}}/api/members?page=1&pageSize=10

### Search members by name
GET {{baseUrl}}/api/members?search=alice

### Filter active members
GET {{baseUrl}}/api/members?isActive=true&page=1&pageSize=5

### Get member by ID (includes active membership and booking count)
GET {{baseUrl}}/api/members/1

### Get non-existent member (404)
GET {{baseUrl}}/api/members/999

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Zara",
  "lastName": "Thompson",
  "email": "zara.thompson@email.com",
  "phone": "555-0901",
  "dateOfBirth": "1998-04-22",
  "emergencyContactName": "Michael Thompson",
  "emergencyContactPhone": "555-0902"
}

### Update a member
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0111",
  "emergencyContactName": "Bob Johnson",
  "emergencyContactPhone": "555-0112"
}

### Deactivate a member (may fail if they have future bookings)
DELETE {{baseUrl}}/api/members/8

### Get member's bookings (paginated, filterable)
GET {{baseUrl}}/api/members/1/bookings?page=1&pageSize=10

### Get member's bookings filtered by status
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed

### Get member's upcoming confirmed bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get member's membership history
GET {{baseUrl}}/api/members/1/memberships

### ===========================
### MEMBERSHIPS
### ===========================

### Create a new membership (for member 7 who has no active membership)
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 7,
  "membershipPlanId": 1,
  "startDate": "2025-07-01",
  "paymentStatus": "Paid"
}

### Get membership by ID
GET {{baseUrl}}/api/memberships/1

### Get non-existent membership (404)
GET {{baseUrl}}/api/memberships/999

### Cancel a membership
POST {{baseUrl}}/api/memberships/8/cancel

### Freeze a membership (7-30 days)
POST {{baseUrl}}/api/memberships/1/freeze
Content-Type: application/json

{
  "durationDays": 14
}

### Unfreeze a membership
POST {{baseUrl}}/api/memberships/1/unfreeze

### Renew an expired membership
POST {{baseUrl}}/api/memberships/7/renew

### ===========================
### INSTRUCTORS
### ===========================

### List all instructors
GET {{baseUrl}}/api/instructors

### Filter by specialization
GET {{baseUrl}}/api/instructors?specialization=Yoga

### Filter by active status
GET {{baseUrl}}/api/instructors?isActive=true

### Get instructor by ID
GET {{baseUrl}}/api/instructors/1

### Create a new instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Elena",
  "lastName": "Volkov",
  "email": "elena.volkov@zenithfitness.com",
  "phone": "555-1005",
  "bio": "Former Olympic gymnast with expertise in flexibility training",
  "specializations": "Yoga,Pilates",
  "hireDate": "2025-06-01"
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Kim",
  "email": "sarah.kim@zenithfitness.com",
  "phone": "555-1001",
  "bio": "Certified yoga instructor with 12 years of experience",
  "specializations": "Yoga,Pilates,Meditation,Breathwork",
  "isActive": true
}

### Get instructor's schedule
GET {{baseUrl}}/api/instructors/1/schedule

### Get instructor's schedule filtered by date range
GET {{baseUrl}}/api/instructors/2/schedule?fromDate=2025-07-07&toDate=2025-07-14

### ===========================
### CLASS TYPES
### ===========================

### List all class types
GET {{baseUrl}}/api/class-types

### Filter by difficulty level
GET {{baseUrl}}/api/class-types?difficulty=Beginner

### Filter premium classes
GET {{baseUrl}}/api/class-types?isPremium=true

### Get class type by ID
GET {{baseUrl}}/api/class-types/1

### Create a new class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Zumba",
  "description": "Dance-based fitness class with Latin-inspired music",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 30,
  "isPremium": false,
  "caloriesPerSession": 400,
  "difficultyLevel": "AllLevels"
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Vinyasa flow yoga for flexibility, mindfulness, and strength",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 300,
  "difficultyLevel": "AllLevels",
  "isActive": true
}

### ===========================
### CLASS SCHEDULES
### ===========================

### List all class schedules (paginated)
GET {{baseUrl}}/api/classes?page=1&pageSize=10

### Filter by date range
GET {{baseUrl}}/api/classes?fromDate=2025-07-07&toDate=2025-07-09

### Filter by class type
GET {{baseUrl}}/api/classes?classTypeId=1

### Filter by instructor
GET {{baseUrl}}/api/classes?instructorId=2

### Filter classes with availability
GET {{baseUrl}}/api/classes?hasAvailability=true

### Get class schedule by ID
GET {{baseUrl}}/api/classes/1

### Get full class (class 11 is at capacity)
GET {{baseUrl}}/api/classes/11

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 1,
  "startTime": "2025-07-14T10:00:00",
  "endTime": "2025-07-14T11:00:00",
  "capacity": 20,
  "room": "Studio A"
}

### Update a class schedule
PUT {{baseUrl}}/api/classes/9
Content-Type: application/json

{
  "instructorId": 2,
  "startTime": "2025-07-11T08:00:00",
  "endTime": "2025-07-11T08:45:00",
  "capacity": 15,
  "room": "Spin Room"
}

### Cancel a class (cascades to all bookings)
PATCH {{baseUrl}}/api/classes/12/cancel
Content-Type: application/json

{
  "reason": "Instructor unavailable due to emergency"
}

### Get class roster (confirmed members)
GET {{baseUrl}}/api/classes/1/roster

### Get class waitlist
GET {{baseUrl}}/api/classes/11/waitlist

### Get available classes (spots open in next 7 days)
GET {{baseUrl}}/api/classes/available

### ===========================
### BOOKINGS
### ===========================

### Get a booking by ID
GET {{baseUrl}}/api/bookings/1

### Get non-existent booking (404)
GET {{baseUrl}}/api/bookings/999

### Book a class (member 6 booking class 7)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 7,
  "memberId": 6
}

### Cancel a booking (promotes waitlisted member if applicable)
POST {{baseUrl}}/api/bookings/1/cancel
Content-Type: application/json

{
  "reason": "Schedule conflict"
}

### Check in to a class (must be within 15 min window)
POST {{baseUrl}}/api/bookings/1/check-in

### Mark booking as no-show (15 min after class start)
POST {{baseUrl}}/api/bookings/1/no-show
