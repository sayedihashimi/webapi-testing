@baseUrl = http://localhost:5000

### ==========================================
### OWNERS
### ==========================================

### List all owners
GET {{baseUrl}}/api/owners?page=1&pageSize=10

### Search owners by name
GET {{baseUrl}}/api/owners?search=johnson

### Get owner by ID (includes pets)
GET {{baseUrl}}/api/owners/1

### Create a new owner
POST {{baseUrl}}/api/owners
Content-Type: application/json

{
  "firstName": "David",
  "lastName": "Thompson",
  "email": "david.thompson@email.com",
  "phone": "555-0106",
  "address": "100 Birch Road",
  "city": "Chicago",
  "state": "IL",
  "zipCode": "60601"
}

### Update owner
PUT {{baseUrl}}/api/owners/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Johnson-Smith",
  "email": "sarah.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Oak Street",
  "city": "Springfield",
  "state": "IL",
  "zipCode": "62701"
}

### Delete owner (will fail if has active pets)
DELETE {{baseUrl}}/api/owners/5

### Get owner's pets
GET {{baseUrl}}/api/owners/1/pets

### Get owner's appointment history
GET {{baseUrl}}/api/owners/1/appointments?page=1&pageSize=10

### ==========================================
### PETS
### ==========================================

### List all active pets
GET {{baseUrl}}/api/pets?page=1&pageSize=10

### Search pets by name
GET {{baseUrl}}/api/pets?search=buddy

### Filter pets by species
GET {{baseUrl}}/api/pets?species=cat

### Include inactive pets
GET {{baseUrl}}/api/pets?includeInactive=true

### Get pet by ID (includes owner info)
GET {{baseUrl}}/api/pets/1

### Create a new pet
POST {{baseUrl}}/api/pets
Content-Type: application/json

{
  "name": "Rocky",
  "species": "Dog",
  "breed": "Labrador Retriever",
  "dateOfBirth": "2023-04-10",
  "weight": 28.5,
  "color": "Chocolate",
  "microchipNumber": "MC-009-2023",
  "ownerId": 2
}

### Update pet (ownership transfer)
PUT {{baseUrl}}/api/pets/4
Content-Type: application/json

{
  "name": "Luna",
  "species": "Cat",
  "breed": "Persian",
  "dateOfBirth": "2022-05-08",
  "weight": 4.0,
  "color": "White",
  "ownerId": 1
}

### Soft delete pet
DELETE {{baseUrl}}/api/pets/8

### Get pet's medical records
GET {{baseUrl}}/api/pets/1/medical-records

### Get pet's vaccinations
GET {{baseUrl}}/api/pets/1/vaccinations

### Get pet's upcoming/overdue vaccinations
GET {{baseUrl}}/api/pets/3/vaccinations/upcoming

### Get pet's active prescriptions
GET {{baseUrl}}/api/pets/1/prescriptions/active

### ==========================================
### VETERINARIANS
### ==========================================

### List all veterinarians
GET {{baseUrl}}/api/veterinarians?page=1&pageSize=10

### Filter by specialization
GET {{baseUrl}}/api/veterinarians?specialization=surgery

### Filter by availability
GET {{baseUrl}}/api/veterinarians?isAvailable=true

### Get veterinarian by ID
GET {{baseUrl}}/api/veterinarians/1

### Create a new veterinarian
POST {{baseUrl}}/api/veterinarians
Content-Type: application/json

{
  "firstName": "Dr. Kevin",
  "lastName": "Park",
  "email": "kevin.park@happypaws.com",
  "phone": "555-0204",
  "specialization": "Dermatology",
  "licenseNumber": "VET-2023-004",
  "hireDate": "2023-09-01"
}

### Update veterinarian
PUT {{baseUrl}}/api/veterinarians/1
Content-Type: application/json

{
  "firstName": "Dr. Amanda",
  "lastName": "Foster",
  "email": "amanda.foster@happypaws.com",
  "phone": "555-0201",
  "specialization": "General Practice & Internal Medicine",
  "licenseNumber": "VET-2015-001",
  "isAvailable": true
}

### Get veterinarian schedule for a date
GET {{baseUrl}}/api/veterinarians/1/schedule?date=2025-01-10

### Get veterinarian's appointments (with status filter)
GET {{baseUrl}}/api/veterinarians/1/appointments?status=Completed&page=1&pageSize=10

### ==========================================
### APPOINTMENTS
### ==========================================

### List all appointments
GET {{baseUrl}}/api/appointments?page=1&pageSize=10

### Filter by date range
GET {{baseUrl}}/api/appointments?dateFrom=2025-01-01&dateTo=2025-01-31

### Filter by status
GET {{baseUrl}}/api/appointments?status=Scheduled

### Filter by vet
GET {{baseUrl}}/api/appointments?vetId=1

### Get today's appointments
GET {{baseUrl}}/api/appointments/today

### Get appointment by ID (full details)
GET {{baseUrl}}/api/appointments/1

### Schedule a new appointment
POST {{baseUrl}}/api/appointments
Content-Type: application/json

{
  "petId": 4,
  "veterinarianId": 1,
  "appointmentDate": "2025-08-15T14:00:00Z",
  "durationMinutes": 30,
  "reason": "Annual wellness exam",
  "notes": "Owner reports decreased appetite"
}

### Update appointment
PUT {{baseUrl}}/api/appointments/6
Content-Type: application/json

{
  "appointmentDate": "2025-07-25T10:00:00Z",
  "durationMinutes": 45,
  "veterinarianId": 1,
  "reason": "Follow-up checkup - extended duration",
  "notes": "Need to check dental health as well"
}

### Update appointment status - Check in
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "CheckedIn"
}

### Update appointment status - Cancel (requires reason)
PATCH {{baseUrl}}/api/appointments/7/status
Content-Type: application/json

{
  "status": "Cancelled",
  "cancellationReason": "Owner requested reschedule due to travel"
}

### ==========================================
### MEDICAL RECORDS
### ==========================================

### Get medical record by ID (includes prescriptions)
GET {{baseUrl}}/api/medical-records/1

### Create a medical record (for completed/in-progress appointment)
POST {{baseUrl}}/api/medical-records
Content-Type: application/json

{
  "appointmentId": 1,
  "diagnosis": "Healthy - annual checkup complete",
  "treatment": "No treatment needed. Continue current care.",
  "notes": "All vitals within normal range",
  "followUpDate": "2026-01-10"
}

### Update medical record
PUT {{baseUrl}}/api/medical-records/1
Content-Type: application/json

{
  "diagnosis": "Healthy - no issues found. Slight weight gain noted.",
  "treatment": "Recommend reducing treat intake and increasing exercise by 10 minutes daily.",
  "notes": "Weight increased by 1.5kg since last visit",
  "followUpDate": "2025-07-10"
}

### ==========================================
### PRESCRIPTIONS
### ==========================================

### Get prescription by ID
GET {{baseUrl}}/api/prescriptions/1

### Create a prescription
POST {{baseUrl}}/api/prescriptions
Content-Type: application/json

{
  "medicalRecordId": 2,
  "medicationName": "Tramadol",
  "dosage": "50mg twice daily",
  "durationDays": 7,
  "startDate": "2025-01-12",
  "instructions": "Give with food. May cause drowsiness."
}

### ==========================================
### VACCINATIONS
### ==========================================

### Record a vaccination
POST {{baseUrl}}/api/vaccinations
Content-Type: application/json

{
  "petId": 3,
  "vaccineName": "Rabies",
  "dateAdministered": "2025-01-20",
  "expirationDate": "2028-01-20",
  "batchNumber": "RAB-2025-1010",
  "administeredByVetId": 2,
  "notes": "3-year rabies vaccine renewal"
}

### Get vaccination by ID
GET {{baseUrl}}/api/vaccinations/1

### ==========================================
### ERROR SCENARIOS
### ==========================================

### Get non-existent owner (404)
GET {{baseUrl}}/api/owners/999

### Get non-existent pet (404)
GET {{baseUrl}}/api/pets/999
