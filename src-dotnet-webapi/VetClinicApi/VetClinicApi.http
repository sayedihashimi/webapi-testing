@baseUrl = http://localhost:5143

# ========================================
# OWNERS
# ========================================

### List all owners (paginated)
GET {{baseUrl}}/api/owners?page=1&pageSize=10

### Search owners by name
GET {{baseUrl}}/api/owners?search=Johnson&page=1&pageSize=10

### Search owners by email
GET {{baseUrl}}/api/owners?search=michael.chen&page=1&pageSize=10

### Get owner by ID (with pets)
GET {{baseUrl}}/api/owners/1

### Get non-existent owner (404)
GET {{baseUrl}}/api/owners/999

### Create a new owner
POST {{baseUrl}}/api/owners
Content-Type: application/json

{
  "firstName": "David",
  "lastName": "Brown",
  "email": "david.brown@email.com",
  "phone": "555-0106",
  "address": "100 Birch Boulevard",
  "city": "Chicago",
  "state": "IL",
  "zipCode": "60601"
}

### Update owner
PUT {{baseUrl}}/api/owners/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Johnson-Smith",
  "email": "sarah.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Oak Street",
  "city": "Springfield",
  "state": "IL",
  "zipCode": "62701"
}

### Delete owner (will fail if has active pets)
DELETE {{baseUrl}}/api/owners/5

### Get owner's pets
GET {{baseUrl}}/api/owners/1/pets

### Get owner's appointment history
GET {{baseUrl}}/api/owners/1/appointments?page=1&pageSize=10

# ========================================
# PETS
# ========================================

### List all active pets (paginated)
GET {{baseUrl}}/api/pets?page=1&pageSize=10

### Search pets by name
GET {{baseUrl}}/api/pets?search=Buddy&page=1&pageSize=10

### Filter pets by species
GET {{baseUrl}}/api/pets?species=Cat&page=1&pageSize=10

### List pets including inactive
GET {{baseUrl}}/api/pets?includeInactive=true&page=1&pageSize=10

### Get pet by ID (with owner)
GET {{baseUrl}}/api/pets/1

### Get non-existent pet (404)
GET {{baseUrl}}/api/pets/999

### Create a new pet
POST {{baseUrl}}/api/pets
Content-Type: application/json

{
  "name": "Charlie",
  "species": "Dog",
  "breed": "Poodle",
  "dateOfBirth": "2022-06-15",
  "weight": 12.5,
  "color": "White",
  "microchipNumber": "MC-009-2022",
  "ownerId": 2
}

### Update a pet (ownership transfer)
PUT {{baseUrl}}/api/pets/1
Content-Type: application/json

{
  "name": "Buddy",
  "species": "Dog",
  "breed": "Golden Retriever",
  "dateOfBirth": "2020-03-15",
  "weight": 33.0,
  "color": "Golden",
  "microchipNumber": "MC-001-2020",
  "ownerId": 1
}

### Soft delete a pet
DELETE {{baseUrl}}/api/pets/7

### Get pet medical records
GET {{baseUrl}}/api/pets/1/medical-records?page=1&pageSize=10

### Get pet vaccinations
GET {{baseUrl}}/api/pets/1/vaccinations

### Get pet upcoming/overdue vaccinations
GET {{baseUrl}}/api/pets/2/vaccinations/upcoming

### Get pet's expired vaccinations
GET {{baseUrl}}/api/pets/3/vaccinations/upcoming

### Get active prescriptions for a pet
GET {{baseUrl}}/api/pets/3/prescriptions/active

# ========================================
# VETERINARIANS
# ========================================

### List all veterinarians
GET {{baseUrl}}/api/veterinarians?page=1&pageSize=10

### Filter veterinarians by specialization
GET {{baseUrl}}/api/veterinarians?specialization=Surgery&page=1&pageSize=10

### Filter available veterinarians
GET {{baseUrl}}/api/veterinarians?isAvailable=true&page=1&pageSize=10

### Get veterinarian by ID
GET {{baseUrl}}/api/veterinarians/1

### Create a new veterinarian
POST {{baseUrl}}/api/veterinarians
Content-Type: application/json

{
  "firstName": "Dr. Jennifer",
  "lastName": "Kim",
  "email": "dr.kim@happypaws.com",
  "phone": "555-0204",
  "specialization": "Dermatology",
  "licenseNumber": "VET-2022-004",
  "isAvailable": true,
  "hireDate": "2022-09-01"
}

### Update a veterinarian
PUT {{baseUrl}}/api/veterinarians/1
Content-Type: application/json

{
  "firstName": "Dr. Robert",
  "lastName": "Smith",
  "email": "dr.smith@happypaws.com",
  "phone": "555-0201",
  "specialization": "General Practice & Internal Medicine",
  "licenseNumber": "VET-2015-001",
  "isAvailable": true,
  "hireDate": "2015-06-01"
}

### Get veterinarian schedule for a specific date
GET {{baseUrl}}/api/veterinarians/1/schedule?date=2025-03-20

### Get veterinarian appointments (paginated)
GET {{baseUrl}}/api/veterinarians/1/appointments?page=1&pageSize=10

### Get veterinarian appointments filtered by status
GET {{baseUrl}}/api/veterinarians/1/appointments?status=Completed&page=1&pageSize=10

# ========================================
# APPOINTMENTS
# ========================================

### List all appointments (paginated)
GET {{baseUrl}}/api/appointments?page=1&pageSize=10

### Filter appointments by status
GET {{baseUrl}}/api/appointments?status=Scheduled&page=1&pageSize=10

### Filter appointments by veterinarian
GET {{baseUrl}}/api/appointments?vetId=1&page=1&pageSize=10

### Filter appointments by pet
GET {{baseUrl}}/api/appointments?petId=1&page=1&pageSize=10

### Get today's appointments
GET {{baseUrl}}/api/appointments/today

### Get appointment by ID (with pet, vet, medical record)
GET {{baseUrl}}/api/appointments/1

### Schedule a new appointment
POST {{baseUrl}}/api/appointments
Content-Type: application/json

{
  "petId": 4,
  "veterinarianId": 1,
  "appointmentDate": "2025-04-15T10:00:00Z",
  "durationMinutes": 30,
  "reason": "Annual wellness examination",
  "notes": "First visit for this pet"
}

### Update an appointment
PUT {{baseUrl}}/api/appointments/6
Content-Type: application/json

{
  "petId": 1,
  "veterinarianId": 1,
  "appointmentDate": "2025-04-16T14:00:00Z",
  "durationMinutes": 45,
  "reason": "Follow-up checkup - extended",
  "notes": "Bring previous lab results"
}

### Check in an appointment
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "CheckedIn"
}

### Start an appointment (CheckedIn → InProgress)
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "InProgress"
}

### Complete an appointment (InProgress → Completed)
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "status": "Completed"
}

### Cancel an appointment (requires reason)
PATCH {{baseUrl}}/api/appointments/7/status
Content-Type: application/json

{
  "status": "Cancelled",
  "cancellationReason": "Pet owner called to reschedule due to work conflict"
}

### Mark as NoShow
PATCH {{baseUrl}}/api/appointments/8/status
Content-Type: application/json

{
  "status": "NoShow"
}

# ========================================
# MEDICAL RECORDS
# ========================================

### Get medical record by ID (with prescriptions)
GET {{baseUrl}}/api/medical-records/1

### Get medical record for dental cleaning
GET {{baseUrl}}/api/medical-records/2

### Create a medical record (appointment must be Completed or InProgress)
POST {{baseUrl}}/api/medical-records
Content-Type: application/json

{
  "appointmentId": 6,
  "diagnosis": "Healthy overall, minor ear infection in left ear",
  "treatment": "Ear cleaning performed. Prescribed ear drops for 10 days.",
  "notes": "Recommend follow-up in 2 weeks to check ear infection progress.",
  "followUpDate": "2025-04-30"
}

### Update a medical record
PUT {{baseUrl}}/api/medical-records/1
Content-Type: application/json

{
  "diagnosis": "Healthy - annual exam. Slight weight gain noted.",
  "treatment": "No treatment required. Updated vaccinations. Diet adjustment recommended.",
  "notes": "Weight increased 1.5kg since last visit. Recommend reducing treats and increasing exercise.",
  "followUpDate": "2025-09-15"
}

# ========================================
# PRESCRIPTIONS
# ========================================

### Get prescription by ID
GET {{baseUrl}}/api/prescriptions/1

### Get active prescription
GET {{baseUrl}}/api/prescriptions/2

### Create a prescription
POST {{baseUrl}}/api/prescriptions
Content-Type: application/json

{
  "medicalRecordId": 1,
  "medicationName": "Apoquel",
  "dosage": "16mg once daily",
  "durationDays": 14,
  "startDate": "2025-03-17",
  "instructions": "Give with food in the morning. Monitor for any vomiting."
}

# ========================================
# VACCINATIONS
# ========================================

### Get vaccination by ID
GET {{baseUrl}}/api/vaccinations/1

### Get expired vaccination
GET {{baseUrl}}/api/vaccinations/4

### Get vaccination expiring soon
GET {{baseUrl}}/api/vaccinations/3

### Record a new vaccination
POST {{baseUrl}}/api/vaccinations
Content-Type: application/json

{
  "petId": 3,
  "vaccineName": "Rabies",
  "dateAdministered": "2025-03-17",
  "expirationDate": "2026-03-17",
  "batchNumber": "RAB-2025-G1",
  "administeredByVetId": 2,
  "notes": "Renewal of expired rabies vaccine"
}
