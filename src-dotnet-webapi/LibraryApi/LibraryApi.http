@baseUrl = http://localhost:5142

##############################################
# AUTHORS
##############################################

### List all authors
GET {{baseUrl}}/api/authors

### List authors with search and pagination
GET {{baseUrl}}/api/authors?search=asimov&page=1&pageSize=5

### Get author by ID (with books)
GET {{baseUrl}}/api/authors/2

### Get non-existent author (404)
GET {{baseUrl}}/api/authors/999

### Create a new author
POST {{baseUrl}}/api/authors
Content-Type: application/json

{
  "firstName": "Ursula",
  "lastName": "Le Guin",
  "biography": "American author known for science fiction and fantasy works.",
  "birthDate": "1929-10-21",
  "country": "United States"
}

### Update an author
PUT {{baseUrl}}/api/authors/1
Content-Type: application/json

{
  "firstName": "Gabriel",
  "lastName": "García Márquez",
  "biography": "Colombian novelist, Nobel Prize in Literature 1982, pioneer of magical realism.",
  "birthDate": "1927-03-06",
  "country": "Colombia"
}

### Delete an author (should fail - has books, 409)
DELETE {{baseUrl}}/api/authors/1

##############################################
# CATEGORIES
##############################################

### List all categories
GET {{baseUrl}}/api/categories

### Get category by ID (with book count)
GET {{baseUrl}}/api/categories/1

### Get non-existent category (404)
GET {{baseUrl}}/api/categories/999

### Create a new category
POST {{baseUrl}}/api/categories
Content-Type: application/json

{
  "name": "Philosophy",
  "description": "Works exploring fundamental questions about existence, knowledge, and ethics."
}

### Update a category
PUT {{baseUrl}}/api/categories/1
Content-Type: application/json

{
  "name": "Fiction",
  "description": "Literary works created from the imagination, including novels and short stories."
}

### Delete a category (should fail - has books, 409)
DELETE {{baseUrl}}/api/categories/1

##############################################
# BOOKS
##############################################

### List all books
GET {{baseUrl}}/api/books

### Search books by title
GET {{baseUrl}}/api/books?search=foundation&page=1&pageSize=5

### Filter available books
GET {{baseUrl}}/api/books?available=true

### Search by category and sort by year
GET {{baseUrl}}/api/books?category=science+fiction&sortBy=year_desc

### Search by author name
GET {{baseUrl}}/api/books?search=austen

### Get book by ID (with authors, categories)
GET {{baseUrl}}/api/books/1

### Get non-existent book (404)
GET {{baseUrl}}/api/books/999

### Create a new book
POST {{baseUrl}}/api/books
Content-Type: application/json

{
  "title": "The Left Hand of Darkness",
  "isbn": "978-0441007318",
  "publisher": "Ace Books",
  "publicationYear": 1969,
  "description": "A groundbreaking work exploring gender and society on an alien planet.",
  "pageCount": 304,
  "language": "English",
  "totalCopies": 3,
  "authorIds": [2],
  "categoryIds": [2]
}

### Update a book
PUT {{baseUrl}}/api/books/1
Content-Type: application/json

{
  "title": "One Hundred Years of Solitude",
  "isbn": "978-0060883287",
  "publisher": "Harper Perennial Modern Classics",
  "publicationYear": 1967,
  "description": "The multi-generational story of the Buendía family in Macondo.",
  "pageCount": 417,
  "language": "English",
  "totalCopies": 5,
  "authorIds": [1],
  "categoryIds": [1, 6]
}

### Delete a book (should fail - has active loans, 409)
DELETE {{baseUrl}}/api/books/1

### Get book loan history
GET {{baseUrl}}/api/books/1/loans

### Get active book reservations
GET {{baseUrl}}/api/books/1/reservations

##############################################
# PATRONS
##############################################

### List all patrons
GET {{baseUrl}}/api/patrons

### Search patrons by name
GET {{baseUrl}}/api/patrons?search=alice

### Filter by membership type
GET {{baseUrl}}/api/patrons?membershipType=Student

### Get patron by ID (with summary)
GET {{baseUrl}}/api/patrons/1

### Get patron with unpaid fines (George - has $12.50 unpaid)
GET {{baseUrl}}/api/patrons/7

### Get non-existent patron (404)
GET {{baseUrl}}/api/patrons/999

### Create a new patron
POST {{baseUrl}}/api/patrons
Content-Type: application/json

{
  "firstName": "Helen",
  "lastName": "Park",
  "email": "helen.park@email.com",
  "phone": "555-0108",
  "address": "258 Walnut Drive",
  "membershipType": "Standard"
}

### Update a patron
PUT {{baseUrl}}/api/patrons/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Oak Street, Apt 4B",
  "membershipType": "Premium"
}

### Deactivate a patron (soft delete - should fail if has active loans)
DELETE {{baseUrl}}/api/patrons/1

### Get patron loans
GET {{baseUrl}}/api/patrons/1/loans

### Get patron loans filtered by status
GET {{baseUrl}}/api/patrons/2/loans?status=Active

### Get patron reservations
GET {{baseUrl}}/api/patrons/4/reservations

### Get patron fines
GET {{baseUrl}}/api/patrons/7/fines

### Get patron fines filtered by status
GET {{baseUrl}}/api/patrons/7/fines?status=Unpaid

##############################################
# LOANS
##############################################

### List all loans
GET {{baseUrl}}/api/loans

### Filter loans by status
GET {{baseUrl}}/api/loans?status=Active

### Filter overdue loans
GET {{baseUrl}}/api/loans?overdue=true

### Get all overdue loans (dedicated endpoint)
GET {{baseUrl}}/api/loans/overdue

### Get loan by ID
GET {{baseUrl}}/api/loans/1

### Get non-existent loan (404)
GET {{baseUrl}}/api/loans/999

### Checkout a book (valid)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 6,
  "patronId": 4
}

### Checkout - patron with too many fines (George has $12.50 unpaid - should fail, 400)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 6,
  "patronId": 7
}

### Checkout - inactive patron (Edward - should fail, 400)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 6,
  "patronId": 5
}

### Checkout - no available copies test (use a book with 0 available)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 11,
  "patronId": 4
}

### Return a book (returned loan)
POST {{baseUrl}}/api/loans/4/return

### Return an overdue book (loan 8 is overdue - will generate fine)
POST {{baseUrl}}/api/loans/8/return

### Return already returned book (should fail, 400)
POST {{baseUrl}}/api/loans/6/return

### Renew a loan (loan 1 is active)
POST {{baseUrl}}/api/loans/1/renew

### Renew - loan with pending reservations (loan 3, book 5 has reservation - should fail)
POST {{baseUrl}}/api/loans/3/renew

### Renew - overdue loan (loan 8 is overdue - should fail)
POST {{baseUrl}}/api/loans/8/renew

##############################################
# RESERVATIONS
##############################################

### List all reservations
GET {{baseUrl}}/api/reservations

### Filter reservations by status
GET {{baseUrl}}/api/reservations?status=Pending

### Get reservation by ID
GET {{baseUrl}}/api/reservations/1

### Get non-existent reservation (404)
GET {{baseUrl}}/api/reservations/999

### Create a reservation (valid)
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 7,
  "patronId": 1
}

### Create reservation - patron already has active loan for this book (should fail, 400)
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 1,
  "patronId": 1
}

### Cancel a reservation
POST {{baseUrl}}/api/reservations/1/cancel

### Fulfill a ready reservation (reservation 3 is Ready)
POST {{baseUrl}}/api/reservations/3/fulfill

##############################################
# FINES
##############################################

### List all fines
GET {{baseUrl}}/api/fines

### Filter fines by status
GET {{baseUrl}}/api/fines?status=Unpaid

### Get fine by ID
GET {{baseUrl}}/api/fines/1

### Get non-existent fine (404)
GET {{baseUrl}}/api/fines/999

### Pay a fine (fine 3 is Unpaid, $1.25)
POST {{baseUrl}}/api/fines/3/pay

### Pay already paid fine (should fail, 400)
POST {{baseUrl}}/api/fines/1/pay

### Waive a fine (fine 2 is Unpaid, $12.50)
POST {{baseUrl}}/api/fines/2/waive

### Waive already waived fine (should fail, 400)
POST {{baseUrl}}/api/fines/4/waive
