@baseUrl = http://localhost:5011

### ========== AUTHORS ==========

### List all authors
GET {{baseUrl}}/api/authors?page=1&pageSize=10

### Search authors by name
GET {{baseUrl}}/api/authors?search=Asimov

### Get author by ID (Isaac Asimov)
GET {{baseUrl}}/api/authors/3

### Create a new author
POST {{baseUrl}}/api/authors
Content-Type: application/json

{
  "firstName": "Margaret",
  "lastName": "Atwood",
  "biography": "Canadian poet, novelist, and literary critic.",
  "birthDate": "1939-11-18",
  "country": "Canada"
}

### Update an author
PUT {{baseUrl}}/api/authors/3
Content-Type: application/json

{
  "firstName": "Isaac",
  "lastName": "Asimov",
  "biography": "American author and biochemistry professor, one of the most prolific science fiction writers of all time.",
  "birthDate": "1920-01-02",
  "country": "United States"
}

### Delete an author (will fail if has books)
DELETE {{baseUrl}}/api/authors/1

### ========== CATEGORIES ==========

### List all categories
GET {{baseUrl}}/api/categories

### Get category by ID (Fiction)
GET {{baseUrl}}/api/categories/1

### Create a new category
POST {{baseUrl}}/api/categories
Content-Type: application/json

{
  "name": "Philosophy",
  "description": "Works exploring fundamental questions about existence and knowledge"
}

### Update a category
PUT {{baseUrl}}/api/categories/1
Content-Type: application/json

{
  "name": "Fiction",
  "description": "Literary works created from the imagination, including novels and short stories"
}

### Delete a category (will fail if has books)
DELETE {{baseUrl}}/api/categories/5

### ========== BOOKS ==========

### List all books
GET {{baseUrl}}/api/books?page=1&pageSize=10

### Search books by title
GET {{baseUrl}}/api/books?search=Robot

### Filter books by category (Science Fiction = 2)
GET {{baseUrl}}/api/books?categoryId=2

### Filter books by author (Harari = 4)
GET {{baseUrl}}/api/books?authorId=4

### Sort books by year descending
GET {{baseUrl}}/api/books?sortBy=year&sortDirection=desc

### Get book by ID (1984)
GET {{baseUrl}}/api/books/2

### Create a new book
POST {{baseUrl}}/api/books
Content-Type: application/json

{
  "title": "The Handmaid's Tale",
  "isbn": "978-0-385-49081-8",
  "publisher": "McClelland and Stewart",
  "publicationYear": 1985,
  "description": "A dystopian novel set in a totalitarian theocracy.",
  "pageCount": 311,
  "language": "English",
  "totalCopies": 3,
  "authorIds": [1],
  "categoryIds": [1, 2]
}

### Update a book
PUT {{baseUrl}}/api/books/2
Content-Type: application/json

{
  "title": "1984",
  "isbn": "978-0-452-28423-4",
  "publisher": "Secker & Warburg",
  "publicationYear": 1949,
  "description": "A dystopian novel about totalitarianism, surveillance, and thought control.",
  "pageCount": 328,
  "language": "English",
  "totalCopies": 5,
  "authorIds": [2],
  "categoryIds": [1, 2]
}

### Delete a book (will fail if has active loans)
DELETE {{baseUrl}}/api/books/2

### Get loan history for a book
GET {{baseUrl}}/api/books/1/loans

### Get active reservations for a book
GET {{baseUrl}}/api/books/1/reservations

### ========== PATRONS ==========

### List all patrons
GET {{baseUrl}}/api/patrons?page=1&pageSize=10

### Search patrons
GET {{baseUrl}}/api/patrons?search=Alice

### Filter patrons by membership type
GET {{baseUrl}}/api/patrons?membershipType=Premium

### Filter active patrons only
GET {{baseUrl}}/api/patrons?isActive=true

### Get patron by ID (Alice Johnson - Premium)
GET {{baseUrl}}/api/patrons/1

### Get patron by ID (Bob Smith - see unpaid fines)
GET {{baseUrl}}/api/patrons/2

### Create a new patron
POST {{baseUrl}}/api/patrons
Content-Type: application/json

{
  "firstName": "Grace",
  "lastName": "Taylor",
  "email": "grace.taylor@email.com",
  "phone": "555-0107",
  "address": "111 Walnut Street",
  "membershipType": "Standard"
}

### Update a patron
PUT {{baseUrl}}/api/patrons/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Oak Street, Apt 2B",
  "membershipType": "Premium"
}

### Deactivate a patron (will fail if has active loans)
DELETE {{baseUrl}}/api/patrons/5

### Get patron's loans
GET {{baseUrl}}/api/patrons/1/loans

### Get patron's active loans only
GET {{baseUrl}}/api/patrons/2/loans?status=Active

### Get patron's reservations
GET {{baseUrl}}/api/patrons/4/reservations

### Get patron's fines
GET {{baseUrl}}/api/patrons/2/fines

### Get patron's unpaid fines
GET {{baseUrl}}/api/patrons/2/fines?status=Unpaid

### ========== LOANS ==========

### List all loans
GET {{baseUrl}}/api/loans?page=1&pageSize=10

### List active loans
GET {{baseUrl}}/api/loans?status=Active

### List overdue loans
GET {{baseUrl}}/api/loans/overdue

### Get loan by ID
GET {{baseUrl}}/api/loans/1

### Checkout a book (new loan - David borrows Steve Jobs)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 8,
  "patronId": 4
}

### Return a book (return Bob's overdue TKAM loan - generates fine)
POST {{baseUrl}}/api/loans/5/return

### Renew a loan (Alice's 1984 loan)
POST {{baseUrl}}/api/loans/1/renew

### ===== LOAN BUSINESS RULE TESTS =====

### Checkout - inactive patron (Eve Davis, id=5 is inactive)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 8,
  "patronId": 5
}

### Checkout - no available copies (try a book with 0 available)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 99,
  "patronId": 1
}

### ========== RESERVATIONS ==========

### List all reservations
GET {{baseUrl}}/api/reservations?page=1&pageSize=10

### List pending reservations
GET {{baseUrl}}/api/reservations?status=Pending

### Get reservation by ID
GET {{baseUrl}}/api/reservations/1

### Create a reservation (Frank reserves Sapiens)
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 6,
  "patronId": 6
}

### Cancel a reservation
POST {{baseUrl}}/api/reservations/2/cancel

### Fulfill a ready reservation (reservation 3 is Ready)
POST {{baseUrl}}/api/reservations/3/fulfill

### ===== RESERVATION BUSINESS RULE TESTS =====

### Cannot reserve book you have on loan (Alice has 1984 on loan)
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 2,
  "patronId": 1
}

### ========== FINES ==========

### List all fines
GET {{baseUrl}}/api/fines?page=1&pageSize=10

### List unpaid fines
GET {{baseUrl}}/api/fines?status=Unpaid

### Get fine by ID
GET {{baseUrl}}/api/fines/1

### Pay a fine (Bob's $1.50 fine)
POST {{baseUrl}}/api/fines/1/pay

### Waive a fine (Frank's $0.75 fine)
POST {{baseUrl}}/api/fines/2/waive

### Get a non-existent resource (404 test)
GET {{baseUrl}}/api/authors/999

### Get a non-existent book (404 test)
GET {{baseUrl}}/api/books/999
