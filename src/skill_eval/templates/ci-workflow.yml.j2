# Skill Evaluation CI Workflow
# Generated by: skill-eval ci-setup
# Re-run `skill-eval ci-setup` to update this workflow.

name: Skill Evaluation

on:
  workflow_dispatch:
    inputs:
      skip_generate:
        description: "Skip the code generation step"
        type: boolean
        default: false
      skip_verify:
        description: "Skip the verification step"
        type: boolean
        default: false
      analyze_only:
        description: "Only run the analysis step"
        type: boolean
        default: false
{% if schedule %}
  schedule:
    - cron: "{{ schedule }}"
{% endif %}

jobs:
  evaluate:
    runs-on: {{ runs_on | default('ubuntu-latest') }}
    timeout-minutes: {{ timeout_minutes | default(120) }}

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Install GitHub Copilot CLI
        run: curl -fsSL https://gh.io/copilot-install | bash
        env:
          GITHUB_TOKEN: ${{ '{{' }} secrets.GITHUB_TOKEN {{ '}}' }}

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "{{ python_version | default('3.12') }}"

      - name: Install skill-eval
        run: pip install git+https://github.com/sayedihashimi/copilot-skill-eval

      - name: Validate configuration
        run: |
          skill-eval \
            --config {{ config_path | default('eval.yaml') }}{% if skill_sources_path %} \
            --skill-sources {{ skill_sources_path }}{% endif %} \
            validate-config

      - name: Run evaluation pipeline
        run: |
          ARGS=""
          if [ "${{ '{{' }} inputs.skip_generate {{ '}}' }}" = "true" ]; then
            ARGS="$ARGS --skip-generate"
          fi
          if [ "${{ '{{' }} inputs.skip_verify {{ '}}' }}" = "true" ]; then
            ARGS="$ARGS --skip-verify"
          fi
          if [ "${{ '{{' }} inputs.analyze_only {{ '}}' }}" = "true" ]; then
            ARGS="$ARGS --analyze-only"
          fi
          skill-eval \
            --config {{ config_path | default('eval.yaml') }}{% if skill_sources_path %} \
            --skill-sources {{ skill_sources_path }}{% endif %} \
            run $ARGS
        env:
          GITHUB_TOKEN: ${{ '{{' }} secrets.GITHUB_TOKEN {{ '}}' }}

      - name: Upload reports
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: evaluation-reports
          path: {{ reports_directory | default('reports') }}/

      - name: Upload generated output
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: generated-output
          path: {{ output_directory | default('output') }}/
