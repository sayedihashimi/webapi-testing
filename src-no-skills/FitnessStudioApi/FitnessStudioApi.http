@baseUrl = http://localhost:5283

### ============================
### Membership Plans
### ============================

### List all active membership plans
GET {{baseUrl}}/api/membership-plans

### Get membership plan by ID
GET {{baseUrl}}/api/membership-plans/1

### Create a new membership plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students under 25.",
  "durationMonths": 1,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a membership plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Access to standard classes with limited weekly bookings. Updated!",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false,
  "isActive": true
}

### Deactivate a membership plan
DELETE {{baseUrl}}/api/membership-plans/1

### ============================
### Members
### ============================

### List members (all)
GET {{baseUrl}}/api/members?page=1&pageSize=10

### List members - search by name
GET {{baseUrl}}/api/members?search=alice&page=1&pageSize=10

### List members - filter by active status
GET {{baseUrl}}/api/members?isActive=true&page=1&pageSize=10

### Get member details (includes active membership & booking stats)
GET {{baseUrl}}/api/members/1

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Sofia",
  "lastName": "Reyes",
  "email": "sofia.reyes@email.com",
  "phone": "555-0901",
  "dateOfBirth": "1998-05-20",
  "emergencyContactName": "Miguel Reyes",
  "emergencyContactPhone": "555-0902"
}

### Update member profile
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Alice",
  "lastName": "Johnson",
  "email": "alice.johnson@email.com",
  "phone": "555-0111",
  "dateOfBirth": "1990-03-15",
  "emergencyContactName": "Bob Johnson",
  "emergencyContactPhone": "555-0112"
}

### Deactivate member (will fail if they have future bookings)
DELETE {{baseUrl}}/api/members/7

### Get member's bookings (all)
GET {{baseUrl}}/api/members/1/bookings?page=1&pageSize=10

### Get member's bookings - filter by status
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed&page=1&pageSize=10

### Get member's bookings - filter by date range
GET {{baseUrl}}/api/members/1/bookings?from=2025-01-01T00:00:00&to=2026-12-31T23:59:59&page=1&pageSize=10

### Get member's upcoming confirmed bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get membership history for a member
GET {{baseUrl}}/api/members/1/memberships

### ============================
### Memberships
### ============================

### Create a membership for a member (member 7 Gina has expired membership)
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 7,
  "membershipPlanId": 1,
  "startDate": "2025-07-01",
  "paymentStatus": "Paid"
}

### Get membership details
GET {{baseUrl}}/api/memberships/1

### Cancel a membership
POST {{baseUrl}}/api/memberships/7/cancel

### Freeze a membership (member 4 Derek has active Premium)
POST {{baseUrl}}/api/memberships/4/freeze
Content-Type: application/json

{
  "freezeDurationDays": 14
}

### Unfreeze a membership
POST {{baseUrl}}/api/memberships/4/unfreeze

### Renew an expired membership (Gina's expired membership is ID 7)
POST {{baseUrl}}/api/memberships/7/renew

### ============================
### Instructors
### ============================

### List all instructors
GET {{baseUrl}}/api/instructors

### List instructors - filter by specialization
GET {{baseUrl}}/api/instructors?specialization=Yoga

### List instructors - filter by active status
GET {{baseUrl}}/api/instructors?isActive=true

### Get instructor details
GET {{baseUrl}}/api/instructors/1

### Create an instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Rachel",
  "lastName": "Kim",
  "email": "rachel.kim@zenith.com",
  "phone": "555-1005",
  "bio": "Dance fitness and Zumba specialist.",
  "specializations": "Dance Fitness, Zumba, Cardio",
  "hireDate": "2025-06-01"
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Chen",
  "email": "sarah.chen@zenith.com",
  "phone": "555-1001",
  "bio": "Certified yoga and meditation instructor with 10+ years experience. Also trained in Pilates.",
  "specializations": "Yoga, Meditation, Pilates, Breathwork",
  "isActive": true
}

### Get instructor's class schedule
GET {{baseUrl}}/api/instructors/1/schedule

### Get instructor's class schedule with date range
GET {{baseUrl}}/api/instructors/1/schedule?from=2025-01-01T00:00:00&to=2026-12-31T23:59:59

### ============================
### Class Types
### ============================

### List all class types
GET {{baseUrl}}/api/class-types

### List class types - filter by difficulty
GET {{baseUrl}}/api/class-types?difficulty=Beginner

### List class types - filter by premium status
GET {{baseUrl}}/api/class-types?isPremium=true

### Get class type details
GET {{baseUrl}}/api/class-types/1

### Create a class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Zumba",
  "description": "High-energy dance fitness class.",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 400,
  "difficultyLevel": "AllLevels"
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Relaxing yoga flow for all levels. Updated description.",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 280,
  "difficultyLevel": "AllLevels",
  "isActive": true
}

### ============================
### Class Schedules
### ============================

### List all scheduled classes
GET {{baseUrl}}/api/classes?page=1&pageSize=20

### List classes - filter by date range
GET {{baseUrl}}/api/classes?from=2025-01-01T00:00:00&to=2026-12-31T23:59:59&page=1&pageSize=20

### List classes - filter by class type (Yoga = 1)
GET {{baseUrl}}/api/classes?classTypeId=1&page=1&pageSize=10

### List classes - filter by instructor
GET {{baseUrl}}/api/classes?instructorId=1&page=1&pageSize=10

### List classes - only with availability
GET {{baseUrl}}/api/classes?hasAvailability=true&page=1&pageSize=10

### Get class details (includes availability info)
GET {{baseUrl}}/api/classes/1

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 4,
  "startTime": "2025-07-25T18:00:00",
  "durationMinutes": 60,
  "capacity": 20,
  "room": "Studio A"
}

### Update class schedule details
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 1,
  "startTime": "2025-07-20T09:00:00",
  "endTime": "2025-07-20T10:00:00",
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class (cascades to all bookings)
PATCH {{baseUrl}}/api/classes/12/cancel
Content-Type: application/json

{
  "reason": "Instructor unavailable due to illness"
}

### Get confirmed members roster for a class
GET {{baseUrl}}/api/classes/1/roster

### Get waitlist for a class (class 5 has waitlisted members)
GET {{baseUrl}}/api/classes/5/waitlist

### Get classes with available spots in the next 7 days
GET {{baseUrl}}/api/classes/available

### ============================
### Bookings
### ============================

### Book a class (member 1 Alice, Elite plan - class 7 yoga day 4)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 7,
  "memberId": 1
}

### Get booking details
GET {{baseUrl}}/api/bookings/1

### Cancel a booking (free cancellation, >2hrs before class)
POST {{baseUrl}}/api/bookings/1/cancel
Content-Type: application/json

{
  "reason": "Schedule conflict"
}

### Check in for a class (will fail if not within 15 min window)
POST {{baseUrl}}/api/bookings/1/check-in

### Mark booking as no-show (will fail if not 15 min past class start)
POST {{baseUrl}}/api/bookings/1/no-show

### ============================
### Business Rule Tests
### ============================

### Test: Basic member trying to book a premium class (Boxing is premium, member 3 Carla has Basic plan)
### Expected: 400 - membership plan does not allow premium classes
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 5,
  "memberId": 3
}

### Test: Member without active membership trying to book (member 7 Gina has expired membership)
### Expected: 400 - no active membership
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 7,
  "memberId": 7
}

### Test: Booking a class that is full (class 5 Boxing is at capacity 3/3)
### Expected: Will be waitlisted, not 400
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 5,
  "memberId": 4
}

### Test: Freeze with invalid duration (too short)
### Expected: 400
POST {{baseUrl}}/api/memberships/1/freeze
Content-Type: application/json

{
  "freezeDurationDays": 3
}
