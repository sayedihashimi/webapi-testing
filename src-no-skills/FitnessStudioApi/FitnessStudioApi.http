@baseUrl = http://localhost:5254

### =============================================
### Membership Plans
### =============================================

### List all active membership plans
GET {{baseUrl}}/api/membership-plans

### Get a specific membership plan (Basic)
GET {{baseUrl}}/api/membership-plans/1

### Create a new membership plan
POST {{baseUrl}}/api/membership-plans
Content-Type: application/json

{
  "name": "Student",
  "description": "Discounted plan for students with valid ID.",
  "durationMonths": 6,
  "price": 19.99,
  "maxClassBookingsPerWeek": 2,
  "allowsPremiumClasses": false
}

### Update a membership plan
PUT {{baseUrl}}/api/membership-plans/1
Content-Type: application/json

{
  "name": "Basic",
  "description": "Access to standard classes only. Perfect for beginners. Updated!",
  "durationMonths": 1,
  "price": 34.99,
  "maxClassBookingsPerWeek": 3,
  "allowsPremiumClasses": false,
  "isActive": true
}

### Deactivate a membership plan
DELETE {{baseUrl}}/api/membership-plans/1

### =============================================
### Members
### =============================================

### List all members (default pagination)
GET {{baseUrl}}/api/members

### List members with search
GET {{baseUrl}}/api/members?search=emma&isActive=true&page=1&pageSize=10

### Get member details (Emma Johnson - Premium member)
GET {{baseUrl}}/api/members/1

### Get member details (Olivia Brown - Basic member)
GET {{baseUrl}}/api/members/3

### Register a new member
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Isabella",
  "lastName": "Wilson",
  "email": "isabella.wilson@email.com",
  "phone": "555-0117",
  "dateOfBirth": "1998-06-20",
  "emergencyContactName": "James Wilson",
  "emergencyContactPhone": "555-0118"
}

### Register a member who is too young (should fail - under 16)
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "firstName": "Young",
  "lastName": "Person",
  "email": "young@email.com",
  "phone": "555-9999",
  "dateOfBirth": "2015-01-01",
  "emergencyContactName": "Parent Person",
  "emergencyContactPhone": "555-9998"
}

### Update member profile
PUT {{baseUrl}}/api/members/1
Content-Type: application/json

{
  "firstName": "Emma",
  "lastName": "Johnson",
  "email": "emma.johnson@email.com",
  "phone": "555-0101-updated",
  "emergencyContactName": "Michael Johnson",
  "emergencyContactPhone": "555-0102"
}

### Deactivate a member (Sophia - no active bookings, should succeed)
DELETE {{baseUrl}}/api/members/7

### Get member's bookings with filters
GET {{baseUrl}}/api/members/1/bookings?status=Confirmed&page=1&pageSize=10

### Get member's upcoming confirmed bookings
GET {{baseUrl}}/api/members/1/bookings/upcoming

### Get membership history for a member
GET {{baseUrl}}/api/members/1/memberships

### Get membership history for member with expired membership
GET {{baseUrl}}/api/members/7/memberships

### =============================================
### Memberships
### =============================================

### Create/purchase a membership for a member without one (member 7 - Sophia)
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 7,
  "membershipPlanId": 2,
  "startDate": "2025-07-20",
  "paymentStatus": "Paid"
}

### Get membership details
GET {{baseUrl}}/api/memberships/1

### Cancel a membership
POST {{baseUrl}}/api/memberships/6/cancel

### Freeze a membership (member 4 - Noah, active Premium)
POST {{baseUrl}}/api/memberships/4/freeze
Content-Type: application/json

{
  "freezeDurationDays": 14
}

### Unfreeze a membership
POST {{baseUrl}}/api/memberships/4/unfreeze

### Renew an expired membership (member 8 - Mason, expired Premium)
POST {{baseUrl}}/api/memberships/8/renew

### Try to create duplicate active membership (should fail)
POST {{baseUrl}}/api/memberships
Content-Type: application/json

{
  "memberId": 1,
  "membershipPlanId": 3,
  "startDate": "2025-07-20",
  "paymentStatus": "Paid"
}

### =============================================
### Instructors
### =============================================

### List all instructors
GET {{baseUrl}}/api/instructors

### List instructors filtered by specialization
GET {{baseUrl}}/api/instructors?specialization=yoga&isActive=true

### Get instructor details
GET {{baseUrl}}/api/instructors/1

### Create a new instructor
POST {{baseUrl}}/api/instructors
Content-Type: application/json

{
  "firstName": "Diana",
  "lastName": "Cooper",
  "email": "diana.cooper@zenithfitness.com",
  "phone": "555-0205",
  "bio": "Dance fitness expert with 5 years of experience.",
  "specializations": "Dance, Zumba, Aerobics",
  "hireDate": "2025-01-15"
}

### Update an instructor
PUT {{baseUrl}}/api/instructors/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Chen",
  "email": "sarah.chen@zenithfitness.com",
  "phone": "555-0201",
  "bio": "Certified yoga instructor with 10+ years of experience. Now also teaching dance fitness!",
  "specializations": "Yoga, Pilates, Meditation, Dance",
  "isActive": true
}

### Get instructor's class schedule
GET {{baseUrl}}/api/instructors/1/schedule

### Get instructor's schedule with date range
GET {{baseUrl}}/api/instructors/2/schedule?fromDate=2025-07-20&toDate=2025-07-27

### =============================================
### Class Types
### =============================================

### List all class types
GET {{baseUrl}}/api/class-types

### List premium class types only
GET {{baseUrl}}/api/class-types?isPremium=true

### List class types by difficulty
GET {{baseUrl}}/api/class-types?difficulty=beginner

### Get class type details
GET {{baseUrl}}/api/class-types/1

### Create a new class type
POST {{baseUrl}}/api/class-types
Content-Type: application/json

{
  "name": "Zumba",
  "description": "Dance-based fitness class with Latin music.",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 400,
  "difficultyLevel": "AllLevels"
}

### Update a class type
PUT {{baseUrl}}/api/class-types/1
Content-Type: application/json

{
  "name": "Yoga",
  "description": "Traditional yoga focusing on flexibility, balance, and mindfulness. Updated with hot yoga option.",
  "defaultDurationMinutes": 60,
  "defaultCapacity": 25,
  "isPremium": false,
  "caloriesPerSession": 300,
  "difficultyLevel": "AllLevels",
  "isActive": true
}

### =============================================
### Class Schedules
### =============================================

### List all scheduled classes
GET {{baseUrl}}/api/classes

### List classes with filters
GET {{baseUrl}}/api/classes?classTypeId=1&page=1&pageSize=10

### List classes with availability only
GET {{baseUrl}}/api/classes?hasAvailability=true

### Get class details (Yoga class)
GET {{baseUrl}}/api/classes/1

### Get class details (full Spin class with waitlist)
GET {{baseUrl}}/api/classes/3

### Get available classes in next 7 days
GET {{baseUrl}}/api/classes/available

### Schedule a new class
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 3,
  "startTime": "2025-07-25T10:00:00",
  "endTime": "2025-07-25T11:00:00",
  "capacity": 20,
  "room": "Studio A"
}

### Update a class
PUT {{baseUrl}}/api/classes/1
Content-Type: application/json

{
  "classTypeId": 1,
  "instructorId": 1,
  "startTime": "2025-07-22T07:30:00",
  "endTime": "2025-07-22T08:30:00",
  "capacity": 25,
  "room": "Studio A"
}

### Cancel a class (cascade cancels all bookings)
PATCH {{baseUrl}}/api/classes/9/cancel
Content-Type: application/json

{
  "cancellationReason": "Room maintenance required"
}

### Get class roster (confirmed members)
GET {{baseUrl}}/api/classes/1/roster

### Get class waitlist
GET {{baseUrl}}/api/classes/3/waitlist

### Try to schedule with instructor conflict (should fail if overlapping)
POST {{baseUrl}}/api/classes
Content-Type: application/json

{
  "classTypeId": 2,
  "instructorId": 1,
  "startTime": "2025-07-22T07:30:00",
  "endTime": "2025-07-22T08:15:00",
  "capacity": 15,
  "room": "Main Floor"
}

### =============================================
### Bookings
### =============================================

### Book a class (member 4 - Noah, Premium plan, for Yoga class)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 1,
  "memberId": 4
}

### Book a premium class as a Basic member (should fail - member 3 is Basic)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 5,
  "memberId": 3
}

### Book a class that is full (should go to waitlist - Spin class 3 is at capacity)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 3,
  "memberId": 5
}

### Get booking details
GET {{baseUrl}}/api/bookings/1

### Cancel a booking (free cancellation - more than 2 hours before)
POST {{baseUrl}}/api/bookings/4/cancel
Content-Type: application/json

{
  "cancellationReason": "Personal emergency"
}

### Cancel a confirmed booking from full class (should promote waitlisted member)
POST {{baseUrl}}/api/bookings/6/cancel
Content-Type: application/json

{
  "cancellationReason": "Cannot make it"
}

### Check in for a class (booking must be within 15 min window of class start)
POST {{baseUrl}}/api/bookings/1/check-in

### Mark booking as no-show (must be 15+ min after class start)
POST {{baseUrl}}/api/bookings/2/no-show

### Try booking with expired membership (member 7 - should fail if no active membership)
POST {{baseUrl}}/api/bookings
Content-Type: application/json

{
  "classScheduleId": 1,
  "memberId": 7
}
