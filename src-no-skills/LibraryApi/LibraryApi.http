@baseUrl = http://localhost:5000

### ==================== AUTHORS ====================

### List all authors
GET {{baseUrl}}/api/authors?page=1&pageSize=10

### Search authors
GET {{baseUrl}}/api/authors?search=Orwell&page=1&pageSize=10

### Get author by ID (George Orwell)
GET {{baseUrl}}/api/authors/1

### Create a new author
POST {{baseUrl}}/api/authors
Content-Type: application/json

{
  "firstName": "Margaret",
  "lastName": "Atwood",
  "biography": "Canadian poet, novelist, and literary critic.",
  "birthDate": "1939-11-18",
  "country": "Canada"
}

### Update an author
PUT {{baseUrl}}/api/authors/1
Content-Type: application/json

{
  "firstName": "George",
  "lastName": "Orwell",
  "biography": "English novelist, essayist, journalist and critic. Born Eric Arthur Blair.",
  "birthDate": "1903-06-25",
  "country": "United Kingdom"
}

### Delete an author (will fail if has books)
DELETE {{baseUrl}}/api/authors/1

### ==================== CATEGORIES ====================

### List all categories
GET {{baseUrl}}/api/categories

### Get category by ID
GET {{baseUrl}}/api/categories/1

### Create a new category
POST {{baseUrl}}/api/categories
Content-Type: application/json

{
  "name": "Philosophy",
  "description": "Philosophical works and thought experiments"
}

### Update a category
PUT {{baseUrl}}/api/categories/1
Content-Type: application/json

{
  "name": "Fiction",
  "description": "Novels, short stories, and other fictional works"
}

### Delete a category (will fail if has books)
DELETE {{baseUrl}}/api/categories/1

### ==================== BOOKS ====================

### List all books
GET {{baseUrl}}/api/books?page=1&pageSize=10

### Search books by title
GET {{baseUrl}}/api/books?search=1984&page=1&pageSize=10

### Filter books by category (Fiction = 1)
GET {{baseUrl}}/api/books?categoryId=1&page=1&pageSize=10

### Filter books by author (Asimov = 3)
GET {{baseUrl}}/api/books?authorId=3&page=1&pageSize=10

### Sort books by year descending
GET {{baseUrl}}/api/books?sortBy=year&sortOrder=desc&page=1&pageSize=10

### Get book by ID (1984)
GET {{baseUrl}}/api/books/1

### Create a new book
POST {{baseUrl}}/api/books
Content-Type: application/json

{
  "title": "The Handmaid's Tale",
  "isbn": "978-0385490818",
  "publisher": "Anchor Books",
  "publicationYear": 1985,
  "description": "A dystopian novel set in a near-future New England.",
  "pageCount": 311,
  "language": "English",
  "totalCopies": 3,
  "authorIds": [],
  "categoryIds": [1, 2]
}

### Update a book
PUT {{baseUrl}}/api/books/1
Content-Type: application/json

{
  "title": "1984",
  "isbn": "978-0451524935",
  "publisher": "Signet Classic",
  "publicationYear": 1949,
  "description": "A dystopian novel set in a totalitarian society ruled by Big Brother.",
  "pageCount": 328,
  "language": "English",
  "totalCopies": 5,
  "authorIds": [1],
  "categoryIds": [1, 6]
}

### Delete a book (will fail if active loans)
DELETE {{baseUrl}}/api/books/7

### Get loan history for a book
GET {{baseUrl}}/api/books/1/loans?page=1&pageSize=10

### Get active reservations for a book
GET {{baseUrl}}/api/books/1/reservations

### ==================== PATRONS ====================

### List all patrons
GET {{baseUrl}}/api/patrons?page=1&pageSize=10

### Search patrons
GET {{baseUrl}}/api/patrons?search=Alice&page=1&pageSize=10

### Filter by membership type
GET {{baseUrl}}/api/patrons?membershipType=Premium&page=1&pageSize=10

### Filter active patrons
GET {{baseUrl}}/api/patrons?isActive=true&page=1&pageSize=10

### Get patron by ID (Alice Johnson - Premium)
GET {{baseUrl}}/api/patrons/1

### Create a new patron
POST {{baseUrl}}/api/patrons
Content-Type: application/json

{
  "firstName": "Grace",
  "lastName": "Hopper",
  "email": "grace.hopper@email.com",
  "phone": "555-0201",
  "address": "100 Computing Way",
  "membershipType": "Premium"
}

### Update a patron
PUT {{baseUrl}}/api/patrons/2
Content-Type: application/json

{
  "firstName": "Bob",
  "lastName": "Smith",
  "email": "bob.smith@email.com",
  "phone": "555-0102",
  "address": "456 Elm St, Apt 2",
  "membershipType": "Premium",
  "isActive": true
}

### Deactivate a patron (fails if active loans)
DELETE {{baseUrl}}/api/patrons/5

### Get patron loans
GET {{baseUrl}}/api/patrons/1/loans?page=1&pageSize=10

### Get patron loans filtered by status
GET {{baseUrl}}/api/patrons/1/loans?status=Active&page=1&pageSize=10

### Get patron reservations
GET {{baseUrl}}/api/patrons/3/reservations

### Get patron fines
GET {{baseUrl}}/api/patrons/4/fines?page=1&pageSize=10

### Get patron unpaid fines
GET {{baseUrl}}/api/patrons/4/fines?status=Unpaid&page=1&pageSize=10

### ==================== LOANS ====================

### List all loans
GET {{baseUrl}}/api/loans?page=1&pageSize=10

### Filter loans by status
GET {{baseUrl}}/api/loans?status=Active&page=1&pageSize=10

### Get overdue loans
GET {{baseUrl}}/api/loans/overdue

### Get loan by ID
GET {{baseUrl}}/api/loans/1

### Checkout a book (new loan) - Alice borrows Pride and Prejudice
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 6,
  "patronId": 1
}

### Return a book
POST {{baseUrl}}/api/loans/1/return

### Renew a loan
POST {{baseUrl}}/api/loans/3/renew

### ---- Business Rule Tests ----

### Checkout: inactive patron (should fail - patron 6 is inactive)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 7,
  "patronId": 6
}

### Checkout: no available copies (book 9 has 1 copy, on loan)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 9,
  "patronId": 1
}

### Renew overdue loan (should fail)
POST {{baseUrl}}/api/loans/7/renew

### ==================== RESERVATIONS ====================

### List all reservations
GET {{baseUrl}}/api/reservations?page=1&pageSize=10

### Filter reservations by status
GET {{baseUrl}}/api/reservations?status=Pending&page=1&pageSize=10

### Get reservation by ID
GET {{baseUrl}}/api/reservations/1

### Create a reservation - Edward reserves 1984
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 1,
  "patronId": 5
}

### Cancel a reservation
POST {{baseUrl}}/api/reservations/1/cancel

### Fulfill a ready reservation
POST {{baseUrl}}/api/reservations/3/fulfill

### ---- Business Rule Tests ----

### Reserve a book already on active loan (should fail - patron 1 has book 1)
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 1,
  "patronId": 1
}

### ==================== FINES ====================

### List all fines
GET {{baseUrl}}/api/fines?page=1&pageSize=10

### Filter unpaid fines
GET {{baseUrl}}/api/fines?status=Unpaid&page=1&pageSize=10

### Get fine by ID
GET {{baseUrl}}/api/fines/2

### Pay a fine
POST {{baseUrl}}/api/fines/2/pay

### Waive a fine
POST {{baseUrl}}/api/fines/3/waive
