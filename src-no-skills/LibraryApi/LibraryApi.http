@baseUrl = http://localhost:5245

###############################################################################
### Authors
###############################################################################

### List all authors
GET {{baseUrl}}/api/authors?page=1&pageSize=10

### Search authors by name
GET {{baseUrl}}/api/authors?search=Orwell&page=1&pageSize=10

### Get author by ID (George Orwell)
GET {{baseUrl}}/api/authors/1

### Create a new author
POST {{baseUrl}}/api/authors
Content-Type: application/json

{
  "firstName": "Haruki",
  "lastName": "Murakami",
  "biography": "Japanese writer known for his surreal and dreamlike novels.",
  "birthDate": "1949-01-12",
  "country": "Japan"
}

### Update an author
PUT {{baseUrl}}/api/authors/1
Content-Type: application/json

{
  "firstName": "George",
  "lastName": "Orwell",
  "biography": "English novelist, essayist, journalist and critic. Best known for '1984' and 'Animal Farm'.",
  "birthDate": "1903-06-25",
  "country": "United Kingdom"
}

### Delete an author (will fail if author has books)
DELETE {{baseUrl}}/api/authors/1

###############################################################################
### Categories
###############################################################################

### List all categories
GET {{baseUrl}}/api/categories?page=1&pageSize=10

### Get category by ID (Fiction)
GET {{baseUrl}}/api/categories/1

### Create a new category
POST {{baseUrl}}/api/categories
Content-Type: application/json

{
  "name": "Philosophy",
  "description": "Books about philosophical ideas and thinkers"
}

### Update a category
PUT {{baseUrl}}/api/categories/1
Content-Type: application/json

{
  "name": "Fiction",
  "description": "Literary works of imaginative narration"
}

### Delete a category (will fail if category has books)
DELETE {{baseUrl}}/api/categories/1

###############################################################################
### Books
###############################################################################

### List all books
GET {{baseUrl}}/api/books?page=1&pageSize=10

### Search books by title
GET {{baseUrl}}/api/books?search=1984&page=1&pageSize=10

### Search books by author name
GET {{baseUrl}}/api/books?search=Asimov&page=1&pageSize=10

### Filter by category
GET {{baseUrl}}/api/books?category=Science Fiction&page=1&pageSize=10

### Filter by availability (available only)
GET {{baseUrl}}/api/books?available=true&page=1&pageSize=10

### Filter by unavailable books
GET {{baseUrl}}/api/books?available=false&page=1&pageSize=10

### Sort by title descending
GET {{baseUrl}}/api/books?sortBy=title&sortOrder=desc&page=1&pageSize=10

### Get book by ID (1984)
GET {{baseUrl}}/api/books/1

### Create a new book
POST {{baseUrl}}/api/books
Content-Type: application/json

{
  "title": "The Caves of Steel",
  "isbn": "978-0553293401",
  "publisher": "Bantam Books",
  "publicationYear": 1954,
  "description": "A science fiction detective novel by Isaac Asimov.",
  "pageCount": 206,
  "language": "English",
  "totalCopies": 2,
  "authorIds": [3],
  "categoryIds": [2]
}

### Update a book
PUT {{baseUrl}}/api/books/1
Content-Type: application/json

{
  "title": "1984",
  "isbn": "978-0451524935",
  "publisher": "Signet Classics",
  "publicationYear": 1949,
  "description": "A dystopian novel set in Airstrip One, a province of the superstate Oceania.",
  "pageCount": 328,
  "language": "English",
  "totalCopies": 4,
  "authorIds": [1],
  "categoryIds": [1, 2, 7]
}

### Delete a book (will fail if book has active loans)
DELETE {{baseUrl}}/api/books/1

### Get loan history for a book
GET {{baseUrl}}/api/books/1/loans?page=1&pageSize=10

### Get active reservations queue for a book
GET {{baseUrl}}/api/books/8/reservations?page=1&pageSize=10

###############################################################################
### Patrons
###############################################################################

### List all patrons
GET {{baseUrl}}/api/patrons?page=1&pageSize=10

### Search patrons by name
GET {{baseUrl}}/api/patrons?search=Alice&page=1&pageSize=10

### Search patrons by email
GET {{baseUrl}}/api/patrons?search=bob.smith@email.com&page=1&pageSize=10

### Filter by membership type
GET {{baseUrl}}/api/patrons?membershipType=Premium&page=1&pageSize=10

### Get patron by ID (Alice Johnson — Premium)
GET {{baseUrl}}/api/patrons/1

### Create a new patron
POST {{baseUrl}}/api/patrons
Content-Type: application/json

{
  "firstName": "Grace",
  "lastName": "Lee",
  "email": "grace.lee@email.com",
  "phone": "555-0107",
  "address": "111 Maple Ave, Springfield",
  "membershipType": "Standard"
}

### Update a patron
PUT {{baseUrl}}/api/patrons/2
Content-Type: application/json

{
  "firstName": "Bob",
  "lastName": "Smith",
  "email": "bob.smith@email.com",
  "phone": "555-0102",
  "address": "456 Oak Ave, Apt 2B, Springfield",
  "membershipType": "Premium"
}

### Deactivate a patron (will fail if patron has active loans)
DELETE {{baseUrl}}/api/patrons/1

### Get patron's loans (all)
GET {{baseUrl}}/api/patrons/1/loans?page=1&pageSize=10

### Get patron's active loans
GET {{baseUrl}}/api/patrons/1/loans?status=Active&page=1&pageSize=10

### Get patron's reservations
GET {{baseUrl}}/api/patrons/1/reservations?page=1&pageSize=10

### Get patron's fines (all)
GET {{baseUrl}}/api/patrons/4/fines?page=1&pageSize=10

### Get patron's unpaid fines
GET {{baseUrl}}/api/patrons/4/fines?status=Unpaid&page=1&pageSize=10

###############################################################################
### Loans
###############################################################################

### List all loans
GET {{baseUrl}}/api/loans?page=1&pageSize=10

### Filter loans by status
GET {{baseUrl}}/api/loans?status=Active&page=1&pageSize=10

### Filter overdue loans
GET {{baseUrl}}/api/loans?overdue=true&page=1&pageSize=10

### Filter loans by date range
GET {{baseUrl}}/api/loans?fromDate=2024-01-01&toDate=2026-12-31&page=1&pageSize=10

### Get loan by ID
GET {{baseUrl}}/api/loans/1

### Check out a book (normal checkout — patron 5, book 7 which is available)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 7,
  "patronId": 5
}

### Return a book (loan 7 which is already returned — should fail; try loan 1 instead)
POST {{baseUrl}}/api/loans/1/return

### Renew a loan
POST {{baseUrl}}/api/loans/2/renew

### Get all overdue loans (also flags overdue loans)
GET {{baseUrl}}/api/loans/overdue?page=1&pageSize=10

###############################################################################
### Business Rule Test Cases
###############################################################################

### FAIL: Check out a book for an inactive patron (patron 6 is inactive)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 2,
  "patronId": 6
}

### FAIL: Check out a book with no available copies (book 8 has 0 available)
POST {{baseUrl}}/api/loans
Content-Type: application/json

{
  "bookId": 8,
  "patronId": 1
}

### FAIL: Attempt to renew an overdue loan (loan 8 is overdue)
POST {{baseUrl}}/api/loans/8/renew

### FAIL: Attempt to renew loan 1 for book 1 — should fail because book 1 has pending reservations
POST {{baseUrl}}/api/loans/1/renew

### FAIL: Reserve a book that patron already has on active loan (patron 1 has book 1 on loan)
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 1,
  "patronId": 1
}

###############################################################################
### Reservations
###############################################################################

### List all reservations
GET {{baseUrl}}/api/reservations?page=1&pageSize=10

### Filter reservations by status
GET {{baseUrl}}/api/reservations?status=Pending&page=1&pageSize=10

### Get reservation by ID
GET {{baseUrl}}/api/reservations/1

### Create a new reservation
POST {{baseUrl}}/api/reservations
Content-Type: application/json

{
  "bookId": 5,
  "patronId": 2
}

### Cancel a reservation
POST {{baseUrl}}/api/reservations/2/cancel

### Fulfill a Ready reservation (reservation 3 is Ready for patron 4, book 1)
POST {{baseUrl}}/api/reservations/3/fulfill

###############################################################################
### Fines
###############################################################################

### List all fines
GET {{baseUrl}}/api/fines?page=1&pageSize=10

### Filter fines by status
GET {{baseUrl}}/api/fines?status=Unpaid&page=1&pageSize=10

### Get fine by ID
GET {{baseUrl}}/api/fines/1

### Pay a fine
POST {{baseUrl}}/api/fines/1/pay

### Waive a fine
POST {{baseUrl}}/api/fines/3/waive
