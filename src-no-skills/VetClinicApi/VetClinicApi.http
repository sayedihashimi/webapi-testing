@baseUrl = http://localhost:5000

### ===========================
### OWNERS
### ===========================

### List all owners
GET {{baseUrl}}/api/owners

### List owners with search and pagination
GET {{baseUrl}}/api/owners?search=johnson&page=1&pageSize=10

### Get owner by ID (with pets)
GET {{baseUrl}}/api/owners/1

### Create a new owner
POST {{baseUrl}}/api/owners
Content-Type: application/json

{
  "firstName": "David",
  "lastName": "Thompson",
  "email": "david.thompson@email.com",
  "phone": "555-0106",
  "address": "100 Birch St",
  "city": "Chicago",
  "state": "IL",
  "zipCode": "60601"
}

### Update owner
PUT {{baseUrl}}/api/owners/1
Content-Type: application/json

{
  "firstName": "Sarah",
  "lastName": "Johnson-Smith",
  "email": "sarah.johnson@email.com",
  "phone": "555-0101",
  "address": "123 Maple St",
  "city": "Springfield",
  "state": "IL",
  "zipCode": "62704"
}

### Delete owner (will fail if has active pets)
DELETE {{baseUrl}}/api/owners/5

### Get owner's pets
GET {{baseUrl}}/api/owners/1/pets

### Get owner's appointments
GET {{baseUrl}}/api/owners/1/appointments?page=1&pageSize=10

### ===========================
### PETS
### ===========================

### List all active pets
GET {{baseUrl}}/api/pets

### List all pets including inactive
GET {{baseUrl}}/api/pets?includeInactive=true

### Search pets
GET {{baseUrl}}/api/pets?search=dog&page=1&pageSize=10

### Get pet by ID (with owner)
GET {{baseUrl}}/api/pets/1

### Create a new pet
POST {{baseUrl}}/api/pets
Content-Type: application/json

{
  "name": "Rocky",
  "species": "Dog",
  "breed": "Bulldog",
  "dateOfBirth": "2023-01-15",
  "weight": 22.5,
  "color": "Brindle",
  "microchipNumber": "MC-009-2023",
  "ownerId": 2
}

### Update pet (transfer ownership)
PUT {{baseUrl}}/api/pets/1
Content-Type: application/json

{
  "name": "Buddy",
  "species": "Dog",
  "breed": "Golden Retriever",
  "dateOfBirth": "2019-03-15",
  "weight": 33.0,
  "color": "Golden",
  "microchipNumber": "MC-001-2019",
  "ownerId": 1
}

### Soft-delete a pet
DELETE {{baseUrl}}/api/pets/1

### Get pet's medical records
GET {{baseUrl}}/api/pets/1/medical-records

### Get pet's vaccinations
GET {{baseUrl}}/api/pets/1/vaccinations

### Get pet's upcoming/overdue vaccinations
GET {{baseUrl}}/api/pets/3/vaccinations/upcoming

### Get pet's active prescriptions
GET {{baseUrl}}/api/pets/5/prescriptions/active

### ===========================
### VETERINARIANS
### ===========================

### List all veterinarians
GET {{baseUrl}}/api/veterinarians

### Filter by specialization
GET {{baseUrl}}/api/veterinarians?specialization=surgery

### Filter by availability
GET {{baseUrl}}/api/veterinarians?isAvailable=true

### Get veterinarian by ID
GET {{baseUrl}}/api/veterinarians/1

### Create a new veterinarian
POST {{baseUrl}}/api/veterinarians
Content-Type: application/json

{
  "firstName": "Dr. Karen",
  "lastName": "Lee",
  "email": "karen.lee@happypaws.com",
  "phone": "555-0204",
  "specialization": "Dermatology",
  "licenseNumber": "VET-2023-004",
  "hireDate": "2023-09-01"
}

### Update veterinarian
PUT {{baseUrl}}/api/veterinarians/1
Content-Type: application/json

{
  "firstName": "Dr. Amanda",
  "lastName": "Foster",
  "email": "amanda.foster@happypaws.com",
  "phone": "555-0201",
  "specialization": "General Practice",
  "licenseNumber": "VET-2015-001",
  "isAvailable": true
}

### Get vet schedule for a date (today)
GET {{baseUrl}}/api/veterinarians/1/schedule?date={{$datetime iso8601 | take 10}}

### Get vet appointments
GET {{baseUrl}}/api/veterinarians/1/appointments?page=1&pageSize=10

### ===========================
### APPOINTMENTS
### ===========================

### List all appointments
GET {{baseUrl}}/api/appointments

### Filter by status
GET {{baseUrl}}/api/appointments?status=Scheduled

### Filter by vet
GET {{baseUrl}}/api/appointments?vetId=1

### Filter by pet
GET {{baseUrl}}/api/appointments?petId=1

### Get appointment by ID (with details)
GET {{baseUrl}}/api/appointments/1

### Get today's appointments
GET {{baseUrl}}/api/appointments/today

### Schedule a new appointment
POST {{baseUrl}}/api/appointments
Content-Type: application/json

{
  "petId": 2,
  "veterinarianId": 1,
  "appointmentDate": "2026-02-15T14:00:00",
  "durationMinutes": 30,
  "reason": "Annual dental check for Whiskers",
  "notes": "Owner reports mild bad breath"
}

### Update appointment
PUT {{baseUrl}}/api/appointments/8
Content-Type: application/json

{
  "petId": 1,
  "veterinarianId": 2,
  "appointmentDate": "2026-02-20T14:00:00",
  "durationMinutes": 45,
  "reason": "Follow-up exam for Buddy — extended",
  "notes": "Need more time for bloodwork"
}

### Update status: Check in
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "newStatus": "CheckedIn"
}

### Update status: Start appointment
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "newStatus": "InProgress"
}

### Update status: Complete
PATCH {{baseUrl}}/api/appointments/6/status
Content-Type: application/json

{
  "newStatus": "Completed"
}

### Update status: Cancel (requires reason)
PATCH {{baseUrl}}/api/appointments/9/status
Content-Type: application/json

{
  "newStatus": "Cancelled",
  "cancellationReason": "Pet is feeling better, no longer needed"
}

### ===========================
### MEDICAL RECORDS
### ===========================

### Get medical record by ID (with prescriptions)
GET {{baseUrl}}/api/medical-records/1

### Create medical record (for completed/in-progress appointment)
POST {{baseUrl}}/api/medical-records
Content-Type: application/json

{
  "appointmentId": 6,
  "diagnosis": "Routine health check — all normal",
  "treatment": "Annual vaccines administered. Flea prevention applied.",
  "notes": "Bella is in excellent health. Weight is stable.",
  "followUpDate": "2026-06-15"
}

### Update medical record
PUT {{baseUrl}}/api/medical-records/1
Content-Type: application/json

{
  "diagnosis": "Healthy — no issues found (updated)",
  "treatment": "Annual vaccines administered (DHPP, Rabies). Heartworm test negative. Added flea prevention.",
  "notes": "Weight stable. Recommend dental cleaning within 3 months.",
  "followUpDate": "2025-09-01"
}

### ===========================
### PRESCRIPTIONS
### ===========================

### Get prescription by ID
GET {{baseUrl}}/api/prescriptions/1

### Create prescription
POST {{baseUrl}}/api/prescriptions
Content-Type: application/json

{
  "medicalRecordId": 1,
  "medicationName": "Apoquel",
  "dosage": "16mg once daily",
  "durationDays": 30,
  "startDate": "2025-03-01",
  "instructions": "Give with or without food. Monitor for GI symptoms."
}

### ===========================
### VACCINATIONS
### ===========================

### Get vaccination by ID
GET {{baseUrl}}/api/vaccinations/1

### Record a new vaccination
POST {{baseUrl}}/api/vaccinations
Content-Type: application/json

{
  "petId": 7,
  "vaccineName": "Rabies",
  "dateAdministered": "2025-03-15",
  "expirationDate": "2028-03-15",
  "batchNumber": "RAB-2025-G7",
  "administeredByVetId": 1,
  "notes": "3-year rabies vaccine renewal"
}
