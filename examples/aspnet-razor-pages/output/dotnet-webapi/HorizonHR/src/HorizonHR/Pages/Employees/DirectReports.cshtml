@page "{id:int}"
@model HorizonHR.Pages.Employees.DirectReportsModel
@{
    ViewData["Title"] = $"Direct Reports - {Model.EmployeeName}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="Index">Employees</a></li>
        <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@Model.EmployeeId">@Model.EmployeeName</a></li>
        <li class="breadcrumb-item active">Direct Reports</li>
    </ol>
</nav>

<h1>Direct Reports — @Model.EmployeeName</h1>

@if (Model.DirectReports.Count == 0)
{
    <p>No direct reports found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Employee #</th>
                <th>Name</th>
                <th>Department</th>
                <th>Job Title</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model.DirectReports)
            {
                <tr>
                    <td>@emp.EmployeeNumber</td>
                    <td><a asp-page="Details" asp-route-id="@emp.Id">@emp.FirstName @emp.LastName</a></td>
                    <td>@emp.Department.Name</td>
                    <td>@emp.JobTitle</td>
                    <td><partial name="_StatusBadge" view-data='@(new ViewDataDictionary(ViewData) { { "Status", emp.Status.ToString() } })' /></td>
                </tr>
            }
        </tbody>
    </table>
}
