@page
@model HorizonHR.Pages.Leave.IndexModel
@{
    ViewData["Title"] = "Leave Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Leave Requests</h1>
    <div>
        <a asp-page="Balances" class="btn btn-outline-info">View Balances</a>
        <a asp-page="Create" class="btn btn-primary">Submit Request</a>
    </div>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <select name="status" class="form-select">
            <option value="">All Statuses</option>
            @foreach (var s in Enum.GetValues<LeaveRequestStatus>())
            {
                <option value="@s" selected="@(Model.Status == s)">@s</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary">Filter</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (Model.Requests.Items.Count == 0)
{
    <p>No leave requests found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Employee</th>
                <th>Leave Type</th>
                <th>Start</th>
                <th>End</th>
                <th>Days</th>
                <th>Status</th>
                <th>Submitted</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var lr in Model.Requests.Items)
            {
                <tr>
                    <td><a asp-page="/Employees/Details" asp-route-id="@lr.EmployeeId">@lr.Employee.FirstName @lr.Employee.LastName</a></td>
                    <td>@lr.LeaveType.Name</td>
                    <td>@lr.StartDate.ToString("MMM dd, yyyy")</td>
                    <td>@lr.EndDate.ToString("MMM dd, yyyy")</td>
                    <td>@lr.TotalDays</td>
                    <td><partial name="_StatusBadge" view-data='@(new ViewDataDictionary(ViewData) { { "Status", lr.Status.ToString() } })' /></td>
                    <td>@lr.SubmittedDate.ToString("MMM dd, yyyy")</td>
                    <td><a asp-page="Details" asp-route-id="@lr.Id" class="btn btn-sm btn-outline-info">View</a></td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.Requests.TotalPages > 1)
    {
        <nav aria-label="Leave requests pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Requests.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-page="Index" asp-route-pageNumber="@(Model.Requests.PageNumber - 1)" asp-route-status="@Model.Status">Previous</a>
                </li>
                @for (var i = 1; i <= Model.Requests.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Requests.PageNumber ? "active" : "")">
                        <a class="page-link" asp-page="Index" asp-route-pageNumber="@i" asp-route-status="@Model.Status">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Requests.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-page="Index" asp-route-pageNumber="@(Model.Requests.PageNumber + 1)" asp-route-status="@Model.Status">Next</a>
                </li>
            </ul>
        </nav>
    }
}
