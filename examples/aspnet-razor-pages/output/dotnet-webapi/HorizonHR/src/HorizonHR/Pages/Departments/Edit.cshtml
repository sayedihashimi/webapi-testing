@page "{id:int}"
@model HorizonHR.Pages.Departments.EditModel
@{
    ViewData["Title"] = "Edit Department";
}

<h1>Edit Department</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Input.Name" class="form-label"></label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Code" class="form-label"></label>
                <input asp-for="Input.Code" class="form-control" />
                <span asp-validation-for="Input.Code" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.ParentDepartmentId" class="form-label">Parent Department</label>
                <select asp-for="Input.ParentDepartmentId" asp-items="Model.DepartmentList" class="form-select">
                    <option value="">-- None --</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Input.ManagerId" class="form-label">Manager</label>
                <select asp-for="Input.ManagerId" asp-items="Model.EmployeeList" class="form-select">
                    <option value="">-- Unassigned --</option>
                </select>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="Input.IsActive" class="form-check-input" />
                <label asp-for="Input.IsActive" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-page="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
