@page "{id:int}"
@model HorizonHR.Pages.Leave.ReviewModel
@{
    ViewData["Title"] = "Review Leave Request";
}

<h1>Review Leave Request #@Model.Request.Id</h1>

<div class="card mb-4">
    <div class="card-body">
        <p><strong>Employee:</strong> @Model.Request.Employee.FirstName @Model.Request.Employee.LastName</p>
        <p><strong>Leave Type:</strong> @Model.Request.LeaveType.Name</p>
        <p><strong>Dates:</strong> @Model.Request.StartDate.ToString("MMM dd, yyyy") — @Model.Request.EndDate.ToString("MMM dd, yyyy")</p>
        <p><strong>Total Days:</strong> @Model.Request.TotalDays</p>
        <p><strong>Reason:</strong> @Model.Request.Reason</p>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="mb-3">
            <label asp-for="ReviewerId" class="form-label">Reviewer</label>
            <select asp-for="ReviewerId" asp-items="Model.ReviewerList" class="form-select">
                <option value="">-- Select Reviewer --</option>
            </select>
        </div>
        <div class="mb-3">
            <label asp-for="ReviewNotes" class="form-label">Notes</label>
            <textarea asp-for="ReviewNotes" class="form-control" rows="3"></textarea>
        </div>

        <div class="d-flex gap-2">
            <form method="post" asp-page-handler="Approve">
                <input type="hidden" name="ReviewerId" value="@Model.ReviewerId" />
                <input type="hidden" name="ReviewNotes" value="@Model.ReviewNotes" />
                <button type="submit" class="btn btn-success">Approve</button>
            </form>
            <form method="post" asp-page-handler="Reject">
                <input type="hidden" name="ReviewerId" value="@Model.ReviewerId" />
                <input type="hidden" name="ReviewNotes" value="@Model.ReviewNotes" />
                <button type="submit" class="btn btn-danger">Reject</button>
            </form>
            <a asp-page="Details" asp-route-id="@Model.Request.Id" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</div>
