@page
@model HorizonHR.Pages.Departments.IndexModel
@{
    ViewData["Title"] = "Departments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Departments</h1>
    <a asp-page="Create" class="btn btn-primary">Create Department</a>
</div>

@if (Model.Departments.Count == 0)
{
    <p>No departments found.</p>
}
else
{
    @foreach (var dept in Model.Departments)
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h5 class="card-title">
                            <a asp-page="Details" asp-route-id="@dept.Id">@dept.Name</a>
                            <span class="badge bg-secondary">@dept.Code</span>
                            @if (!dept.IsActive)
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </h5>
                        <p class="card-text text-muted">@dept.Description</p>
                        <p class="mb-1"><strong>Manager:</strong> @(dept.Manager != null ? $"{dept.Manager.FirstName} {dept.Manager.LastName}" : "Unassigned")</p>
                        <p class="mb-0"><strong>Employees:</strong> @dept.Employees.Count</p>
                    </div>
                    <div>
                        <a asp-page="Edit" asp-route-id="@dept.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    </div>
                </div>
                @if (dept.ChildDepartments.Any())
                {
                    <div class="mt-2 ms-4">
                        <small class="text-muted">Sub-departments:</small>
                        @foreach (var child in dept.ChildDepartments)
                        {
                            <span class="badge bg-light text-dark me-1">
                                <a asp-page="Details" asp-route-id="@child.Id">@child.Name</a>
                            </span>
                        }
                    </div>
                }
            </div>
        </div>
    }
}
