@page
@model HorizonHR.Pages.Reviews.IndexModel
@{
    ViewData["Title"] = "Performance Reviews";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Performance Reviews</h1>
    <a asp-page="Create" class="btn btn-primary">Create Review</a>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <select name="status" class="form-select">
            <option value="">All Statuses</option>
            @foreach (var s in Enum.GetValues<ReviewStatus>())
            {
                <option value="@s" selected="@(Model.Status == s)">@s</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary">Filter</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (Model.Reviews.Items.Count == 0)
{
    <p>No performance reviews found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Employee</th>
                <th>Department</th>
                <th>Reviewer</th>
                <th>Period</th>
                <th>Status</th>
                <th>Rating</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Reviews.Items)
            {
                <tr>
                    <td><a asp-page="/Employees/Details" asp-route-id="@r.EmployeeId">@r.Employee.FirstName @r.Employee.LastName</a></td>
                    <td>@r.Employee.Department.Name</td>
                    <td>@r.Reviewer.FirstName @r.Reviewer.LastName</td>
                    <td>@r.ReviewPeriodStart.ToString("MMM yyyy") — @r.ReviewPeriodEnd.ToString("MMM yyyy")</td>
                    <td><partial name="_StatusBadge" view-data='@(new ViewDataDictionary(ViewData) { { "Status", r.Status.ToString() } })' /></td>
                    <td>
                        @if (r.OverallRating.HasValue)
                        {
                            <partial name="_StatusBadge" view-data='@(new ViewDataDictionary(ViewData) { { "Status", r.OverallRating.Value.ToString() } })' />
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </td>
                    <td><a asp-page="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-info">View</a></td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.Reviews.TotalPages > 1)
    {
        <nav aria-label="Reviews pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Reviews.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-page="Index" asp-route-pageNumber="@(Model.Reviews.PageNumber - 1)" asp-route-status="@Model.Status">Previous</a>
                </li>
                @for (var i = 1; i <= Model.Reviews.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Reviews.PageNumber ? "active" : "")">
                        <a class="page-link" asp-page="Index" asp-route-pageNumber="@i" asp-route-status="@Model.Status">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Reviews.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-page="Index" asp-route-pageNumber="@(Model.Reviews.PageNumber + 1)" asp-route-status="@Model.Status">Next</a>
                </li>
            </ul>
        </nav>
    }
}
