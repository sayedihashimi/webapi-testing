@page "{id:int}"
@model SparkEvents.Pages.Events.CancelModel
@{
    ViewData["Title"] = "Cancel Event";
    var evt = Model.Event;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="Index">Events</a></li>
        <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@evt.Id">@evt.Title</a></li>
        <li class="breadcrumb-item active" aria-current="page">Cancel</li>
    </ol>
</nav>

<h1 class="mb-4 text-danger">Cancel Event</h1>

<div class="card mb-4">
    <div class="card-header bg-danger text-white">
        <h5 class="mb-0">Are you sure you want to cancel this event?</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@evt.Title</dd>

            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@evt.StartDate.ToString("MMMM dd, yyyy h:mm tt") — @evt.EndDate.ToString("MMMM dd, yyyy h:mm tt")</dd>

            <dt class="col-sm-3">Venue</dt>
            <dd class="col-sm-9">@evt.Venue.Name</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <partial name="_StatusBadge" view-data='@(new ViewDataDictionary(ViewData) { { "Status", evt.Status.ToString() } })' />
            </dd>

            <dt class="col-sm-3">Registrations</dt>
            <dd class="col-sm-9">@evt.CurrentRegistrations / @evt.TotalCapacity</dd>
        </dl>
    </div>
</div>

@if (Model.ActiveRegistrationCount > 0)
{
    <div class="alert alert-warning">
        <strong>Warning:</strong> There are <strong>@Model.ActiveRegistrationCount</strong> active registration(s) that will be cancelled.
    </div>
}

<form method="post" asp-route-id="@evt.Id">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Input.CancellationReason" class="form-label"></label>
        <textarea asp-for="Input.CancellationReason" class="form-control" rows="4" placeholder="Explain why this event is being cancelled..."></textarea>
        <span asp-validation-for="Input.CancellationReason" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Confirm Cancellation</button>
        <a asp-page="Details" asp-route-id="@evt.Id" class="btn btn-outline-secondary">Go Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
