@page
@model SparkEvents.Pages.Attendees.IndexModel
@{
    ViewData["Title"] = "Attendees";
}

<h1>Attendees</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" class="d-flex">
            <input type="text" name="search" value="@Model.Search" class="form-control me-2" placeholder="Search by name or email..." />
            <button type="submit" class="btn btn-primary me-2">Search</button>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
            }
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-page="Create" class="btn btn-success">+ New Attendee</a>
    </div>
</div>

@if (Model.Attendees.Items.Count == 0)
{
    <div class="alert alert-info">No attendees found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Organization</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var attendee in Model.Attendees.Items)
            {
                <tr>
                    <td>@attendee.FullName</td>
                    <td>@attendee.Email</td>
                    <td>@(attendee.Organization ?? "—")</td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@attendee.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-page="Details" asp-route-id="@attendee.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <partial name="_Pagination" view-data='@(new ViewDataDictionary(ViewData) {
        { "PageNumber", Model.Attendees.PageNumber },
        { "TotalPages", Model.Attendees.TotalPages },
        { "HasPreviousPage", Model.Attendees.HasPreviousPage },
        { "HasNextPage", Model.Attendees.HasNextPage },
        { "PageUrl", $"?search={Model.Search}&pageSize={Model.PageSize}" }
    })' />
}
