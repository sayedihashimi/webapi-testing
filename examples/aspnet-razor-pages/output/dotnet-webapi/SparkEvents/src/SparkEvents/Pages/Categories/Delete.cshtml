@page "{id:int}"
@model SparkEvents.Pages.Categories.DeleteModel
@{
    ViewData["Title"] = "Delete Category";
}

<h1>Delete Category</h1>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Model.Category.Name</h5>

        @if (!string.IsNullOrEmpty(Model.Category.Description))
        {
            <p class="card-text">@Model.Category.Description</p>
        }

        @if (!string.IsNullOrEmpty(Model.Category.ColorHex))
        {
            <p>
                <strong>Color:</strong>
                <span class="badge" style="background-color: @Model.Category.ColorHex;">@Model.Category.ColorHex</span>
            </p>
        }

        @if (Model.HasEvents)
        {
            <div class="alert alert-danger">
                This category cannot be deleted because it has associated events. Remove or reassign the events first.
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                Are you sure you want to delete this category? This action cannot be undone.
            </div>

            <form method="post" asp-route-id="@Model.Category.Id">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-page="Index" class="btn btn-secondary">Back to list</a>
            </form>
        }

        @if (Model.HasEvents)
        {
            <a asp-page="Index" class="btn btn-secondary mt-2">Back to list</a>
        }
    </div>
</div>
