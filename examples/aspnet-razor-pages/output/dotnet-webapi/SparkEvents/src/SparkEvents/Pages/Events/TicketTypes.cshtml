@page "{eventId:int}/TicketTypes"
@model SparkEvents.Pages.Events.TicketTypesModel
@{
    ViewData["Title"] = $"Ticket Types — {Model.Event.Title}";
    var evt = Model.Event;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="Index">Events</a></li>
        <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@evt.Id">@evt.Title</a></li>
        <li class="breadcrumb-item active" aria-current="page">Ticket Types</li>
    </ol>
</nav>

<h1 class="mb-4">Ticket Types — @evt.Title</h1>

@if (Model.TicketTypesList.Any())
{
    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Existing Ticket Types</h5></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Price</th>
                            <th>Early Bird</th>
                            <th>Quantity</th>
                            <th>Sold</th>
                            <th>Order</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tt in Model.TicketTypesList.OrderBy(t => t.SortOrder))
                        {
                            <tr>
                                <td>@tt.Name</td>
                                <td>@(tt.Description ?? "—")</td>
                                <td>@tt.Price.ToString("C")</td>
                                <td>@(tt.EarlyBirdPrice?.ToString("C") ?? "—")</td>
                                <td>@tt.Quantity</td>
                                <td>@tt.QuantitySold</td>
                                <td>@tt.SortOrder</td>
                                <td>
                                    @if (tt.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <form method="post" asp-page-handler="ToggleActive" asp-route-eventId="@evt.Id" asp-route-ticketTypeId="@tt.Id" class="d-inline">
                                        <button type="submit" class="btn btn-sm @(tt.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                            @(tt.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info mb-4">No ticket types have been created for this event yet.</div>
}

<div class="card mb-4">
    <div class="card-header"><h5 class="mb-0">Add New Ticket Type</h5></div>
    <div class="card-body">
        <form method="post" asp-page-handler="Create" asp-route-eventId="@evt.Id">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Input.Name" class="form-label"></label>
                    <input asp-for="Input.Name" class="form-control" />
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Input.Description" class="form-label"></label>
                    <input asp-for="Input.Description" class="form-control" />
                    <span asp-validation-for="Input.Description" class="text-danger"></span>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-3">
                    <label asp-for="Input.Price" class="form-label"></label>
                    <input asp-for="Input.Price" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Input.Price" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Input.EarlyBirdPrice" class="form-label"></label>
                    <input asp-for="Input.EarlyBirdPrice" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Input.EarlyBirdPrice" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Input.Quantity" class="form-label"></label>
                    <input asp-for="Input.Quantity" class="form-control" type="number" min="1" />
                    <span asp-validation-for="Input.Quantity" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Input.SortOrder" class="form-label"></label>
                    <input asp-for="Input.SortOrder" class="form-control" type="number" min="0" />
                    <span asp-validation-for="Input.SortOrder" class="text-danger"></span>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Add Ticket Type</button>
            </div>
        </form>
    </div>
</div>

<a asp-page="Details" asp-route-id="@evt.Id" class="btn btn-outline-secondary">Back to Event</a>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
