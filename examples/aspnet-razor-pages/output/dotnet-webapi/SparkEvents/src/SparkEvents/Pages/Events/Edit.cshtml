@page "{id:int}"
@model SparkEvents.Pages.Events.EditModel
@{
    ViewData["Title"] = "Edit Event";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="Index">Events</a></li>
        <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@Model.Input.Id">@Model.Input.Title</a></li>
        <li class="breadcrumb-item active" aria-current="page">Edit</li>
    </ol>
</nav>

<h1 class="mb-4">Edit Event</h1>

@if (Model.CurrentRegistrations > 0)
{
    <div class="alert alert-warning">
        <strong>Note:</strong> This event has @Model.CurrentRegistrations current registration(s). Reducing capacity below this number is not allowed.
    </div>
}

<form method="post" asp-route-id="@Model.Input.Id">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Input.Id" />

    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Basic Information</h5></div>
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="Input.Title" class="form-label"></label>
                <input asp-for="Input.Title" class="form-control" />
                <span asp-validation-for="Input.Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Category &amp; Venue</h5></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.EventCategoryId" class="form-label"></label>
                    <select asp-for="Input.EventCategoryId" asp-items="Model.Categories" class="form-select">
                        <option value="">— Select Category —</option>
                    </select>
                    <span asp-validation-for="Input.EventCategoryId" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.VenueId" class="form-label"></label>
                    <select asp-for="Input.VenueId" asp-items="Model.Venues" class="form-select">
                        <option value="">— Select Venue —</option>
                    </select>
                    <span asp-validation-for="Input.VenueId" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Dates</h5></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.StartDate" class="form-label"></label>
                    <input asp-for="Input.StartDate" type="datetime-local" class="form-control" />
                    <span asp-validation-for="Input.StartDate" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.EndDate" class="form-label"></label>
                    <input asp-for="Input.EndDate" type="datetime-local" class="form-control" />
                    <span asp-validation-for="Input.EndDate" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.RegistrationOpenDate" class="form-label"></label>
                    <input asp-for="Input.RegistrationOpenDate" type="datetime-local" class="form-control" />
                    <span asp-validation-for="Input.RegistrationOpenDate" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.RegistrationCloseDate" class="form-label"></label>
                    <input asp-for="Input.RegistrationCloseDate" type="datetime-local" class="form-control" />
                    <span asp-validation-for="Input.RegistrationCloseDate" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.EarlyBirdDeadline" class="form-label"></label>
                    <input asp-for="Input.EarlyBirdDeadline" type="datetime-local" class="form-control" />
                    <span asp-validation-for="Input.EarlyBirdDeadline" class="text-danger"></span>
                    <div class="form-text">Optional. Leave blank if no early bird pricing.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Capacity</h5></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.TotalCapacity" class="form-label"></label>
                    <input asp-for="Input.TotalCapacity" class="form-control" type="number" min="1" />
                    <span asp-validation-for="Input.TotalCapacity" class="text-danger"></span>
                    <div class="form-text">Cannot exceed the selected venue's maximum capacity.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-page="Details" asp-route-id="@Model.Input.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
