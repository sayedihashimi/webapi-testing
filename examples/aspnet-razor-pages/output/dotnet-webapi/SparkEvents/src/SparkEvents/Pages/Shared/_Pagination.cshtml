@using SparkEvents.Services
@model dynamic
@{
    int pageNumber = (int)ViewData["PageNumber"]!;
    int totalPages = (int)ViewData["TotalPages"]!;
    string pageUrl = (string)ViewData["PageUrl"]!;
    bool hasPreviousPage = (bool)ViewData["HasPreviousPage"]!;
    bool hasNextPage = (bool)ViewData["HasNextPage"]!;
}

@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(hasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="@pageUrl&pageNumber=@(pageNumber - 1)">Previous</a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == pageNumber ? "active" : "")">
                    <a class="page-link" href="@pageUrl&pageNumber=@i">@i</a>
                </li>
            }
            <li class="page-item @(hasNextPage ? "" : "disabled")">
                <a class="page-link" href="@pageUrl&pageNumber=@(pageNumber + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
