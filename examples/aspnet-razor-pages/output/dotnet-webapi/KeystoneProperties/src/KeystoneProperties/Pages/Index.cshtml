@page
@model KeystoneProperties.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

<section class="row mb-4">
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Properties</h5>
                <p class="display-6">@Model.Dashboard.TotalProperties</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Units</h5>
                <p class="display-6">@Model.Dashboard.TotalUnits</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Occupancy</h5>
                <p class="display-6">@Model.Dashboard.OccupancyRate%</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Rent (Month)</h5>
                <p class="display-6">@Model.Dashboard.RentCollectedThisMonth.ToString("C0")</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="card text-center border-danger">
            <div class="card-body">
                <h5 class="card-title">Overdue</h5>
                <p class="display-6 text-danger">@Model.Dashboard.OverduePaymentsCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="card text-center border-warning">
            <div class="card-body">
                <h5 class="card-title">Open Maint.</h5>
                <p class="display-6 text-warning">@Model.Dashboard.OpenMaintenanceRequests</p>
            </div>
        </div>
    </div>
</section>

<section>
    <h3>Upcoming Lease Expirations (Next 30 Days)</h3>
    @if (Model.Dashboard.UpcomingLeaseExpirations.Count == 0)
    {
        <p class="text-muted">No leases expiring in the next 30 days.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Tenant</th>
                    <th>Unit</th>
                    <th>End Date</th>
                    <th>Days Left</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Dashboard.UpcomingLeaseExpirations)
                {
                    <tr>
                        <td>@item.TenantName</td>
                        <td>@item.UnitInfo</td>
                        <td>@item.EndDate.ToString("MMM d, yyyy")</td>
                        <td>
                            @if (item.DaysUntilExpiration <= 7)
                            {
                                <span class="badge bg-danger">@item.DaysUntilExpiration days</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@item.DaysUntilExpiration days</span>
                            }
                        </td>
                        <td>
                            <a asp-page="/Leases/Details" asp-route-id="@item.LeaseId" class="btn btn-sm btn-outline-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>
