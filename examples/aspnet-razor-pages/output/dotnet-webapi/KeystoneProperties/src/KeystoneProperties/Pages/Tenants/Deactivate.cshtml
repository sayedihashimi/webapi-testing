@page "{id:int}"
@model KeystoneProperties.Pages.Tenants.DeactivateModel
@{
    ViewData["Title"] = "Deactivate Tenant";
}

<h1>Deactivate Tenant</h1>

<div class="alert alert-warning">
    Are you sure you want to deactivate <strong>@Model.Tenant.FullName</strong>? This tenant will no longer appear as active.
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Tenant Information</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Tenant.FullName</dd>
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Tenant.Email</dd>
            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.Tenant.Phone</dd>
            <dt class="col-sm-3">Date of Birth</dt>
            <dd class="col-sm-9">@Model.Tenant.DateOfBirth.ToString("MMM d, yyyy")</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @await Html.PartialAsync("_StatusBadge", new ViewDataDictionary(ViewData) { { "Status", Model.Tenant.IsActive ? "Active" : "Inactive" } })
            </dd>
        </dl>
    </div>
</div>

<form method="post">
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Confirm Deactivation</button>
        <a asp-page="Details" asp-route-id="@Model.Tenant.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
