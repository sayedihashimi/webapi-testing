@page
@model KeystoneProperties.Pages.Units.IndexModel
@{
    ViewData["Title"] = "Units";

    var queryParams = new Dictionary<string, string?>();
    if (Model.PropertyId.HasValue) queryParams["propertyId"] = Model.PropertyId.Value.ToString();
    if (Model.Status.HasValue) queryParams["status"] = Model.Status.Value.ToString();
    if (Model.Bedrooms.HasValue) queryParams["bedrooms"] = Model.Bedrooms.Value.ToString();
    if (Model.MinRent.HasValue) queryParams["minRent"] = Model.MinRent.Value.ToString();
    if (Model.MaxRent.HasValue) queryParams["maxRent"] = Model.MaxRent.Value.ToString();
    if (!string.IsNullOrEmpty(Model.Search)) queryParams["search"] = Model.Search;
    var queryString = string.Join("&", queryParams.Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value ?? "")}"));
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Units</h1>
    <a asp-page="Create" class="btn btn-primary">Add Unit</a>
</div>

<form method="get" class="card card-body mb-4">
    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="PropertyId" class="form-label">Property</label>
            <select asp-for="PropertyId" asp-items="Model.PropertyList" class="form-select">
                <option value="">All Properties</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="Status" class="form-label">Status</label>
            <select asp-for="Status" asp-items="Model.StatusList" class="form-select">
                <option value="">All Statuses</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="Bedrooms" class="form-label">Bedrooms</label>
            <select asp-for="Bedrooms" asp-items="Model.BedroomList" class="form-select">
                <option value="">Any</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="MinRent" class="form-label">Min Rent</label>
            <input asp-for="MinRent" class="form-control" placeholder="Min" />
        </div>
        <div class="col-md-2">
            <label asp-for="MaxRent" class="form-label">Max Rent</label>
            <input asp-for="MaxRent" class="form-control" placeholder="Max" />
        </div>
        <div class="col-md-3">
            <label asp-for="Search" class="form-label">Search Unit #</label>
            <input asp-for="Search" class="form-control" placeholder="Unit number..." />
        </div>
        <div class="col-md-3 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-outline-primary">Filter</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </div>
</form>

@if (Model.Units.Items.Count == 0)
{
    <div class="alert alert-info">No units found matching the selected filters.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Property</th>
                <th>Unit #</th>
                <th>Bed / Bath</th>
                <th>Sq Ft</th>
                <th>Rent</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var unit in Model.Units.Items)
            {
                <tr>
                    <td>@unit.Property.Name</td>
                    <td>@unit.UnitNumber</td>
                    <td>@unit.Bedrooms bd / @unit.Bathrooms ba</td>
                    <td>@unit.SquareFeet.ToString("N0")</td>
                    <td>@unit.MonthlyRent.ToString("C")</td>
                    <td>
                        @await Html.PartialAsync("_StatusBadge", null, new ViewDataDictionary(ViewData) { { "Status", unit.Status.ToString() } })
                    </td>
                    <td>
                        <a asp-page="Details" asp-route-id="@unit.Id" class="btn btn-sm btn-outline-primary">View</a>
                        <a asp-page="Edit" asp-route-id="@unit.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @await Html.PartialAsync("_Pagination", (object)Model.Units, new ViewDataDictionary(ViewData) { { "QueryString", queryString } })
}
