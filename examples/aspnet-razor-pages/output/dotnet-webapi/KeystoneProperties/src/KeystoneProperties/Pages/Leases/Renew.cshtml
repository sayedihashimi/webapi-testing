@page "{id:int}"
@model KeystoneProperties.Pages.Leases.RenewModel
@{
    ViewData["Title"] = "Renew Lease";
}

<h1>Renew Lease</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header"><h5 class="mb-0">Original Lease</h5></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Tenant</dt>
                    <dd class="col-sm-8">@Model.Lease.Tenant.FullName</dd>

                    <dt class="col-sm-4">Unit</dt>
                    <dd class="col-sm-8">@Model.Lease.Unit.Property.Name - @Model.Lease.Unit.UnitNumber</dd>

                    <dt class="col-sm-4">Current Period</dt>
                    <dd class="col-sm-8">@Model.Lease.StartDate.ToString("MMM d, yyyy") – @Model.Lease.EndDate.ToString("MMM d, yyyy")</dd>

                    <dt class="col-sm-4">Current Monthly Rent</dt>
                    <dd class="col-sm-8">@Model.Lease.MonthlyRentAmount.ToString("C")</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        @await Html.PartialAsync("_StatusBadge", new ViewDataDictionary(ViewData) { { "Status", Model.Lease.Status.ToString() } })
                    </dd>
                </dl>
            </div>
        </div>

        <div class="card border-success">
            <div class="card-header bg-success text-white"><h5 class="mb-0">Renewal Details</h5></div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Input.Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">New Start Date</label>
                        <input type="date" class="form-control" value="@Model.NewStartDate.ToString("yyyy-MM-dd")" disabled />
                        <div class="form-text">Automatically set to the day after the current lease ends.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.NewEndDate" class="form-label"></label>
                        <input asp-for="Input.NewEndDate" class="form-control" type="date" />
                        <span asp-validation-for="Input.NewEndDate" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.NewMonthlyRent" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Input.NewMonthlyRent" class="form-control" />
                        </div>
                        <span asp-validation-for="Input.NewMonthlyRent" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Confirm Renewal</button>
                        <a asp-page="Details" asp-route-id="@Model.Lease.Id" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
