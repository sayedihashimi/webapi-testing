@page
@model KeystoneProperties.Pages.Maintenance.CreateModel
@{
    ViewData["Title"] = "New Maintenance Request";
}

<h1>New Maintenance Request</h1>

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.UnitId" class="form-label"></label>
                <select asp-for="Input.UnitId" class="form-select">
                    <option value="">— Select Unit —</option>
                    @foreach (var unit in Model.Units)
                    {
                        <option value="@unit.Id">@unit.Property?.Name — @unit.UnitNumber</option>
                    }
                </select>
                <span asp-validation-for="Input.UnitId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.TenantId" class="form-label"></label>
                <select asp-for="Input.TenantId" class="form-select">
                    <option value="">— Select Tenant —</option>
                    @foreach (var tenant in Model.Tenants)
                    {
                        <option value="@tenant.Id">@tenant.FullName</option>
                    }
                </select>
                <span asp-validation-for="Input.TenantId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Title" class="form-label"></label>
                <input asp-for="Input.Title" class="form-control" />
                <span asp-validation-for="Input.Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.Priority" class="form-label"></label>
                    <select asp-for="Input.Priority" id="prioritySelect" class="form-select"
                            asp-items="@(new SelectList(Enum.GetValues<KeystoneProperties.Models.MaintenancePriority>()))">
                    </select>
                    <span asp-validation-for="Input.Priority" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.Category" class="form-label"></label>
                    <select asp-for="Input.Category" class="form-select"
                            asp-items="@(new SelectList(Enum.GetValues<KeystoneProperties.Models.MaintenanceCategory>()))">
                    </select>
                    <span asp-validation-for="Input.Category" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3" id="assignedToGroup"
                 style="@(Model.Input.Priority == KeystoneProperties.Models.MaintenancePriority.Emergency ? "" : "display:none;")">
                <label asp-for="Input.AssignedTo" class="form-label"></label>
                <input asp-for="Input.AssignedTo" class="form-control" />
                <span asp-validation-for="Input.AssignedTo" class="text-danger"></span>
                <div class="form-text">Required for Emergency priority requests.</div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Create Request</button>
                <a asp-page="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('prioritySelect').addEventListener('change', function () {
            var group = document.getElementById('assignedToGroup');
            if (this.value === '@nameof(KeystoneProperties.Models.MaintenancePriority.Emergency)') {
                group.style.display = '';
            } else {
                group.style.display = 'none';
            }
        });
    </script>
}
