@model KeystoneProperties.Services.PaginatedList<object>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.PageNumber - 1)&@ViewData["QueryString"]">Previous</a>
            </li>
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" href="?pageNumber=@i&@ViewData["QueryString"]">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="?pageNumber=@(Model.PageNumber + 1)&@ViewData["QueryString"]">Next</a>
            </li>
        </ul>
    </nav>
    <p class="text-muted text-center">Showing page @Model.PageNumber of @Model.TotalPages (@Model.TotalCount total items)</p>
}
