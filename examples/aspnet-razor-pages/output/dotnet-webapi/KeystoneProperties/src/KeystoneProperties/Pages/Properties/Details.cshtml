@page "{id:int}"
@model KeystoneProperties.Pages.Properties.DetailsModel
@using KeystoneProperties.Models
@{
    ViewData["Title"] = Model.Property.Name;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@Model.Property.Name</h1>
    <div class="btn-group">
        <a asp-page="Edit" asp-route-id="@Model.Property.Id" class="btn btn-outline-secondary">Edit</a>
        @if (Model.Property.IsActive)
        {
            <a asp-page="Deactivate" asp-route-id="@Model.Property.Id" class="btn btn-outline-danger">Deactivate</a>
        }
        <a asp-page="Index" class="btn btn-outline-primary">Back to List</a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Property Information</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Address</dt>
                    <dd class="col-sm-8">@Model.Property.Address, @Model.Property.City, @Model.Property.State @Model.Property.ZipCode</dd>

                    <dt class="col-sm-4">Type</dt>
                    <dd class="col-sm-8">@Model.Property.PropertyType</dd>

                    <dt class="col-sm-4">Year Built</dt>
                    <dd class="col-sm-8">@(Model.Property.YearBuilt?.ToString() ?? "N/A")</dd>

                    <dt class="col-sm-4">Total Units</dt>
                    <dd class="col-sm-8">@Model.Property.TotalUnits</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.Property.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@(Model.Property.Description ?? "—")</dd>

                    <dt class="col-sm-4">Created</dt>
                    <dd class="col-sm-8">@Model.Property.CreatedAt.ToString("MMM d, yyyy")</dd>

                    <dt class="col-sm-4">Last Updated</dt>
                    <dd class="col-sm-8">@Model.Property.UpdatedAt.ToString("MMM d, yyyy")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Occupancy Summary</h5>
            </div>
            <div class="card-body text-center">
                @{
                    var totalUnits = Model.Property.TotalUnits;
                    var occupiedCount = Model.OccupiedUnitCount;
                    var occupancyRate = totalUnits > 0 ? (double)occupiedCount / totalUnits * 100 : 0;
                }
                <p class="display-4 mb-1">@occupancyRate.ToString("F0")%</p>
                <p class="text-muted">@occupiedCount of @totalUnits units occupied</p>
                <div class="progress" style="height: 24px;">
                    <div class="progress-bar @(occupancyRate >= 80 ? "bg-success" : occupancyRate >= 50 ? "bg-warning" : "bg-danger")"
                         role="progressbar"
                         style="width: @occupancyRate.ToString("F0")%"
                         aria-valuenow="@occupancyRate.ToString("F0")"
                         aria-valuemin="0"
                         aria-valuemax="100">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Units (@Model.Property.Units.Count)</h5>
    </div>
    <div class="card-body">
        @if (Model.Property.Units.Count == 0)
        {
            <p class="text-muted">No units have been added to this property.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Unit #</th>
                            <th>Status</th>
                            <th>Monthly Rent</th>
                            <th>Current Tenant</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var unit in Model.Property.Units.OrderBy(u => u.UnitNumber))
                        {
                            var activeLease = unit.Leases.FirstOrDefault(l => l.Status == LeaseStatus.Active);
                            <tr>
                                <td>@unit.UnitNumber</td>
                                <td>
                                    @await Html.PartialAsync("_StatusBadge", new ViewDataDictionary(ViewData) { { "Status", unit.Status.ToString() } })
                                </td>
                                <td>@unit.MonthlyRent.ToString("C")</td>
                                <td>
                                    @if (activeLease?.Tenant is not null)
                                    {
                                        @($"{activeLease.Tenant.FirstName} {activeLease.Tenant.LastName}")
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
