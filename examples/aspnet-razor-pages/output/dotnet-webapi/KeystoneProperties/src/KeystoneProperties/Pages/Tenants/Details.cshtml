@page "{id:int}"
@model KeystoneProperties.Pages.Tenants.DetailsModel
@{
    ViewData["Title"] = $"Tenant – {Model.Tenant.FullName}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@Model.Tenant.FullName</h1>
    <div>
        <a asp-page="Edit" asp-route-id="@Model.Tenant.Id" class="btn btn-outline-primary">Edit</a>
        @if (Model.Tenant.IsActive)
        {
            <a asp-page="Deactivate" asp-route-id="@Model.Tenant.Id" class="btn btn-outline-danger">Deactivate</a>
        }
        <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Tenant Information</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Email</dt>
                    <dd class="col-sm-7">@Model.Tenant.Email</dd>
                    <dt class="col-sm-5">Phone</dt>
                    <dd class="col-sm-7">@Model.Tenant.Phone</dd>
                    <dt class="col-sm-5">Date of Birth</dt>
                    <dd class="col-sm-7">@Model.Tenant.DateOfBirth.ToString("MMM d, yyyy")</dd>
                    <dt class="col-sm-5">Status</dt>
                    <dd class="col-sm-7">
                        @await Html.PartialAsync("_StatusBadge", new ViewDataDictionary(ViewData) { { "Status", Model.Tenant.IsActive ? "Active" : "Inactive" } })
                    </dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Emergency Contact</dt>
                    <dd class="col-sm-7">@Model.Tenant.EmergencyContactName</dd>
                    <dt class="col-sm-5">Emergency Phone</dt>
                    <dd class="col-sm-7">@Model.Tenant.EmergencyContactPhone</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Current Leases</h5>
    </div>
    <div class="card-body">
        @if (Model.CurrentLeases.Count == 0)
        {
            <p class="text-muted mb-0">No current leases.</p>
        }
        else
        {
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Property</th>
                        <th>Unit</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Monthly Rent</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lease in Model.CurrentLeases)
                    {
                        <tr>
                            <td>@lease.Unit?.Property?.Name</td>
                            <td>@lease.Unit?.UnitNumber</td>
                            <td>@lease.StartDate.ToString("MMM d, yyyy")</td>
                            <td>@lease.EndDate.ToString("MMM d, yyyy")</td>
                            <td>@lease.MonthlyRentAmount.ToString("C")</td>
                            <td>
                                @await Html.PartialAsync("_StatusBadge", new ViewDataDictionary(ViewData) { { "Status", lease.Status.ToString() } })
                            </td>
                            <td>
                                <a asp-page="/Leases/Details" asp-route-id="@lease.Id" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Past Leases</h5>
    </div>
    <div class="card-body">
        @if (Model.PastLeases.Count == 0)
        {
            <p class="text-muted mb-0">No past leases.</p>
        }
        else
        {
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Property</th>
                        <th>Unit</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Monthly Rent</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lease in Model.PastLeases)
                    {
                        <tr>
                            <td>@lease.Unit?.Property?.Name</td>
                            <td>@lease.Unit?.UnitNumber</td>
                            <td>@lease.StartDate.ToString("MMM d, yyyy")</td>
                            <td>@lease.EndDate.ToString("MMM d, yyyy")</td>
                            <td>@lease.MonthlyRentAmount.ToString("C")</td>
                            <td>
                                @await Html.PartialAsync("_StatusBadge", new ViewDataDictionary(ViewData) { { "Status", lease.Status.ToString() } })
                            </td>
                            <td>
                                <a asp-page="/Leases/Details" asp-route-id="@lease.Id" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Recent Payment History</h5>
    </div>
    <div class="card-body">
        @if (Model.RecentPayments.Count == 0)
        {
            <p class="text-muted mb-0">No payment history.</p>
        }
        else
        {
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Type</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model.RecentPayments)
                    {
                        <tr>
                            <td>@payment.PaymentDate.ToString("MMM d, yyyy")</td>
                            <td>@payment.Amount.ToString("C")</td>
                            <td>
                                @await Html.PartialAsync("_StatusBadge", new ViewDataDictionary(ViewData) { { "Status", payment.PaymentType.ToString() } })
                            </td>
                            <td>
                                @await Html.PartialAsync("_StatusBadge", new ViewDataDictionary(ViewData) { { "Status", payment.Status.ToString() } })
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Maintenance Requests</h5>
    </div>
    <div class="card-body">
        @if (Model.Tenant.MaintenanceRequests.Count == 0)
        {
            <p class="text-muted mb-0">No maintenance requests.</p>
        }
        else
        {
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Unit</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model.Tenant.MaintenanceRequests.OrderByDescending(r => r.SubmittedDate))
                    {
                        <tr>
                            <td>@request.Title</td>
                            <td>@request.Unit?.UnitNumber</td>
                            <td>
                                @await Html.PartialAsync("_StatusBadge", new ViewDataDictionary(ViewData) { { "Status", request.Priority.ToString() } })
                            </td>
                            <td>
                                @await Html.PartialAsync("_StatusBadge", new ViewDataDictionary(ViewData) { { "Status", request.Status.ToString() } })
                            </td>
                            <td>@request.SubmittedDate.ToString("MMM d, yyyy")</td>
                            <td>
                                <a asp-page="/Maintenance/Details" asp-route-id="@request.Id" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
