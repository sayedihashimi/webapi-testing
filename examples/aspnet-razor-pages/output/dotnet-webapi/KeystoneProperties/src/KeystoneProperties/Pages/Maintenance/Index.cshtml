@page
@model KeystoneProperties.Pages.Maintenance.IndexModel
@{
    ViewData["Title"] = "Maintenance Requests";

    var queryParts = new List<string>();
    if (Model.Status.HasValue) queryParts.Add($"status={Model.Status}");
    if (Model.Priority.HasValue) queryParts.Add($"priority={Model.Priority}");
    if (Model.PropertyId.HasValue) queryParts.Add($"propertyId={Model.PropertyId}");
    if (Model.Category.HasValue) queryParts.Add($"category={Model.Category}");
    ViewData["QueryString"] = string.Join("&", queryParts);

    string PriorityBadgeClass(KeystoneProperties.Models.MaintenancePriority p) => p switch
    {
        KeystoneProperties.Models.MaintenancePriority.Emergency => "bg-danger",
        KeystoneProperties.Models.MaintenancePriority.High => "bg-warning text-dark",
        KeystoneProperties.Models.MaintenancePriority.Medium => "bg-secondary",
        KeystoneProperties.Models.MaintenancePriority.Low => "bg-light text-dark",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Maintenance Requests</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Request
    </a>
</div>

<form method="get" class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label for="Status" class="form-label">Status</label>
                <select asp-for="Status" class="form-select"
                        asp-items="@(new SelectList(Enum.GetValues<KeystoneProperties.Models.MaintenanceStatus>()))">
                    <option value="">All Statuses</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="Priority" class="form-label">Priority</label>
                <select asp-for="Priority" class="form-select"
                        asp-items="@(new SelectList(Enum.GetValues<KeystoneProperties.Models.MaintenancePriority>()))">
                    <option value="">All Priorities</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="PropertyId" class="form-label">Property</label>
                <select asp-for="PropertyId" class="form-select"
                        asp-items="@(new SelectList(Model.Properties, "Id", "Name"))">
                    <option value="">All Properties</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="Category" class="form-label">Category</label>
                <select asp-for="Category" class="form-select"
                        asp-items="@(new SelectList(Enum.GetValues<KeystoneProperties.Models.MaintenanceCategory>()))">
                    <option value="">All Categories</option>
                </select>
            </div>
        </div>
        <div class="mt-3">
            <button type="submit" class="btn btn-outline-primary">Filter</button>
            <a asp-page="Index" class="btn btn-outline-secondary ms-2">Clear</a>
        </div>
    </div>
</form>

@if (Model.Requests.Items.Count == 0)
{
    <div class="alert alert-info">No maintenance requests found matching the selected filters.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Priority</th>
                    <th>Unit / Property</th>
                    <th>Tenant</th>
                    <th>Status</th>
                    <th>Submitted</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in Model.Requests.Items)
                {
                    <tr>
                        <td>@req.Title</td>
                        <td><span class="badge @PriorityBadgeClass(req.Priority)">@req.Priority</span></td>
                        <td>@req.Unit?.Property?.Name — @req.Unit?.UnitNumber</td>
                        <td>@req.Tenant?.FullName</td>
                        <td>
                            @await Html.PartialAsync("_StatusBadge", new ViewDataDictionary(ViewData) { { "Status", req.Status.ToString() } })
                        </td>
                        <td>@req.SubmittedDate.ToString("MMM d, yyyy")</td>
                        <td>
                            <a asp-page="Details" asp-route-id="@req.Id" class="btn btn-sm btn-outline-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @await Html.PartialAsync("_Pagination", KeystoneProperties.Services.PaginatedList<object>.Create(
        Model.Requests.Items.Cast<object>().ToList(),
        Model.Requests.TotalCount,
        Model.Requests.PageNumber,
        Model.Requests.PageSize))
}
