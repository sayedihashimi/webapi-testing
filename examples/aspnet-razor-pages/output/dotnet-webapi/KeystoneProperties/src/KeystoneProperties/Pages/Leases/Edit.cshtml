@page "{id:int}"
@model KeystoneProperties.Pages.Leases.EditModel
@{
    ViewData["Title"] = "Edit Lease";
    var isActive = Model.Lease.Status == KeystoneProperties.Models.LeaseStatus.Active;
}

<h1>Edit Lease</h1>

@if (isActive)
{
    <div class="alert alert-info">
        This lease is currently <strong>Active</strong>. Only the Notes field can be edited.
    </div>
}

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <input type="hidden" asp-for="Input.Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0">Lease Information</h5></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Tenant</dt>
                        <dd class="col-sm-8">@Model.Lease.Tenant.FullName</dd>
                        <dt class="col-sm-4">Unit</dt>
                        <dd class="col-sm-8">@Model.Lease.Unit.Property.Name - @Model.Lease.Unit.UnitNumber</dd>
                    </dl>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.StartDate" class="form-label"></label>
                    <input asp-for="Input.StartDate" class="form-control" type="date" disabled="@isActive" />
                    @if (isActive)
                    {
                        <input type="hidden" asp-for="Input.StartDate" />
                    }
                    <span asp-validation-for="Input.StartDate" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.EndDate" class="form-label"></label>
                    <input asp-for="Input.EndDate" class="form-control" type="date" disabled="@isActive" />
                    @if (isActive)
                    {
                        <input type="hidden" asp-for="Input.EndDate" />
                    }
                    <span asp-validation-for="Input.EndDate" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.MonthlyRentAmount" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Input.MonthlyRentAmount" class="form-control" disabled="@isActive" />
                    </div>
                    @if (isActive)
                    {
                        <input type="hidden" asp-for="Input.MonthlyRentAmount" />
                    }
                    <span asp-validation-for="Input.MonthlyRentAmount" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.DepositAmount" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Input.DepositAmount" class="form-control" disabled="@isActive" />
                    </div>
                    @if (isActive)
                    {
                        <input type="hidden" asp-for="Input.DepositAmount" />
                    }
                    <span asp-validation-for="Input.DepositAmount" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Status" class="form-label"></label>
                <select asp-for="Input.Status" class="form-select" disabled="@isActive"
                        asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Enum.GetValues<KeystoneProperties.Models.LeaseStatus>()))">
                </select>
                @if (isActive)
                {
                    <input type="hidden" asp-for="Input.Status" />
                }
                <span asp-validation-for="Input.Status" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Notes" class="form-label"></label>
                <textarea asp-for="Input.Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Notes" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-page="Details" asp-route-id="@Model.Lease.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
