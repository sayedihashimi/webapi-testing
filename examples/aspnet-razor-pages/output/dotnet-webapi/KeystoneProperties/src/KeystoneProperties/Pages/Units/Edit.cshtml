@page "{id:int}"
@model KeystoneProperties.Pages.Units.EditModel
@{
    ViewData["Title"] = "Edit Unit";
}

<h1>Edit Unit</h1>

<div class="row">
    <div class="col-md-8">
        <form method="post" asp-route-id="@Model.UnitId">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Input.PropertyId" class="form-label"></label>
                <select asp-for="Input.PropertyId" asp-items="Model.PropertyList" class="form-select">
                    <option value="">— Select Property —</option>
                </select>
                <span asp-validation-for="Input.PropertyId" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.UnitNumber" class="form-label"></label>
                    <input asp-for="Input.UnitNumber" class="form-control" />
                    <span asp-validation-for="Input.UnitNumber" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.Floor" class="form-label"></label>
                    <input asp-for="Input.Floor" class="form-control" />
                    <span asp-validation-for="Input.Floor" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.Bedrooms" class="form-label"></label>
                    <select asp-for="Input.Bedrooms" class="form-select">
                        @for (var i = 0; i <= 5; i++)
                        {
                            <option value="@i">@(i == 0 ? "Studio" : i.ToString())</option>
                        }
                    </select>
                    <span asp-validation-for="Input.Bedrooms" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.Bathrooms" class="form-label"></label>
                    <input asp-for="Input.Bathrooms" class="form-control" step="0.5" />
                    <span asp-validation-for="Input.Bathrooms" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.SquareFeet" class="form-label"></label>
                    <input asp-for="Input.SquareFeet" class="form-control" />
                    <span asp-validation-for="Input.SquareFeet" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.MonthlyRent" class="form-label"></label>
                    <input asp-for="Input.MonthlyRent" class="form-control" step="0.01" />
                    <span asp-validation-for="Input.MonthlyRent" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.DepositAmount" class="form-label"></label>
                    <input asp-for="Input.DepositAmount" class="form-control" step="0.01" />
                    <span asp-validation-for="Input.DepositAmount" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.Status" class="form-label"></label>
                    <select asp-for="Input.Status" asp-items="Model.StatusList" class="form-select"></select>
                    <span asp-validation-for="Input.Status" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Amenities" class="form-label"></label>
                <textarea asp-for="Input.Amenities" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Amenities" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-page="Details" asp-route-id="@Model.UnitId" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
