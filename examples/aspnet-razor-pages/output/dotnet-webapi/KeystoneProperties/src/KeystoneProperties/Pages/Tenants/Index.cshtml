@page
@model KeystoneProperties.Pages.Tenants.IndexModel
@{
    ViewData["Title"] = "Tenants";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Tenants</h1>
    <a asp-page="Create" class="btn btn-primary">Add Tenant</a>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-5">
        <input type="text" asp-for="Search" class="form-control" placeholder="Search by name or email..." />
    </div>
    <div class="col-md-3">
        <select asp-for="IsActive" class="form-select">
            <option value="">All Statuses</option>
            <option value="true">Active</option>
            <option value="false">Inactive</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary w-100">Search</button>
    </div>
    <div class="col-md-2">
        <a asp-page="Index" class="btn btn-outline-dark w-100">Clear</a>
    </div>
</form>

@if (Model.Tenants.Items.Count == 0)
{
    <div class="alert alert-info">No tenants found.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tenant in Model.Tenants.Items)
            {
                <tr>
                    <td>
                        <a asp-page="Details" asp-route-id="@tenant.Id">@tenant.FullName</a>
                    </td>
                    <td>@tenant.Email</td>
                    <td>@tenant.Phone</td>
                    <td>
                        @await Html.PartialAsync("_StatusBadge", new ViewDataDictionary(ViewData) { { "Status", tenant.IsActive ? "Active" : "Inactive" } })
                    </td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@tenant.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        @if (tenant.IsActive)
                        {
                            <a asp-page="Deactivate" asp-route-id="@tenant.Id" class="btn btn-sm btn-outline-danger">Deactivate</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.Tenants.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Tenants.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-page="Index" asp-route-pageNumber="@(Model.Tenants.PageNumber - 1)" asp-route-search="@Model.Search" asp-route-isActive="@Model.IsActive">Previous</a>
                </li>
                @for (var i = 1; i <= Model.Tenants.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Tenants.PageNumber ? "active" : "")">
                        <a class="page-link" asp-page="Index" asp-route-pageNumber="@i" asp-route-search="@Model.Search" asp-route-isActive="@Model.IsActive">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Tenants.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-page="Index" asp-route-pageNumber="@(Model.Tenants.PageNumber + 1)" asp-route-search="@Model.Search" asp-route-isActive="@Model.IsActive">Next</a>
                </li>
            </ul>
        </nav>
        <p class="text-muted text-center">Showing page @Model.Tenants.PageNumber of @Model.Tenants.TotalPages (@Model.Tenants.TotalCount total items)</p>
    }
}
