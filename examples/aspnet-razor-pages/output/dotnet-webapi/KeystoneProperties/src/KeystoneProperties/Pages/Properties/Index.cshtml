@page
@model KeystoneProperties.Pages.Properties.IndexModel
@{
    ViewData["Title"] = "Properties";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Properties</h1>
    <a asp-page="Create" class="btn btn-primary">Add Property</a>
</div>

<form method="get" class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label for="Search" class="form-label">Search</label>
                <input asp-for="Search" class="form-control" placeholder="Name or city..." />
            </div>
            <div class="col-md-3">
                <label for="Type" class="form-label">Property Type</label>
                <select asp-for="Type" asp-items="Model.PropertyTypeOptions" class="form-select">
                    <option value="">All Types</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="IsActive" class="form-label">Status</label>
                <select asp-for="IsActive" class="form-select">
                    <option value="">All</option>
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-outline-primary">Filter</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </div>
    </div>
</form>

@if (Model.Properties.Items.Count == 0)
{
    <div class="alert alert-info">No properties found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Address</th>
                    <th>Type</th>
                    <th>Units</th>
                    <th>Occupancy</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var property in Model.Properties.Items)
                {
                    var occupied = Model.OccupiedCounts.GetValueOrDefault(property.Id);
                    var occupancyRate = property.TotalUnits > 0
                        ? (double)occupied / property.TotalUnits * 100
                        : 0;

                    <tr>
                        <td>
                            <a asp-page="Details" asp-route-id="@property.Id">@property.Name</a>
                        </td>
                        <td>@property.Address, @property.City, @property.State @property.ZipCode</td>
                        <td>@property.PropertyType</td>
                        <td>@property.Units.Count / @property.TotalUnits</td>
                        <td>
                            <div class="progress" style="min-width: 80px;" title="@occupancyRate.ToString("F0")% occupied">
                                <div class="progress-bar @(occupancyRate >= 80 ? "bg-success" : occupancyRate >= 50 ? "bg-warning" : "bg-danger")"
                                     role="progressbar"
                                     style="width: @occupancyRate.ToString("F0")%"
                                     aria-valuenow="@occupancyRate.ToString("F0")"
                                     aria-valuemin="0"
                                     aria-valuemax="100">
                                    @occupancyRate.ToString("F0")%
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (property.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a asp-page="Details" asp-route-id="@property.Id" class="btn btn-outline-primary">Details</a>
                                <a asp-page="Edit" asp-route-id="@property.Id" class="btn btn-outline-secondary">Edit</a>
                                @if (property.IsActive)
                                {
                                    <a asp-page="Deactivate" asp-route-id="@property.Id" class="btn btn-outline-danger">Deactivate</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Properties.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Properties.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-page="Index"
                       asp-route-search="@Model.Search"
                       asp-route-type="@Model.Type"
                       asp-route-isActive="@Model.IsActive"
                       asp-route-pageNumber="@(Model.PageNumber - 1)"
                       asp-route-pageSize="@Model.PageSize">Previous</a>
                </li>
                @for (var i = 1; i <= Model.Properties.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link"
                           asp-page="Index"
                           asp-route-search="@Model.Search"
                           asp-route-type="@Model.Type"
                           asp-route-isActive="@Model.IsActive"
                           asp-route-pageNumber="@i"
                           asp-route-pageSize="@Model.PageSize">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Properties.HasNextPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-page="Index"
                       asp-route-search="@Model.Search"
                       asp-route-type="@Model.Type"
                       asp-route-isActive="@Model.IsActive"
                       asp-route-pageNumber="@(Model.PageNumber + 1)"
                       asp-route-pageSize="@Model.PageSize">Next</a>
                </li>
            </ul>
        </nav>
        <p class="text-muted text-center">
            Showing page @Model.Properties.PageNumber of @Model.Properties.TotalPages (@Model.Properties.TotalCount total items)
        </p>
    }
}
