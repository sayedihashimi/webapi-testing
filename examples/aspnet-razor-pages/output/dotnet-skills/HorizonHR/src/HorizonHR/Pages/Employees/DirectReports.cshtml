@page "{id:int}"
@model HorizonHR.Pages.Employees.DirectReportsModel
@{
    ViewData["Title"] = $"Direct Reports - {Model.Employee.FullName}";
}

<section class="py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="Index">Employees</a></li>
            <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@Model.Employee.Id">@Model.Employee.FullName</a></li>
            <li class="breadcrumb-item active" aria-current="page">Direct Reports</li>
        </ol>
    </nav>

    <h1 class="mb-2">Direct Reports</h1>
    <p class="text-muted mb-4">
        Employees reporting to <strong><a asp-page="Details" asp-route-id="@Model.Employee.Id">@Model.Employee.FullName</a></strong>
        (@Model.Employee.JobTitle, @Model.Employee.Department?.Name)
    </p>

    @if (Model.DirectReports.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Employee Number</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Job Title</th>
                        <th>Department</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in Model.DirectReports)
                    {
                        <tr>
                            <td>@report.EmployeeNumber</td>
                            <td>
                                <a asp-page="Details" asp-route-id="@report.Id">@report.FullName</a>
                            </td>
                            <td>@report.Email</td>
                            <td>@report.JobTitle</td>
                            <td>@report.Department?.Name</td>
                            <td>
                                <partial name="_StatusBadge" model="@report.Status.ToString()" />
                            </td>
                            <td>
                                <a asp-page="Details" asp-route-id="@report.Id" class="btn btn-sm btn-outline-info">Details</a>
                                <a asp-page="Edit" asp-route-id="@report.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No direct reports found for this employee.
        </div>
    }

    <a asp-page="Details" asp-route-id="@Model.Employee.Id" class="btn btn-outline-secondary">Back to Employee Details</a>
</section>
