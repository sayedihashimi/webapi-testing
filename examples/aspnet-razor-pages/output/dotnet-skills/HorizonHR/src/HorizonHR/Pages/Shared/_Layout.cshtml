<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Horizon HR</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YcnS/1p0TTFJU6bDEFwzY3lQ0P7hMZbqEMaF" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark" aria-label="Main navigation">
            <div class="container">
                <a class="navbar-brand" asp-page="/Index">Horizon HR</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                @{
                    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
                }
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @(currentPage == "/Index" || currentPage == "/Dashboard/Index" ? "active" : "")"
                               asp-page="/Index"
                               aria-current="@(currentPage == "/Index" || currentPage == "/Dashboard/Index" ? "page" : null)">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.StartsWith("/Employees") ? "active" : "")"
                               asp-page="/Employees/Index"
                               aria-current="@(currentPage.StartsWith("/Employees") ? "page" : null)">Employees</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.StartsWith("/Departments") ? "active" : "")"
                               asp-page="/Departments/Index"
                               aria-current="@(currentPage.StartsWith("/Departments") ? "page" : null)">Departments</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.StartsWith("/Leave") ? "active" : "")"
                               asp-page="/Leave/Index"
                               aria-current="@(currentPage.StartsWith("/Leave") ? "page" : null)">Leave</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.StartsWith("/Reviews") ? "active" : "")"
                               asp-page="/Reviews/Index"
                               aria-current="@(currentPage.StartsWith("/Reviews") ? "page" : null)">Reviews</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentPage.StartsWith("/Skills") ? "active" : "")"
                               asp-page="/Skills/Index"
                               aria-current="@(currentPage.StartsWith("/Skills") ? "page" : null)">Skills</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container">
        <partial name="_FlashMessages" />
        @RenderBody()
    </main>

    <footer class="border-top text-muted">
        <div class="container text-center">
            &copy; 2026 Horizon HR
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
