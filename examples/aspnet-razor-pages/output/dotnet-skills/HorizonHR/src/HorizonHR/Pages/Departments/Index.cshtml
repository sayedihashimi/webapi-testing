@page
@model HorizonHR.Pages.Departments.IndexModel
@{
    ViewData["Title"] = "Departments";
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
}

<header class="d-flex justify-content-between align-items-center mb-4">
    <h1>Departments</h1>
    <a asp-page="Create" class="btn btn-primary">Create Department</a>
</header>

@if (Model.Departments.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Manager</th>
                    <th>Parent Department</th>
                    <th>Employee Count</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var department in Model.Departments)
                {
                    <tr>
                        <td>@department.Name</td>
                        <td><code>@department.Code</code></td>
                        <td>@(department.Manager?.FullName ?? "—")</td>
                        <td>@(department.ParentDepartment?.Name ?? "—")</td>
                        <td>@department.Employees.Count</td>
                        <td>
                            <partial name="_StatusBadge" model="@(department.IsActive ? "Active" : "Terminated")" />
                        </td>
                        <td>
                            <a asp-page="Details" asp-route-id="@department.Id" class="btn btn-sm btn-outline-primary">Details</a>
                            <a asp-page="Edit" asp-route-id="@department.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="@(new HorizonHR.Models.PaginationModel
    {
        CurrentPage = Model.PageNumber,
        TotalPages = totalPages,
        PageUrl = "/Departments/Index"
    })" />
}
else
{
    <p class="text-muted">No departments found.</p>
}
