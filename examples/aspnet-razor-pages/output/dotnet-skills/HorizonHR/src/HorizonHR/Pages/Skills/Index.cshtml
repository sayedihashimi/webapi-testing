@page
@model HorizonHR.Pages.Skills.IndexModel
@{
    ViewData["Title"] = "Skills";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Skills</h1>
    <div class="d-flex gap-2">
        <a asp-page="Search" class="btn btn-outline-primary">Search by Skill</a>
        <a asp-page="Create" class="btn btn-primary">Create Skill</a>
    </div>
</div>

@if (Model.SkillsByCategory.Any())
{
    @foreach (var category in Model.SkillsByCategory)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">@category.Key</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Employees</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var skill in category.Value)
                            {
                                <tr>
                                    <td>@skill.Name</td>
                                    <td>@(skill.Description ?? "—")</td>
                                    <td>
                                        <span class="badge bg-info">@skill.EmployeeSkills.Count</span>
                                    </td>
                                    <td>
                                        <a asp-page="Edit" asp-route-id="@skill.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="alert alert-info">No skills have been added yet.</div>
}
