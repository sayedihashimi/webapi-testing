@page
@model HorizonHR.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}
<section class="text-center py-5">
    <h1 class="text-danger">An error occurred</h1>
    <p class="lead">Sorry, an unexpected error has occurred while processing your request.</p>
    @if (Model.RequestId != null)
    {
        <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }
    <a asp-page="/Index" class="btn btn-primary mt-3">Return to Dashboard</a>
</section>
