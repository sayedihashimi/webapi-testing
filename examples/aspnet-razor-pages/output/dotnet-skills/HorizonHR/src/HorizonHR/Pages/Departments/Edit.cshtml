@page "{id:int}"
@model HorizonHR.Pages.Departments.EditModel
@{
    ViewData["Title"] = "Edit Department";
}

<h1 class="mb-4">Edit Department</h1>

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Name" class="form-label"></label>
                <input asp-for="Input.Name" class="form-control" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Code" class="form-label"></label>
                <input asp-for="Input.Code" class="form-control" />
                <span asp-validation-for="Input.Code" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.ParentDepartmentId" class="form-label"></label>
                <select asp-for="Input.ParentDepartmentId" asp-items="Model.ParentDepartments" class="form-select">
                    <option value="">— None —</option>
                </select>
                <span asp-validation-for="Input.ParentDepartmentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.ManagerId" class="form-label"></label>
                <select asp-for="Input.ManagerId" asp-items="Model.Managers" class="form-select">
                    <option value="">— None —</option>
                </select>
                <span asp-validation-for="Input.ManagerId" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="Input.IsActive" class="form-check-input" />
                <label asp-for="Input.IsActive" class="form-check-label"></label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-page="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
