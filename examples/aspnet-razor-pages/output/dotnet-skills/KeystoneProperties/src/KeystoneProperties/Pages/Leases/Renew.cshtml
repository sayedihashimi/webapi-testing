@page "{id:int}"
@model KeystoneProperties.Pages.Leases.RenewModel
@{
    ViewData["Title"] = "Renew Lease";
}

<section>
    <h1 class="mb-4"><i class="bi bi-arrow-repeat"></i> Renew Lease</h1>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Original Lease Information</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-5">Tenant</dt>
                        <dd class="col-sm-7">@Model.Lease.Tenant.FullName</dd>

                        <dt class="col-sm-5">Property</dt>
                        <dd class="col-sm-7">@Model.Lease.Unit.Property.Name</dd>

                        <dt class="col-sm-5">Unit</dt>
                        <dd class="col-sm-7">@Model.Lease.Unit.UnitNumber</dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-5">Start Date</dt>
                        <dd class="col-sm-7">@Model.Lease.StartDate.ToString("MMM dd, yyyy")</dd>

                        <dt class="col-sm-5">End Date</dt>
                        <dd class="col-sm-7">@Model.Lease.EndDate.ToString("MMM dd, yyyy")</dd>

                        <dt class="col-sm-5">Monthly Rent</dt>
                        <dd class="col-sm-7">@Model.Lease.MonthlyRentAmount.ToString("C")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="bi bi-arrow-repeat"></i> Renewal Details</h5>
        </div>
        <div class="card-body">
            <form method="post">
                <input type="hidden" asp-for="Input.Id" />
                <input type="hidden" asp-for="Input.NewStartDate" />
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Input.NewStartDate" class="form-label"></label>
                        <input type="date" class="form-control" value="@Model.Input.NewStartDate.ToString("yyyy-MM-dd")" disabled />
                        <div class="form-text">Automatically set to the day after the current lease ends.</div>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Input.NewEndDate" class="form-label"></label>
                        <input asp-for="Input.NewEndDate" type="date" class="form-control" />
                        <span asp-validation-for="Input.NewEndDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Input.NewRentAmount" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Input.NewRentAmount" class="form-control" />
                        </div>
                        <span asp-validation-for="Input.NewRentAmount" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-arrow-repeat"></i> Renew Lease
                    </button>
                    <a asp-page="Details" asp-route-id="@Model.Lease.Id" class="btn btn-outline-secondary ms-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
