@page "{id:int}"
@model KeystoneProperties.Pages.Maintenance.DetailsModel
@{
    ViewData["Title"] = "Maintenance Request Details";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-wrench"></i> Maintenance Request #@Model.Request.Id</h1>
        <div>
            @if (!Model.IsTerminalState)
            {
                <a asp-page="UpdateStatus" asp-route-id="@Model.Request.Id" class="btn btn-warning">
                    <i class="bi bi-arrow-repeat"></i> Update Status
                </a>
            }
            <a asp-page="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Request Details</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Title</dt>
                        <dd class="col-sm-9">@Model.Request.Title</dd>

                        <dt class="col-sm-3">Description</dt>
                        <dd class="col-sm-9">@Model.Request.Description</dd>

                        <dt class="col-sm-3">Priority</dt>
                        <dd class="col-sm-9">
                            <partial name="_StatusBadge" model='(Model.Request.Priority.ToString(), "MaintenancePriority")' />
                        </dd>

                        <dt class="col-sm-3">Category</dt>
                        <dd class="col-sm-9">@Model.Request.Category</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            <partial name="_StatusBadge" model='(Model.Request.Status.ToString(), "MaintenanceStatus")' />
                        </dd>

                        @if (!string.IsNullOrEmpty(Model.Request.AssignedTo))
                        {
                            <dt class="col-sm-3">Assigned To</dt>
                            <dd class="col-sm-9">@Model.Request.AssignedTo</dd>
                        }

                        @if (!string.IsNullOrEmpty(Model.Request.CompletionNotes))
                        {
                            <dt class="col-sm-3">Completion Notes</dt>
                            <dd class="col-sm-9">@Model.Request.CompletionNotes</dd>
                        }
                    </dl>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-building"></i> Unit &amp; Tenant Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Property</dt>
                        <dd class="col-sm-9">@Model.Request.Unit.Property.Name</dd>

                        <dt class="col-sm-3">Unit</dt>
                        <dd class="col-sm-9">Unit @Model.Request.Unit.UnitNumber</dd>

                        <dt class="col-sm-3">Tenant</dt>
                        <dd class="col-sm-9">@Model.Request.Tenant.FullName</dd>

                        <dt class="col-sm-3">Tenant Email</dt>
                        <dd class="col-sm-9">@Model.Request.Tenant.Email</dd>

                        <dt class="col-sm-3">Tenant Phone</dt>
                        <dd class="col-sm-9">@Model.Request.Tenant.Phone</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-clock-history"></i> Status Timeline</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <i class="bi bi-check-circle-fill text-info"></i>
                                <strong>Submitted</strong>
                            </div>
                            <span class="text-muted small">@Model.Request.SubmittedDate.ToString("MMM dd, yyyy h:mm tt")</span>
                        </li>
                        @if (Model.Request.AssignedDate.HasValue)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-check-circle-fill text-primary"></i>
                                    <strong>Assigned</strong>
                                </div>
                                <span class="text-muted small">@Model.Request.AssignedDate.Value.ToString("MMM dd, yyyy h:mm tt")</span>
                            </li>
                        }
                        @if (Model.Request.CompletedDate.HasValue)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                    <strong>Completed</strong>
                                </div>
                                <span class="text-muted small">@Model.Request.CompletedDate.Value.ToString("MMM dd, yyyy h:mm tt")</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-currency-dollar"></i> Cost Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-6">Estimated Cost</dt>
                        <dd class="col-sm-6">@(Model.Request.EstimatedCost?.ToString("C") ?? "—")</dd>

                        <dt class="col-sm-6">Actual Cost</dt>
                        <dd class="col-sm-6">@(Model.Request.ActualCost?.ToString("C") ?? "—")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</section>
