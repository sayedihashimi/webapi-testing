@page
@model KeystoneProperties.Pages.Units.IndexModel
@{
    ViewData["Title"] = "Units";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-door-open"></i> Units</h1>
        <a asp-page="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Create New Unit
        </a>
    </div>

    <form method="get" class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label for="PropertyId" class="form-label">Property</label>
                    <select asp-for="PropertyId" asp-items="Model.PropertyList" class="form-select">
                        <option value="">All Properties</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="Status" class="form-label">Status</label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<UnitStatus>()" class="form-select">
                        <option value="">All Statuses</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="Bedrooms" class="form-label">Bedrooms</label>
                    <select asp-for="Bedrooms" class="form-select">
                        <option value="">Any</option>
                        <option value="0">Studio</option>
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="MinRent" class="form-label">Min Rent</label>
                    <input asp-for="MinRent" class="form-control" placeholder="Min" />
                </div>
                <div class="col-md-2">
                    <label for="MaxRent" class="form-label">Max Rent</label>
                    <input asp-for="MaxRent" class="form-control" placeholder="Max" />
                </div>
                <div class="col-md-3">
                    <label for="Search" class="form-label">Unit Number</label>
                    <input asp-for="Search" class="form-control" placeholder="Search by unit number" />
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-search"></i> Filter
                    </button>
                    <a asp-page="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg"></i> Clear
                    </a>
                </div>
            </div>
        </div>
    </form>

    @if (!Model.Units.Any())
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle"></i> No units found matching your criteria.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Unit Number</th>
                        <th>Property</th>
                        <th>Floor</th>
                        <th>Bedrooms</th>
                        <th>Bathrooms</th>
                        <th>Sq Ft</th>
                        <th>Monthly Rent</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Units)
                    {
                        <tr>
                            <td>@item.UnitNumber</td>
                            <td>@item.Property.Name</td>
                            <td>@item.Floor</td>
                            <td>@(item.Bedrooms == 0 ? "Studio" : item.Bedrooms.ToString())</td>
                            <td>@item.Bathrooms</td>
                            <td>@item.SquareFeet.ToString("N0")</td>
                            <td>@item.MonthlyRent.ToString("C")</td>
                            <td>@await Html.PartialAsync("_StatusBadge", (item.Status.ToString(), "UnitStatus"))</td>
                            <td>
                                <a asp-page="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Units.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-page="Index"
                       asp-route-pageNumber="@(Model.Units.PageIndex - 1)"
                       asp-route-propertyId="@Model.PropertyId"
                       asp-route-status="@Model.Status"
                       asp-route-bedrooms="@Model.Bedrooms"
                       asp-route-minRent="@Model.MinRent"
                       asp-route-maxRent="@Model.MaxRent"
                       asp-route-search="@Model.Search">
                        <span aria-hidden="true">&laquo;</span> Previous
                    </a>
                </li>
                @for (var i = 1; i <= Model.Units.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Units.PageIndex ? "active" : "")">
                        <a class="page-link"
                           asp-page="Index"
                           asp-route-pageNumber="@i"
                           asp-route-propertyId="@Model.PropertyId"
                           asp-route-status="@Model.Status"
                           asp-route-bedrooms="@Model.Bedrooms"
                           asp-route-minRent="@Model.MinRent"
                           asp-route-maxRent="@Model.MaxRent"
                           asp-route-search="@Model.Search">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Units.HasNextPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-page="Index"
                       asp-route-pageNumber="@(Model.Units.PageIndex + 1)"
                       asp-route-propertyId="@Model.PropertyId"
                       asp-route-status="@Model.Status"
                       asp-route-bedrooms="@Model.Bedrooms"
                       asp-route-minRent="@Model.MinRent"
                       asp-route-maxRent="@Model.MaxRent"
                       asp-route-search="@Model.Search">
                        Next <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>
        <p class="text-center text-muted small">
            Showing page @Model.Units.PageIndex of @Model.Units.TotalPages (@Model.Units.TotalCount total items)
        </p>
    }
</section>
