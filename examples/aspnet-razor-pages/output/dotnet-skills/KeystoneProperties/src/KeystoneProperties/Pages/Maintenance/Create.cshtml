@page
@model KeystoneProperties.Pages.Maintenance.CreateModel
@{
    ViewData["Title"] = "New Maintenance Request";
}

<section>
    <h1 class="mb-4"><i class="bi bi-wrench"></i> New Maintenance Request</h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Input.UnitId" class="form-label"></label>
                            <select asp-for="Input.UnitId" asp-items="Model.UnitList" class="form-select">
                                <option value="">-- Select Unit --</option>
                            </select>
                            <span asp-validation-for="Input.UnitId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.TenantId" class="form-label"></label>
                            <select asp-for="Input.TenantId" asp-items="Model.TenantList" class="form-select">
                                <option value="">-- Select Tenant --</option>
                            </select>
                            <span asp-validation-for="Input.TenantId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Title" class="form-label"></label>
                            <input asp-for="Input.Title" class="form-control" />
                            <span asp-validation-for="Input.Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Description" class="form-label"></label>
                            <textarea asp-for="Input.Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Input.Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Priority" class="form-label"></label>
                            <select asp-for="Input.Priority" asp-items="Html.GetEnumSelectList<MaintenancePriority>()" class="form-select" id="prioritySelect">
                                <option value="">-- Select Priority --</option>
                            </select>
                            <span asp-validation-for="Input.Priority" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Category" class="form-label"></label>
                            <select asp-for="Input.Category" asp-items="Html.GetEnumSelectList<MaintenanceCategory>()" class="form-select">
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="Input.Category" class="text-danger"></span>
                        </div>

                        <div class="mb-3" id="assignedToGroup" style="display: none;">
                            <label asp-for="Input.AssignedTo" class="form-label"></label>
                            <input asp-for="Input.AssignedTo" class="form-control" id="assignedToInput" />
                            <span asp-validation-for="Input.AssignedTo" class="text-danger"></span>
                            <div class="form-text">Required for emergency priority requests.</div>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg"></i> Submit Request
                            </button>
                            <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('prioritySelect').addEventListener('change', function() {
            var assignedGroup = document.getElementById('assignedToGroup');
            if (this.value === 'Emergency' || this.value === '3') {
                assignedGroup.style.display = 'block';
                document.getElementById('assignedToInput').required = true;
            } else {
                assignedGroup.style.display = 'none';
                document.getElementById('assignedToInput').required = false;
            }
        });
    </script>
}
