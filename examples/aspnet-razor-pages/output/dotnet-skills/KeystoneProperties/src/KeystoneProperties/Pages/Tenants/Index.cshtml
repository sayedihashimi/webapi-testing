@page
@model KeystoneProperties.Pages.Tenants.IndexModel
@{
    ViewData["Title"] = "Tenants";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-people"></i> Tenants</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Add Tenant
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label for="Search" class="form-label">Search by name or email</label>
                <input type="text" class="form-control" id="Search" name="Search"
                       value="@Model.Search" placeholder="Enter name or email..." />
            </div>
            <div class="col-md-3">
                <label for="IsActive" class="form-label">Status</label>
                <select class="form-select" id="IsActive" name="IsActive">
                    <option value="">All</option>
                    <option value="true" selected="@(Model.IsActive == true)">Active</option>
                    <option value="false" selected="@(Model.IsActive == false)">Inactive</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-outline-primary me-2">
                    <i class="bi bi-search"></i> Search
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i> Clear
                </a>
            </div>
        </form>
    </div>
</div>

@if (Model.Tenants.Count == 0)
{
    <div class="alert alert-info text-center" role="alert">
        <i class="bi bi-info-circle"></i> No tenants found. Try adjusting your search criteria or
        <a asp-page="Create">add a new tenant</a>.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Active</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tenant in Model.Tenants)
                {
                    <tr>
                        <td>@tenant.FullName</td>
                        <td>@tenant.Email</td>
                        <td>@tenant.Phone</td>
                        <td>
                            @if (tenant.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            <a asp-page="Details" asp-route-id="@tenant.Id" class="btn btn-sm btn-outline-info" title="Details">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <a asp-page="Edit" asp-route-id="@tenant.Id" class="btn btn-sm btn-outline-warning" title="Edit">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_PaginationPartial" model="@(new PaginatedList<object>(
        Model.Tenants.Cast<object>().ToList(),
        Model.Tenants.TotalCount,
        Model.Tenants.PageIndex,
        10))" />
}
