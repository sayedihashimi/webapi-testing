@page "{id:int}"
@model KeystoneProperties.Pages.Properties.DetailsModel
@{
    ViewData["Title"] = $"Property – {Model.Property.Name}";
}

<section>
    <h1>@Model.Property.Name</h1>

    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Property Information</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.Property.Name</dd>

                        <dt class="col-sm-4">Address</dt>
                        <dd class="col-sm-8">@Model.Property.Address</dd>

                        <dt class="col-sm-4">City / State</dt>
                        <dd class="col-sm-8">@Model.Property.City, @Model.Property.State @Model.Property.ZipCode</dd>

                        <dt class="col-sm-4">Type</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-info text-dark">@Model.Property.PropertyType</span>
                        </dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Year Built</dt>
                        <dd class="col-sm-8">@(Model.Property.YearBuilt?.ToString() ?? "N/A")</dd>

                        <dt class="col-sm-4">Total Units</dt>
                        <dd class="col-sm-8">@Model.Property.TotalUnits</dd>

                        <dt class="col-sm-4">Active</dt>
                        <dd class="col-sm-8">
                            @if (Model.Property.IsActive)
                            {
                                <span class="text-success fw-bold">Yes</span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold">No</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@(Model.Property.Description ?? "N/A")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-primary">@Model.TotalUnits</h5>
                    <p class="card-text">Total Units</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-success">@Model.OccupiedUnits</h5>
                    <p class="card-text">Occupied</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-warning">@Model.AvailableUnits</h5>
                    <p class="card-text">Available</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title text-danger">@Model.MaintenanceUnits</h5>
                    <p class="card-text">Maintenance</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Units</h5>
        </div>
        <div class="card-body">
            @if (Model.Property.Units.Count == 0)
            {
                <p class="text-muted">No units found for this property.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Unit Number</th>
                                <th>Floor</th>
                                <th>Bedrooms</th>
                                <th>Bathrooms</th>
                                <th>Sq Ft</th>
                                <th>Rent</th>
                                <th>Status</th>
                                <th>Current Tenant</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var unit in Model.Property.Units)
                            {
                                var activeLease = unit.Leases?.FirstOrDefault(l => l.Status == LeaseStatus.Active);
                                var tenantName = activeLease?.Tenant?.FullName ?? "N/A";

                                <tr>
                                    <td>@unit.UnitNumber</td>
                                    <td>@(unit.Floor?.ToString() ?? "N/A")</td>
                                    <td>@unit.Bedrooms</td>
                                    <td>@unit.Bathrooms</td>
                                    <td>@unit.SquareFeet.ToString("N0")</td>
                                    <td>@unit.MonthlyRent.ToString("C")</td>
                                    <td>
                                        @await Html.PartialAsync("_StatusBadge", (unit.Status.ToString(), "UnitStatus"))
                                    </td>
                                    <td>@tenantName</td>
                                    <td>
                                        <a asp-page="/Units/Details" asp-route-id="@unit.Id" class="btn btn-sm btn-outline-primary" title="View Unit">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="d-flex gap-2">
        <a asp-page="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
        <a asp-page="Edit" asp-route-id="@Model.Property.Id" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Edit
        </a>
        @if (Model.Property.IsActive)
        {
            <a asp-page="Deactivate" asp-route-id="@Model.Property.Id" class="btn btn-danger">
                <i class="bi bi-x-circle"></i> Deactivate
            </a>
        }
    </div>
</section>
