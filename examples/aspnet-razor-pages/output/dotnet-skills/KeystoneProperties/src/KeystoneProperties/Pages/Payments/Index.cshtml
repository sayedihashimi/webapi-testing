@page
@model KeystoneProperties.Pages.Payments.IndexModel
@{
    ViewData["Title"] = "Payments";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-cash-stack"></i> Payments</h1>
        <div>
            <a asp-page="Overdue" class="btn btn-outline-warning me-2">
                <i class="bi bi-exclamation-triangle"></i> Overdue
            </a>
            <a asp-page="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Record Payment
            </a>
        </div>
    </div>

    <form method="get" class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-2">
                    <label asp-for="Type" class="form-label">Type</label>
                    <select asp-for="Type" asp-items="Html.GetEnumSelectList<PaymentType>()" class="form-select">
                        <option value="">All Types</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<PaymentStatus>()" class="form-select">
                        <option value="">All Statuses</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label asp-for="PropertyId" class="form-label">Property</label>
                    <select asp-for="PropertyId" asp-items="Model.PropertyList" class="form-select">
                        <option value="">All Properties</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label asp-for="FromDate" class="form-label">From Date</label>
                    <input asp-for="FromDate" type="date" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label asp-for="ToDate" class="form-label">To Date</label>
                    <input asp-for="ToDate" type="date" class="form-control" />
                </div>
                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-funnel"></i> Filter
                    </button>
                    <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
                </div>
            </div>
        </div>
    </form>

    @if (Model.Payments.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Tenant</th>
                        <th>Property / Unit</th>
                        <th>Amount</th>
                        <th>Type</th>
                        <th>Method</th>
                        <th>Status</th>
                        <th>Reference #</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model.Payments)
                    {
                        <tr>
                            <td>@payment.PaymentDate.ToString("MMM dd, yyyy")</td>
                            <td>@payment.Lease.Tenant.FullName</td>
                            <td>@payment.Lease.Unit.Property.Name / @payment.Lease.Unit.UnitNumber</td>
                            <td>@payment.Amount.ToString("C")</td>
                            <td><span class="badge bg-info text-dark">@payment.PaymentType</span></td>
                            <td>@payment.PaymentMethod</td>
                            <td>
                                <partial name="_StatusBadge" model="@(payment.Status.ToString(), "PaymentStatus")" />
                            </td>
                            <td>@(payment.ReferenceNumber ?? "—")</td>
                            <td>
                                <a asp-page="Details" asp-route-id="@payment.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Payments.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-route-pageNumber="@(Model.Payments.PageIndex - 1)"
                       asp-route-type="@Model.Type"
                       asp-route-status="@Model.Status"
                       asp-route-propertyId="@Model.PropertyId"
                       asp-route-fromDate="@Model.FromDate"
                       asp-route-toDate="@Model.ToDate">
                        <span aria-hidden="true">&laquo;</span> Previous
                    </a>
                </li>
                @for (var i = 1; i <= Model.Payments.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Payments.PageIndex ? "active" : "")">
                        <a class="page-link"
                           asp-route-pageNumber="@i"
                           asp-route-type="@Model.Type"
                           asp-route-status="@Model.Status"
                           asp-route-propertyId="@Model.PropertyId"
                           asp-route-fromDate="@Model.FromDate"
                           asp-route-toDate="@Model.ToDate">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Payments.HasNextPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-route-pageNumber="@(Model.Payments.PageIndex + 1)"
                       asp-route-type="@Model.Type"
                       asp-route-status="@Model.Status"
                       asp-route-propertyId="@Model.PropertyId"
                       asp-route-fromDate="@Model.FromDate"
                       asp-route-toDate="@Model.ToDate">
                        Next <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>
        <p class="text-center text-muted small">
            Showing page @Model.Payments.PageIndex of @Model.Payments.TotalPages (@Model.Payments.TotalCount total items)
        </p>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-cash-stack display-4"></i>
            <p class="mt-3">No payments found matching your filters.</p>
        </div>
    }
</section>
