@page
@model KeystoneProperties.Pages.Inspections.IndexModel
@{
    ViewData["Title"] = "Inspections";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-clipboard-check"></i> Inspections</h1>
        <a asp-page="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Schedule Inspection
        </a>
    </div>

    <form method="get" class="card mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label for="TypeFilter" class="form-label">Inspection Type</label>
                    <select asp-for="TypeFilter" asp-items="Html.GetEnumSelectList<InspectionType>()" class="form-select">
                        <option value="">All Types</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="UnitId" class="form-label">Unit ID</label>
                    <input asp-for="UnitId" class="form-control" placeholder="Unit ID" />
                </div>
                <div class="col-md-2">
                    <label for="FromDate" class="form-label">From Date</label>
                    <input asp-for="FromDate" type="date" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label for="ToDate" class="form-label">To Date</label>
                    <input asp-for="ToDate" type="date" class="form-control" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-primary me-2">
                        <i class="bi bi-funnel"></i> Filter
                    </button>
                    <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
                </div>
            </div>
        </div>
    </form>

    @if (Model.Inspections.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Scheduled Date</th>
                        <th>Type</th>
                        <th>Unit</th>
                        <th>Inspector</th>
                        <th>Completed</th>
                        <th>Condition</th>
                        <th>Follow-Up</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Inspections)
                    {
                        <tr>
                            <td>@item.ScheduledDate.ToString("MMM dd, yyyy")</td>
                            <td>@item.InspectionType</td>
                            <td>@item.Unit.Property.Name - @item.Unit.UnitNumber</td>
                            <td>@item.InspectorName</td>
                            <td>
                                @if (item.CompletedDate.HasValue)
                                {
                                    @item.CompletedDate.Value.ToString("MMM dd, yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">No</span>
                                }
                            </td>
                            <td>
                                @await Html.PartialAsync("_StatusBadge", (item.OverallCondition?.ToString() ?? "N/A", "OverallCondition"))
                            </td>
                            <td>
                                @if (item.FollowUpRequired)
                                {
                                    <span class="badge bg-warning text-dark">Yes</span>
                                }
                                else
                                {
                                    <span class="text-muted">No</span>
                                }
                            </td>
                            <td>
                                <a asp-page="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                                @if (!item.CompletedDate.HasValue)
                                {
                                    <a asp-page="Complete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">Complete</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Inspections.TotalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Inspections.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-route-pageNumber="@(Model.Inspections.PageIndex - 1)"
                           asp-route-typeFilter="@Model.TypeFilter"
                           asp-route-unitId="@Model.UnitId"
                           asp-route-fromDate="@Model.FromDate"
                           asp-route-toDate="@Model.ToDate">
                            <span aria-hidden="true">&laquo;</span> Previous
                        </a>
                    </li>
                    @for (var i = 1; i <= Model.Inspections.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Inspections.PageIndex ? "active" : "")">
                            <a class="page-link"
                               asp-route-pageNumber="@i"
                               asp-route-typeFilter="@Model.TypeFilter"
                               asp-route-unitId="@Model.UnitId"
                               asp-route-fromDate="@Model.FromDate"
                               asp-route-toDate="@Model.ToDate">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Inspections.HasNextPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-route-pageNumber="@(Model.Inspections.PageIndex + 1)"
                           asp-route-typeFilter="@Model.TypeFilter"
                           asp-route-unitId="@Model.UnitId"
                           asp-route-fromDate="@Model.FromDate"
                           asp-route-toDate="@Model.ToDate">
                            Next <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                </ul>
            </nav>
            <p class="text-center text-muted small">
                Showing page @Model.Inspections.PageIndex of @Model.Inspections.TotalPages (@Model.Inspections.TotalCount total items)
            </p>
        }
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No inspections found. Use the button above to schedule one.
        </div>
    }
</section>
