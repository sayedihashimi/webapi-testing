@page "{id:int}"
@model KeystoneProperties.Pages.Properties.DeactivateModel
@{
    ViewData["Title"] = "Deactivate Property";
}

<section>
    <h1>Deactivate Property</h1>

    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i>
        <strong>Warning:</strong> Are you sure you want to deactivate this property? This action will mark the property as inactive.
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Property Details</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Property.Name</dd>

                <dt class="col-sm-3">Address</dt>
                <dd class="col-sm-9">@Model.Property.Address</dd>

                <dt class="col-sm-3">City / State</dt>
                <dd class="col-sm-9">@Model.Property.City, @Model.Property.State @Model.Property.ZipCode</dd>

                <dt class="col-sm-3">Type</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-info text-dark">@Model.Property.PropertyType</span>
                </dd>

                <dt class="col-sm-3">Total Units</dt>
                <dd class="col-sm-9">@Model.Property.TotalUnits</dd>

                <dt class="col-sm-3">Active</dt>
                <dd class="col-sm-9">
                    @if (Model.Property.IsActive)
                    {
                        <span class="text-success fw-bold">Yes</span>
                    }
                    else
                    {
                        <span class="text-danger fw-bold">No</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <form method="post" asp-route-id="@Model.Property.Id">
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-x-circle"></i> Confirm Deactivation
            </button>
            <a asp-page="Details" asp-route-id="@Model.Property.Id" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</section>
