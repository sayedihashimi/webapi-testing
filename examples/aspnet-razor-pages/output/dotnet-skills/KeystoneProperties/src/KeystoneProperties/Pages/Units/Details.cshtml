@page "{id:int}"
@model KeystoneProperties.Pages.Units.DetailsModel
@{
    ViewData["Title"] = $"Unit {Model.Unit.UnitNumber}";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-door-open"></i> Unit @Model.Unit.UnitNumber</h1>
        <div>
            <a asp-page="Edit" asp-route-id="@Model.Unit.Id" class="btn btn-warning">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-page="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <!-- Unit Info Card -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-info-circle"></i> Unit Information</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Unit Number</dt>
                        <dd class="col-sm-7">@Model.Unit.UnitNumber</dd>

                        <dt class="col-sm-5">Property</dt>
                        <dd class="col-sm-7">
                            <a asp-page="/Properties/Details" asp-route-id="@Model.Unit.PropertyId">
                                @Model.Unit.Property.Name
                            </a>
                        </dd>

                        <dt class="col-sm-5">Floor</dt>
                        <dd class="col-sm-7">@(Model.Unit.Floor?.ToString() ?? "—")</dd>

                        <dt class="col-sm-5">Bedrooms</dt>
                        <dd class="col-sm-7">@(Model.Unit.Bedrooms == 0 ? "Studio" : Model.Unit.Bedrooms.ToString())</dd>

                        <dt class="col-sm-5">Bathrooms</dt>
                        <dd class="col-sm-7">@Model.Unit.Bathrooms</dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Square Feet</dt>
                        <dd class="col-sm-7">@Model.Unit.SquareFeet.ToString("N0")</dd>

                        <dt class="col-sm-5">Monthly Rent</dt>
                        <dd class="col-sm-7">@Model.Unit.MonthlyRent.ToString("C")</dd>

                        <dt class="col-sm-5">Deposit Amount</dt>
                        <dd class="col-sm-7">@Model.Unit.DepositAmount.ToString("C")</dd>

                        <dt class="col-sm-5">Status</dt>
                        <dd class="col-sm-7">@await Html.PartialAsync("_StatusBadge", (Model.Unit.Status.ToString(), "UnitStatus"))</dd>

                        <dt class="col-sm-5">Amenities</dt>
                        <dd class="col-sm-7">@(Model.Unit.Amenities ?? "—")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <!-- Current Lease -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-file-earmark-text"></i> Current Lease</h5>
        </div>
        <div class="card-body">
            @if (Model.CurrentLease is not null)
            {
                <dl class="row mb-0">
                    <dt class="col-sm-3">Tenant</dt>
                    <dd class="col-sm-9">@Model.CurrentLease.Tenant.FullName</dd>

                    <dt class="col-sm-3">Lease Period</dt>
                    <dd class="col-sm-9">@Model.CurrentLease.StartDate.ToString("MMM d, yyyy") — @Model.CurrentLease.EndDate.ToString("MMM d, yyyy")</dd>

                    <dt class="col-sm-3">Monthly Rent</dt>
                    <dd class="col-sm-9">@Model.CurrentLease.MonthlyRentAmount.ToString("C")</dd>
                </dl>
            }
            else
            {
                <p class="text-muted mb-0">No active lease for this unit.</p>
            }
        </div>
    </div>

    <!-- Lease History -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-clock-history"></i> Lease History</h5>
        </div>
        <div class="card-body">
            @if (Model.Unit.Leases.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Tenant</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Monthly Rent</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lease in Model.Unit.Leases)
                            {
                                <tr>
                                    <td>@lease.Tenant.FullName</td>
                                    <td>@lease.StartDate.ToString("MMM d, yyyy")</td>
                                    <td>@lease.EndDate.ToString("MMM d, yyyy")</td>
                                    <td>@lease.MonthlyRentAmount.ToString("C")</td>
                                    <td>@await Html.PartialAsync("_StatusBadge", (lease.Status.ToString(), "LeaseStatus"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No lease history for this unit.</p>
            }
        </div>
    </div>

    <!-- Maintenance History -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-wrench"></i> Maintenance History</h5>
        </div>
        <div class="card-body">
            @if (Model.Unit.MaintenanceRequests.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Category</th>
                                <th>Priority</th>
                                <th>Submitted</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model.Unit.MaintenanceRequests)
                            {
                                <tr>
                                    <td>@request.Title</td>
                                    <td>@request.Category</td>
                                    <td>@await Html.PartialAsync("_StatusBadge", (request.Priority.ToString(), "MaintenancePriority"))</td>
                                    <td>@request.SubmittedDate.ToString("MMM d, yyyy")</td>
                                    <td>@await Html.PartialAsync("_StatusBadge", (request.Status.ToString(), "MaintenanceStatus"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No maintenance requests for this unit.</p>
            }
        </div>
    </div>

    <!-- Inspections -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-clipboard-check"></i> Inspections</h5>
        </div>
        <div class="card-body">
            @if (Model.Unit.Inspections.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Scheduled</th>
                                <th>Completed</th>
                                <th>Inspector</th>
                                <th>Condition</th>
                                <th>Follow-Up</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inspection in Model.Unit.Inspections)
                            {
                                <tr>
                                    <td>@inspection.InspectionType</td>
                                    <td>@inspection.ScheduledDate.ToString("MMM d, yyyy")</td>
                                    <td>@(inspection.CompletedDate?.ToString("MMM d, yyyy") ?? "—")</td>
                                    <td>@inspection.InspectorName</td>
                                    <td>
                                        @if (inspection.OverallCondition.HasValue)
                                        {
                                            @await Html.PartialAsync("_StatusBadge", (inspection.OverallCondition.Value.ToString(), "OverallCondition"))
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (inspection.FollowUpRequired)
                                        {
                                            <span class="badge bg-warning text-dark">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">No inspections for this unit.</p>
            }
        </div>
    </div>
</section>
