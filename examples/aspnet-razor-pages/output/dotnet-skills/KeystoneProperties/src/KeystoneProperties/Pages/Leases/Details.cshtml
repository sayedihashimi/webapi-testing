@page "{id:int}"
@model KeystoneProperties.Pages.Leases.DetailsModel
@{
    ViewData["Title"] = "Lease Details";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-file-earmark-text"></i> Lease Details</h1>
        <a asp-page="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Leases
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Lease Information</h5>
            @await Html.PartialAsync("_StatusBadge", (Model.Lease.Status.ToString(), "LeaseStatus"))
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-5">Tenant</dt>
                        <dd class="col-sm-7">@Model.Lease.Tenant.FullName</dd>

                        <dt class="col-sm-5">Property</dt>
                        <dd class="col-sm-7">@Model.Lease.Unit.Property.Name</dd>

                        <dt class="col-sm-5">Unit</dt>
                        <dd class="col-sm-7">@Model.Lease.Unit.UnitNumber</dd>

                        <dt class="col-sm-5">Start Date</dt>
                        <dd class="col-sm-7">@Model.Lease.StartDate.ToString("MMM dd, yyyy")</dd>

                        <dt class="col-sm-5">End Date</dt>
                        <dd class="col-sm-7">@Model.Lease.EndDate.ToString("MMM dd, yyyy")</dd>

                        <dt class="col-sm-5">Monthly Rent</dt>
                        <dd class="col-sm-7">@Model.Lease.MonthlyRentAmount.ToString("C")</dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <dl class="row">
                        <dt class="col-sm-5">Deposit Amount</dt>
                        <dd class="col-sm-7">@Model.Lease.DepositAmount.ToString("C")</dd>

                        <dt class="col-sm-5">Deposit Status</dt>
                        <dd class="col-sm-7">@await Html.PartialAsync("_StatusBadge", (Model.Lease.DepositStatus.ToString(), "DepositStatus"))</dd>

                        @if (Model.Lease.TerminationDate.HasValue)
                        {
                            <dt class="col-sm-5">Termination Date</dt>
                            <dd class="col-sm-7">@Model.Lease.TerminationDate.Value.ToString("MMM dd, yyyy")</dd>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Lease.TerminationReason))
                        {
                            <dt class="col-sm-5">Termination Reason</dt>
                            <dd class="col-sm-7">@Model.Lease.TerminationReason</dd>
                        }

                        <dt class="col-sm-5">Notes</dt>
                        <dd class="col-sm-7">@(Model.Lease.Notes ?? "—")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Lease.RenewalOfLeaseId.HasValue)
    {
        <div class="alert alert-info">
            <i class="bi bi-arrow-repeat"></i> This lease is a renewal of
            <a asp-page="Details" asp-route-id="@Model.Lease.RenewalOfLeaseId.Value">Lease #@Model.Lease.RenewalOfLeaseId.Value</a>.
        </div>
    }
    @if (Model.RenewalLease is not null)
    {
        <div class="alert alert-success">
            <i class="bi bi-arrow-repeat"></i> This lease was renewed as
            <a asp-page="Details" asp-route-id="@Model.RenewalLease.Id">Lease #@Model.RenewalLease.Id</a>.
        </div>
    }

    <div class="mb-4">
        @if (Model.Lease.Status == LeaseStatus.Active)
        {
            <a asp-page="Edit" asp-route-id="@Model.Lease.Id" class="btn btn-outline-primary me-2">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-page="Terminate" asp-route-id="@Model.Lease.Id" class="btn btn-outline-danger me-2">
                <i class="bi bi-x-circle"></i> Terminate
            </a>
            <a asp-page="Renew" asp-route-id="@Model.Lease.Id" class="btn btn-outline-success me-2">
                <i class="bi bi-arrow-repeat"></i> Renew
            </a>
        }
        @if (Model.Lease.Status == LeaseStatus.Pending)
        {
            <a asp-page="Edit" asp-route-id="@Model.Lease.Id" class="btn btn-outline-primary me-2">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <form method="post" asp-page-handler="Activate" asp-route-id="@Model.Lease.Id" class="d-inline">
                <button type="submit" class="btn btn-outline-success me-2">
                    <i class="bi bi-check-circle"></i> Activate
                </button>
            </form>
        }
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-credit-card"></i> Payment History</h5>
        </div>
        <div class="card-body">
            @if (Model.Lease.Payments.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Date</th>
                                <th>Due Date</th>
                                <th>Amount</th>
                                <th>Method</th>
                                <th>Status</th>
                                <th>Reference</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var payment in Model.Lease.Payments.OrderByDescending(p => p.PaymentDate))
                            {
                                <tr>
                                    <td>@payment.PaymentDate.ToString("MMM dd, yyyy")</td>
                                    <td>@payment.DueDate.ToString("MMM dd, yyyy")</td>
                                    <td>@payment.Amount.ToString("C")</td>
                                    <td>@payment.PaymentMethod</td>
                                    <td>@await Html.PartialAsync("_StatusBadge", (payment.Status.ToString(), "PaymentStatus"))</td>
                                    <td>@(payment.ReferenceNumber ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No payments recorded for this lease.</p>
            }
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-clipboard-check"></i> Linked Inspections</h5>
        </div>
        <div class="card-body">
            @if (Model.Lease.Inspections.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Type</th>
                                <th>Scheduled Date</th>
                                <th>Completed Date</th>
                                <th>Inspector</th>
                                <th>Condition</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inspection in Model.Lease.Inspections.OrderByDescending(i => i.ScheduledDate))
                            {
                                <tr>
                                    <td>@inspection.InspectionType</td>
                                    <td>@inspection.ScheduledDate.ToString("MMM dd, yyyy")</td>
                                    <td>@(inspection.CompletedDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                                    <td>@inspection.InspectorName</td>
                                    <td>
                                        @if (inspection.OverallCondition.HasValue)
                                        {
                                            @await Html.PartialAsync("_StatusBadge", (inspection.OverallCondition.Value.ToString(), "OverallCondition"))
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No inspections linked to this lease.</p>
            }
        </div>
    </div>
</section>
