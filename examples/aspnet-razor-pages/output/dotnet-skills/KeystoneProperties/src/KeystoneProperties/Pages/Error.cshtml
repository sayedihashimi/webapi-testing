@page "{code?}"
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<section class="text-center py-5">
    <h1 class="display-4 text-danger"><i class="bi bi-exclamation-triangle"></i> Oops!</h1>
    @if (Model.ErrorCode == 404)
    {
        <h2>Page Not Found</h2>
        <p class="lead text-muted">The page you are looking for does not exist.</p>
    }
    else
    {
        <h2>An error occurred while processing your request.</h2>
        <p class="lead text-muted">Please try again later or contact support.</p>
    }

    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a asp-page="/Index" class="btn btn-primary mt-3">
        <i class="bi bi-house"></i> Return to Dashboard
    </a>
</section>
