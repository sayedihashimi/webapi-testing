@page
@model KeystoneProperties.Pages.Maintenance.IndexModel
@{
    ViewData["Title"] = "Maintenance Requests";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-wrench"></i> Maintenance Requests</h1>
        <a asp-page="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> New Request
        </a>
    </div>

    <form method="get" class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<MaintenanceStatus>()" class="form-select">
                        <option value="">All Statuses</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Priority</label>
                    <select asp-for="Priority" asp-items="Html.GetEnumSelectList<MaintenancePriority>()" class="form-select">
                        <option value="">All Priorities</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Property</label>
                    <select asp-for="PropertyId" asp-items="Model.PropertyList" class="form-select">
                        <option value="">All Properties</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Category</label>
                    <select asp-for="Category" asp-items="Html.GetEnumSelectList<MaintenanceCategory>()" class="form-select">
                        <option value="">All Categories</option>
                    </select>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-funnel"></i> Filter
                </button>
                <a asp-page="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i> Clear
                </a>
            </div>
        </div>
    </form>

    @if (Model.Requests.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Unit</th>
                        <th>Tenant</th>
                        <th>Priority</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Submitted Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Requests)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.Unit.Property.Name - Unit @item.Unit.UnitNumber</td>
                            <td>@item.Tenant.FullName</td>
                            <td>
                                <partial name="_StatusBadge" model='(item.Priority.ToString(), "MaintenancePriority")' />
                            </td>
                            <td>@item.Category</td>
                            <td>
                                <partial name="_StatusBadge" model='(item.Status.ToString(), "MaintenanceStatus")' />
                            </td>
                            <td>@item.SubmittedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a asp-page="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Requests.TotalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Requests.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-route-pageNumber="@(Model.Requests.PageIndex - 1)"
                           asp-route-status="@Model.Status"
                           asp-route-priority="@Model.Priority"
                           asp-route-propertyId="@Model.PropertyId"
                           asp-route-category="@Model.Category">
                            <span aria-hidden="true">&laquo;</span> Previous
                        </a>
                    </li>
                    @for (var i = 1; i <= Model.Requests.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Requests.PageIndex ? "active" : "")">
                            <a class="page-link"
                               asp-route-pageNumber="@i"
                               asp-route-status="@Model.Status"
                               asp-route-priority="@Model.Priority"
                               asp-route-propertyId="@Model.PropertyId"
                               asp-route-category="@Model.Category">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Requests.HasNextPage ? "" : "disabled")">
                        <a class="page-link"
                           asp-route-pageNumber="@(Model.Requests.PageIndex + 1)"
                           asp-route-status="@Model.Status"
                           asp-route-priority="@Model.Priority"
                           asp-route-propertyId="@Model.PropertyId"
                           asp-route-category="@Model.Category">
                            Next <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                </ul>
            </nav>
            <p class="text-center text-muted small">
                Showing page @Model.Requests.PageIndex of @Model.Requests.TotalPages (@Model.Requests.TotalCount total items)
            </p>
        }
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No maintenance requests found matching the selected filters.
        </div>
    }
</section>
