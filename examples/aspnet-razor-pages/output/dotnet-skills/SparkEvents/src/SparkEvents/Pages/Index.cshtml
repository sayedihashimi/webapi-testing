@page "/"
@model SparkEvents.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<section>
    <h1 class="mb-4">⚡ Spark Events Dashboard</h1>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Events</h5>
                    <p class="card-text display-6">@Model.TotalEvents</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Registrations</h5>
                    <p class="card-text display-6">@Model.TotalRegistrations</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info mb-3">
                <div class="card-body">
                    <h5 class="card-title">Events This Month</h5>
                    <p class="card-text display-6">@Model.EventsThisMonth</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-dark bg-warning mb-3">
                <div class="card-body">
                    <h5 class="card-title">Today's Events</h5>
                    <p class="card-text display-6">@Model.TodaysEvents.Count</p>
                </div>
            </div>
        </div>
    </div>
</section>

@if (Model.TodaysEvents.Any())
{
    <section class="mb-4">
        <h3>Today's Events</h3>
        <div class="row">
            @foreach (var evt in Model.TodaysEvents)
            {
                <div class="col-md-6 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">@evt.Title</h5>
                            <p class="card-text text-muted">@evt.Venue.Name · @evt.StartDate.ToString("h:mm tt") - @evt.EndDate.ToString("h:mm tt")</p>
                            <div class="mb-2">
                                <span class="text-muted">Check-in Progress</span>
                                @{
                                    var pct = evt.CurrentRegistrations > 0 ? (int)((double)evt.Registrations.Count(r => r.Status == SparkEvents.Models.RegistrationStatus.CheckedIn) / evt.CurrentRegistrations * 100) : 0;
                                }
                                <div class="progress">
                                    <div class="progress-bar bg-success" role="progressbar" style="width: @pct%" aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">@pct%</div>
                                </div>
                            </div>
                            <a asp-page="/Events/Details" asp-route-id="@evt.Id" class="btn btn-sm btn-outline-primary">View</a>
                            <a asp-page="/CheckIn/Index" asp-route-eventId="@evt.Id" class="btn btn-sm btn-primary">Check-In</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

<section class="mb-4">
    <h3>Upcoming Events (Next 7 Days)</h3>
    @if (Model.UpcomingEvents.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Event</th>
                        <th>Date</th>
                        <th>Venue</th>
                        <th>Status</th>
                        <th>Registrations</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in Model.UpcomingEvents)
                    {
                        <tr>
                            <td><a asp-page="/Events/Details" asp-route-id="@evt.Id">@evt.Title</a></td>
                            <td>@evt.StartDate.ToString("MMM dd, yyyy h:mm tt")</td>
                            <td>@evt.Venue.Name</td>
                            <td><partial name="_EventStatusBadge" model="evt.Status" /></td>
                            <td>@evt.CurrentRegistrations / @evt.TotalCapacity</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No upcoming events in the next 7 days.</p>
    }
</section>

<section>
    <h3>Recent Registrations</h3>
    @if (Model.RecentRegistrations.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Confirmation #</th>
                        <th>Attendee</th>
                        <th>Event</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in Model.RecentRegistrations)
                    {
                        <tr>
                            <td><a asp-page="/Registrations/Details" asp-route-id="@reg.Id">@reg.ConfirmationNumber</a></td>
                            <td>@reg.Attendee.FullName</td>
                            <td>@reg.Event.Title</td>
                            <td><partial name="_RegistrationStatusBadge" model="reg.Status" /></td>
                            <td>@reg.RegistrationDate.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">No registrations yet.</p>
    }
</section>
