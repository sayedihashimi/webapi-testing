@page
@using KeystoneProperties.Models
@model KeystoneProperties.Pages.Payments.IndexModel
@{
    ViewData["Title"] = "Payments";
}

<h1>Payments</h1>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["LateFeeMessage"] is string lateFeeMessage)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <strong>Late Fee Generated:</strong> @lateFeeMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2">
                <label class="form-label">Type</label>
                <select asp-for="PaymentType" asp-items="Html.GetEnumSelectList<PaymentType>()" class="form-select">
                    <option value="">All Types</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select asp-for="PaymentStatus" asp-items="Html.GetEnumSelectList<PaymentStatus>()" class="form-select">
                    <option value="">All Statuses</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Start Date</label>
                <input asp-for="StartDate" type="date" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">End Date</label>
                <input asp-for="EndDate" type="date" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Property</label>
                <select asp-for="PropertyId" class="form-select">
                    <option value="">All Properties</option>
                    @foreach (var property in Model.AllProperties)
                    {
                        <option value="@property.Id">@property.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary">Search</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </div>
    </div>
</form>

<div class="d-flex justify-content-between mb-3">
    <div class="d-flex gap-2">
        <a asp-page="Create" class="btn btn-success">Record Payment</a>
        <a asp-page="Overdue" class="btn btn-warning">View Overdue</a>
    </div>
</div>

@if (Model.Payments.Count == 0)
{
    <div class="alert alert-info">No payments found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Due Date</th>
                    <th>Tenant</th>
                    <th>Unit</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>Method</th>
                    <th>Status</th>
                    <th>Reference #</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model.Payments)
                {
                    <tr>
                        <td>@payment.PaymentDate.ToString("MMM dd, yyyy")</td>
                        <td>@payment.DueDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            <a asp-page="/Tenants/Details" asp-route-id="@payment.Lease.TenantId">
                                @payment.Lease.Tenant.FullName
                            </a>
                        </td>
                        <td>@payment.Lease.Unit.UnitNumber</td>
                        <td>@await Component.InvokeAsync("StatusBadge", new { status = payment.PaymentType.ToString() })</td>
                        <td class="@(payment.PaymentType == PaymentType.DepositReturn ? "text-danger fw-bold" : "")">
                            @payment.Amount.ToString("C")
                        </td>
                        <td>@payment.PaymentMethod</td>
                        <td>@await Component.InvokeAsync("StatusBadge", new { status = payment.Status.ToString() })</td>
                        <td>@(payment.ReferenceNumber ?? "—")</td>
                        <td>
                            <a asp-page="Details" asp-route-id="@payment.Id" class="btn btn-sm btn-outline-primary">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_PaginationPartial" />
}
