@page
@model KeystoneProperties.Pages.Payments.OverdueModel
@{
    ViewData["Title"] = "Overdue Payments";
}

<h1>Overdue Payments</h1>

<div class="mb-3">
    <a asp-page="Index" class="text-decoration-none">&larr; Back to Payments</a>
</div>

@if (Model.OverduePayments.Count == 0)
{
    <div class="alert alert-success">
        <strong>No overdue payments!</strong> All rent is up to date.
    </div>
}
else
{
    var totalOverdue = Model.OverduePayments.Sum(o => o.AmountDue);

    <div class="alert alert-danger">
        <strong>@Model.OverduePayments.Count overdue payment(s)</strong> totaling @totalOverdue.ToString("C")
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Tenant</th>
                    <th>Unit</th>
                    <th>Due Date</th>
                    <th>Days Overdue</th>
                    <th>Amount Due</th>
                    <th>Estimated Late Fee</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OverduePayments)
                {
                    var estimatedLateFee = item.DaysOverdue > 5
                        ? Math.Min(50m + 5m * (item.DaysOverdue - 5), 200m)
                        : (decimal?)null;

                    <tr>
                        <td>
                            <a asp-page="/Tenants/Details" asp-route-id="@item.Lease.TenantId">
                                @item.Lease.Tenant.FullName
                            </a>
                        </td>
                        <td>
                            Unit @item.Lease.Unit.UnitNumber at @item.Lease.Unit.Property.Name
                        </td>
                        <td>@item.DueDate.ToString("MMM dd, yyyy")</td>
                        <td class="text-danger fw-bold">@item.DaysOverdue days</td>
                        <td>@item.AmountDue.ToString("C")</td>
                        <td>
                            @if (estimatedLateFee.HasValue)
                            {
                                <span class="text-danger">@estimatedLateFee.Value.ToString("C")</span>
                            }
                            else
                            {
                                <span class="text-muted">N/A</span>
                            }
                        </td>
                        <td>
                            <a asp-page="Create" asp-route-leaseId="@item.Lease.Id" class="btn btn-sm btn-primary">
                                Record Payment
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
