@page
@using KeystoneProperties.Models
@model KeystoneProperties.Pages.Payments.CreateModel
@{
    ViewData["Title"] = "Record Payment";
}

<h1>Record Payment</h1>

<div class="mb-3">
    <a asp-page="Index" class="text-decoration-none">&larr; Back to Payments</a>
</div>

<div class="row">
    <div class="col-md-8">
        <div asp-validation-summary="All" class="text-danger"></div>

        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.LeaseId" class="form-label"></label>
                <select asp-for="Input.LeaseId" asp-items="Model.LeaseSelectList" class="form-select">
                    <option value="">-- Select a Lease --</option>
                </select>
                <span asp-validation-for="Input.LeaseId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.PaymentType" class="form-label"></label>
                <select asp-for="Input.PaymentType" asp-items="Html.GetEnumSelectList<PaymentType>()" class="form-select"></select>
                <span asp-validation-for="Input.PaymentType" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Amount" class="form-label"></label>
                <input asp-for="Input.Amount" type="number" step="0.01" min="0.01" class="form-control" />
                <span asp-validation-for="Input.Amount" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.PaymentDate" class="form-label"></label>
                    <input asp-for="Input.PaymentDate" type="date" class="form-control" />
                    <span asp-validation-for="Input.PaymentDate" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.DueDate" class="form-label"></label>
                    <input asp-for="Input.DueDate" type="date" class="form-control" />
                    <span asp-validation-for="Input.DueDate" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.PaymentMethod" class="form-label"></label>
                <select asp-for="Input.PaymentMethod" asp-items="Html.GetEnumSelectList<PaymentMethod>()" class="form-select"></select>
                <span asp-validation-for="Input.PaymentMethod" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.ReferenceNumber" class="form-label"></label>
                <input asp-for="Input.ReferenceNumber" class="form-control" />
                <span asp-validation-for="Input.ReferenceNumber" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Notes" class="form-label"></label>
                <textarea asp-for="Input.Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Notes" class="text-danger"></span>
            </div>

            <div class="alert alert-info">
                <strong>Late Fee Policy:</strong> Late fees are automatically calculated for rent payments made more than 5 days after the due date. Fee: $50 base + $5/day (max $200).
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Record Payment</button>
                <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
