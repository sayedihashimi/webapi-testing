@page "{id:int}"
@using KeystoneProperties.Models
@model KeystoneProperties.Pages.Payments.DetailsModel
@{
    ViewData["Title"] = "Payment Details";
    var isNegative = Model.Payment.Amount < 0 || Model.Payment.PaymentType == PaymentType.DepositReturn;
    var daysLate = Model.Payment.PaymentDate.DayNumber - Model.Payment.DueDate.DayNumber;
}

<h1>Payment Details</h1>

<div class="mb-3">
    <a asp-page="Index" class="text-decoration-none">&larr; Back to Payments</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Payment Information</h5>
            </div>
            <div class="card-body">
                <div class="text-center mb-4">
                    <h2 class="@(isNegative ? "text-danger" : "text-success")">
                        @Model.Payment.Amount.ToString("C")
                    </h2>
                    <div class="d-flex justify-content-center gap-2">
                        @await Component.InvokeAsync("StatusBadge", new { status = Model.Payment.PaymentType.ToString() })
                        @await Component.InvokeAsync("StatusBadge", new { status = Model.Payment.Status.ToString() })
                    </div>
                </div>

                <dl class="row mb-0">
                    <dt class="col-sm-5">Payment Date</dt>
                    <dd class="col-sm-7">@Model.Payment.PaymentDate.ToString("MMMM dd, yyyy")</dd>

                    <dt class="col-sm-5">Due Date</dt>
                    <dd class="col-sm-7">@Model.Payment.DueDate.ToString("MMMM dd, yyyy")</dd>

                    <dt class="col-sm-5">Payment Method</dt>
                    <dd class="col-sm-7">@Model.Payment.PaymentMethod</dd>

                    @if (!string.IsNullOrWhiteSpace(Model.Payment.ReferenceNumber))
                    {
                        <dt class="col-sm-5">Reference Number</dt>
                        <dd class="col-sm-7">@Model.Payment.ReferenceNumber</dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.Payment.Notes))
                    {
                        <dt class="col-sm-5">Notes</dt>
                        <dd class="col-sm-7">@Model.Payment.Notes</dd>
                    }

                    <dt class="col-sm-5">Created</dt>
                    <dd class="col-sm-7">@Model.Payment.CreatedAt.ToString("MMMM dd, yyyy h:mm tt")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Lease Information</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Tenant</dt>
                    <dd class="col-sm-7">
                        <a asp-page="/Tenants/Details" asp-route-id="@Model.Payment.Lease.TenantId">
                            @Model.Payment.Lease.Tenant.FullName
                        </a>
                    </dd>

                    <dt class="col-sm-5">Unit</dt>
                    <dd class="col-sm-7">
                        <a asp-page="/Units/Details" asp-route-id="@Model.Payment.Lease.UnitId">
                            Unit @Model.Payment.Lease.Unit.UnitNumber
                        </a>
                        at @Model.Payment.Lease.Unit.Property.Name
                    </dd>

                    <dt class="col-sm-5">Lease Period</dt>
                    <dd class="col-sm-7">
                        @Model.Payment.Lease.StartDate.ToString("MMM dd, yyyy") &ndash; @Model.Payment.Lease.EndDate.ToString("MMM dd, yyyy")
                    </dd>

                    <dt class="col-sm-5">Monthly Rent</dt>
                    <dd class="col-sm-7">@Model.Payment.Lease.MonthlyRentAmount.ToString("C")</dd>
                </dl>

                @if (Model.Payment.PaymentType == PaymentType.LateFee && daysLate > 0)
                {
                    <hr />
                    <div class="alert alert-warning mb-0">
                        <strong>Days Late:</strong> @daysLate days
                    </div>
                }
            </div>
        </div>
    </div>
</div>
