@page "{id:int}"
@model KeystoneProperties.Pages.Leases.RenewModel
@{
    ViewData["Title"] = "Renew Lease";
}

<h1>Renew Lease</h1>

<div class="mb-3">
    <a asp-page="Details" asp-route-id="@Model.OriginalLease.Id" class="btn btn-outline-secondary">&larr; Back to Lease Details</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Current Lease Information</h5>
        <dl class="row mb-0">
            <dt class="col-sm-3">Tenant</dt>
            <dd class="col-sm-9">@Model.OriginalLease.Tenant.FullName</dd>
            <dt class="col-sm-3">Unit</dt>
            <dd class="col-sm-9">@Model.OriginalLease.Unit.UnitNumber - @Model.OriginalLease.Unit.Property.Name</dd>
            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.OriginalLease.StartDate.ToString("MMM dd, yyyy")</dd>
            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.OriginalLease.EndDate.ToString("MMM dd, yyyy")</dd>
            <dt class="col-sm-3">Monthly Rent</dt>
            <dd class="col-sm-9">@Model.OriginalLease.MonthlyRentAmount.ToString("C")</dd>
        </dl>
    </div>
</div>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<h4>New Lease Details</h4>

<form method="post" class="row g-3">
    <div class="col-md-4">
        <label class="form-label">New Start Date</label>
        <input type="date" class="form-control" value="@Model.OriginalLease.EndDate.AddDays(1).ToString("yyyy-MM-dd")" disabled />
        <div class="form-text">Automatically set to one day after the current lease ends.</div>
    </div>
    <div class="col-md-4">
        <label asp-for="Input.NewEndDate" class="form-label"></label>
        <input asp-for="Input.NewEndDate" class="form-control" type="date" />
        <span asp-validation-for="Input.NewEndDate" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Input.NewMonthlyRent" class="form-label"></label>
        <input asp-for="Input.NewMonthlyRent" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Input.NewMonthlyRent" class="text-danger"></span>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-success">Renew Lease</button>
        <a asp-page="Details" asp-route-id="@Model.OriginalLease.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
