@page "{id:int}"
@model KeystoneProperties.Pages.Leases.TerminateModel
@{
    ViewData["Title"] = "Terminate Lease";
}

<h1>Terminate Lease</h1>

<div class="mb-3">
    <a asp-page="Details" asp-route-id="@Model.Lease.Id" class="btn btn-outline-secondary">&larr; Back to Lease Details</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Lease Summary</h5>
        <dl class="row mb-0">
            <dt class="col-sm-3">Tenant</dt>
            <dd class="col-sm-9">@Model.Lease.Tenant.FullName</dd>
            <dt class="col-sm-3">Unit</dt>
            <dd class="col-sm-9">@Model.Lease.Unit.UnitNumber - @Model.Lease.Unit.Property.Name</dd>
            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.Lease.StartDate.ToString("MMM dd, yyyy")</dd>
            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.Lease.EndDate.ToString("MMM dd, yyyy")</dd>
            <dt class="col-sm-3">Monthly Rent</dt>
            <dd class="col-sm-9">@Model.Lease.MonthlyRentAmount.ToString("C")</dd>
            <dt class="col-sm-3">Deposit Amount</dt>
            <dd class="col-sm-9">@Model.Lease.DepositAmount.ToString("C")</dd>
        </dl>
    </div>
</div>

<div class="alert alert-warning">
    <strong>Warning:</strong> This action cannot be undone. The lease will be permanently terminated.
</div>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<form method="post" class="row g-3">
    <div class="col-12">
        <label asp-for="Input.TerminationReason" class="form-label"></label>
        <textarea asp-for="Input.TerminationReason" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Input.TerminationReason" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Input.DepositDisposition" class="form-label"></label>
        <select asp-for="Input.DepositDisposition" class="form-select">
            <option value="">-- Select --</option>
            <option value="@DepositStatus.Returned">Returned</option>
            <option value="@DepositStatus.PartiallyReturned">Partially Returned</option>
            <option value="@DepositStatus.Forfeited">Forfeited</option>
        </select>
        <span asp-validation-for="Input.DepositDisposition" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Input.DepositReturnAmount" class="form-label"></label>
        <input asp-for="Input.DepositReturnAmount" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Input.DepositReturnAmount" class="text-danger"></span>
        <div class="form-text">Original deposit: @Model.Lease.DepositAmount.ToString("C"). Required for partial returns.</div>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-danger">Terminate Lease</button>
        <a asp-page="Details" asp-route-id="@Model.Lease.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
