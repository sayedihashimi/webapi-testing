@page
@model SparkEvents.Pages.Attendees.IndexModel
@{
    ViewData["Title"] = "Attendees";
}

<section>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Attendees</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Attendees</h1>
        <a asp-page="Create" class="btn btn-primary">Create New Attendee</a>
    </div>

    <form method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="search" value="@Model.Search" class="form-control"
                   placeholder="Search by name or email..." />
            <button type="submit" class="btn btn-outline-secondary">Search</button>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a asp-page="Index" class="btn btn-outline-danger">Clear</a>
            }
        </div>
    </form>

    @if (Model.Attendees.Count == 0)
    {
        <p class="text-muted">No attendees found.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Organization</th>
                    <th># Registrations</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var attendee in Model.Attendees)
                {
                    <tr>
                        <td>@attendee.FullName</td>
                        <td>@attendee.Email</td>
                        <td>@attendee.Organization</td>
                        <td>@attendee.Registrations.Count</td>
                        <td>
                            <a asp-page="Details" asp-route-id="@attendee.Id"
                               class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-page="Edit" asp-route-id="@attendee.Id"
                               class="btn btn-sm btn-outline-primary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <partial name="_Pagination" model="Model.Pagination" />
    }
</section>
