@page "{id:int}"
@model SparkEvents.Pages.Venues.DeleteModel
@{
    ViewData["Title"] = "Delete Venue";
}

<section>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="Index">Venues</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>

    <h1>Delete Venue</h1>

    @if (Model.HasFutureEvents)
    {
        <div class="alert alert-danger" role="alert">
            This venue cannot be deleted because it has future events scheduled. Please cancel or reassign those events first.
        </div>
    }

    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.Venue!.Name</h5>

            <dl class="row mb-0">
                <dt class="col-sm-3">Address</dt>
                <dd class="col-sm-9">@Model.Venue.Address</dd>

                <dt class="col-sm-3">City</dt>
                <dd class="col-sm-9">@Model.Venue.City</dd>

                <dt class="col-sm-3">State</dt>
                <dd class="col-sm-9">@Model.Venue.State</dd>

                <dt class="col-sm-3">Zip Code</dt>
                <dd class="col-sm-9">@Model.Venue.ZipCode</dd>

                <dt class="col-sm-3">Max Capacity</dt>
                <dd class="col-sm-9">@Model.Venue.MaxCapacity.ToString("N0")</dd>
            </dl>
        </div>
    </div>

    <form method="post" class="mt-3">
        <button type="submit" class="btn btn-danger" disabled="@Model.HasFutureEvents">Delete</button>
        <a asp-page="Index" class="btn btn-secondary">Cancel</a>
    </form>
</section>
