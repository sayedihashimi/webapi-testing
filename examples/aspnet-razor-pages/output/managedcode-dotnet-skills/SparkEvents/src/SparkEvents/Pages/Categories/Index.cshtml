@page
@model SparkEvents.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
}

<section>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Categories</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Categories</h1>
        <a asp-page="Create" class="btn btn-primary">Create New Category</a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Categories.Count == 0)
    {
        <p class="text-muted">No categories found.</p>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Color</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model.Categories)
                {
                    <tr>
                        <td>@category.Name</td>
                        <td>@category.Description</td>
                        <td>
                            @if (!string.IsNullOrEmpty(category.ColorHex))
                            {
                                <span class="badge" style="background-color: @category.ColorHex;">&nbsp;&nbsp;&nbsp;</span>
                                <span class="ms-1 text-muted small">@category.ColorHex</span>
                            }
                        </td>
                        <td>
                            <a asp-page="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-page="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>
