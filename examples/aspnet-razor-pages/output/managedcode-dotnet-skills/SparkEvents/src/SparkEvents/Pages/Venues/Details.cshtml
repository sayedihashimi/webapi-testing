@page "{id:int}"
@model SparkEvents.Pages.Venues.DetailsModel
@{
    ViewData["Title"] = Model.Venue!.Name;
}

<section>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="Index">Venues</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Venue.Name</li>
        </ol>
    </nav>

    <h1>@Model.Venue.Name</h1>

    <div class="card mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Address</dt>
                <dd class="col-sm-9">@Model.Venue.Address</dd>

                <dt class="col-sm-3">City</dt>
                <dd class="col-sm-9">@Model.Venue.City</dd>

                <dt class="col-sm-3">State</dt>
                <dd class="col-sm-9">@Model.Venue.State</dd>

                <dt class="col-sm-3">Zip Code</dt>
                <dd class="col-sm-9">@Model.Venue.ZipCode</dd>

                <dt class="col-sm-3">Max Capacity</dt>
                <dd class="col-sm-9">@Model.Venue.MaxCapacity.ToString("N0")</dd>

                @if (!string.IsNullOrEmpty(Model.Venue.ContactEmail))
                {
                    <dt class="col-sm-3">Contact Email</dt>
                    <dd class="col-sm-9">@Model.Venue.ContactEmail</dd>
                }

                @if (!string.IsNullOrEmpty(Model.Venue.ContactPhone))
                {
                    <dt class="col-sm-3">Contact Phone</dt>
                    <dd class="col-sm-9">@Model.Venue.ContactPhone</dd>
                }

                @if (!string.IsNullOrEmpty(Model.Venue.Notes))
                {
                    <dt class="col-sm-3">Notes</dt>
                    <dd class="col-sm-9">@Model.Venue.Notes</dd>
                }
            </dl>
        </div>
    </div>

    <h2>Upcoming Events</h2>

    @if (Model.UpcomingEvents.Count == 0)
    {
        <p class="text-muted">No upcoming events at this venue.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evt in Model.UpcomingEvents)
                {
                    <tr>
                        <td>@evt.Title</td>
                        <td>@evt.StartDate.ToString("g")</td>
                        <td>@evt.EndDate.ToString("g")</td>
                        <td>
                            <partial name="_StatusBadge" model="@evt.Status.ToString()" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <a asp-page="Edit" asp-route-id="@Model.Venue.Id" class="btn btn-primary">Edit</a>
        <a asp-page="Index" class="btn btn-secondary">Back to List</a>
    </div>
</section>
