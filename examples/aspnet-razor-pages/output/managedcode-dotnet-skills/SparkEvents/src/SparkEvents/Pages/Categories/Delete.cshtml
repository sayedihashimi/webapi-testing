@page "{id:int}"
@model SparkEvents.Pages.Categories.DeleteModel
@{
    ViewData["Title"] = "Delete Category";
}

<section>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="Index">Categories</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>

    <h1>Delete Category</h1>

    @if (Model.HasEvents)
    {
        <div class="alert alert-danger" role="alert">
            This category cannot be deleted because it has associated events. Please reassign or remove those events first.
        </div>
    }

    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.Category!.Name</h5>

            @if (!string.IsNullOrEmpty(Model.Category.Description))
            {
                <p class="card-text">@Model.Category.Description</p>
            }

            @if (!string.IsNullOrEmpty(Model.Category.ColorHex))
            {
                <p>
                    <strong>Color:</strong>
                    <span class="badge" style="background-color: @Model.Category.ColorHex;">&nbsp;&nbsp;&nbsp;</span>
                    <span class="ms-1 text-muted small">@Model.Category.ColorHex</span>
                </p>
            }
        </div>
    </div>

    <form method="post" class="mt-3">
        <button type="submit" class="btn btn-danger" disabled="@Model.HasEvents">Delete</button>
        <a asp-page="Index" class="btn btn-secondary">Cancel</a>
    </form>
</section>
