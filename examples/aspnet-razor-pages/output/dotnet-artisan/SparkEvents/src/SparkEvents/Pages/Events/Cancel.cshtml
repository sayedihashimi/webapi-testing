@page "{id:int}"
@model SparkEvents.Pages.Events.CancelModel
@{
    ViewData["Title"] = "Cancel Event";
}

<h1 class="mb-4 text-danger">Cancel Event</h1>

<div class="alert alert-warning">
    <h5 class="alert-heading">Are you sure you want to cancel this event?</h5>
    <p class="mb-0">This action cannot be undone.</p>
</div>

<div class="card mb-4">
    <div class="card-header"><h5 class="mb-0">Event Details</h5></div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Title</dt>
            <dd class="col-sm-8">@Model.Event.Title</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8"><partial name="_StatusBadge" model="Model.Event.Status" /></dd>

            <dt class="col-sm-4">Date</dt>
            <dd class="col-sm-8">@Model.Event.StartDate.ToString("MMMM dd, yyyy h:mm tt") — @Model.Event.EndDate.ToString("MMMM dd, yyyy h:mm tt")</dd>

            <dt class="col-sm-4">Venue</dt>
            <dd class="col-sm-8">@Model.Event.Venue.Name</dd>

            <dt class="col-sm-4">Current Registrations</dt>
            <dd class="col-sm-8">@Model.Event.CurrentRegistrations</dd>
        </dl>
    </div>
</div>

@if (Model.ActiveRegistrationCount > 0)
{
    <div class="alert alert-danger">
        <strong>@Model.ActiveRegistrationCount</strong> active registration(s) will be cancelled.
    </div>
}

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Input.Id" />

    <div class="mb-3">
        <label asp-for="Input.CancellationReason" class="form-label"></label>
        <textarea asp-for="Input.CancellationReason" class="form-control" rows="3" placeholder="Explain why this event is being cancelled..."></textarea>
        <span asp-validation-for="Input.CancellationReason" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Confirm Cancellation</button>
        <a asp-page="Details" asp-route-id="@Model.Event.Id" class="btn btn-outline-secondary">Go Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
