@page "/Events/{eventId:int}/Roster"
@model SparkEvents.Pages.Events.RosterModel

@{
    ViewData["Title"] = $"Roster — {Model.Event.Title}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Event Roster</h1>
        <h5 class="text-muted">@Model.Event.Title</h5>
    </div>
    <div>
        <a asp-page="/Events/Register" asp-route-eventId="@Model.Event.Id" class="btn btn-primary">Register Attendee</a>
    </div>
</div>

<form method="get" class="mb-3" asp-route-eventId="@Model.Event.Id">
    <div class="input-group" style="max-width: 400px;">
        <input type="text" name="Search" value="@Model.Search" class="form-control"
               placeholder="Search by name or email..." />
        <button type="submit" class="btn btn-outline-secondary">Search</button>
        @if (!string.IsNullOrWhiteSpace(Model.Search))
        {
            <a asp-page="Roster" asp-route-eventId="@Model.Event.Id" class="btn btn-outline-danger">Clear</a>
        }
    </div>
</form>

@if (Model.Registrations.Items.Count == 0)
{
    <div class="alert alert-info">No registrations found.</div>
}
else
{
    <p class="text-muted">Showing @Model.Registrations.Items.Count of @Model.Registrations.TotalCount registrations</p>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Ticket Type</th>
                    <th>Confirmation #</th>
                    <th>Status</th>
                    <th>Check-In</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in Model.Registrations.Items)
                {
                    <tr>
                        <td>@reg.Attendee.FullName</td>
                        <td>@reg.Attendee.Email</td>
                        <td>@reg.TicketType.Name</td>
                        <td>
                            <a asp-page="/Registrations/Details" asp-route-id="@reg.Id">
                                @reg.ConfirmationNumber
                            </a>
                        </td>
                        <td>
                            <partial name="_RegistrationStatusBadge" model="reg.Status" />
                        </td>
                        <td>
                            @if (reg.CheckInTime.HasValue)
                            {
                                <span class="text-success">✓ @reg.CheckInTime.Value.ToString("h:mm tt")</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Registrations.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Registrations.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="?pageNumber=@(Model.Registrations.PageNumber - 1)&Search=@Model.Search">Previous</a>
                </li>
                @for (var i = 1; i <= Model.Registrations.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Registrations.PageNumber ? "active" : "")">
                        <a class="page-link" href="?pageNumber=@i&Search=@Model.Search">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Registrations.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="?pageNumber=@(Model.Registrations.PageNumber + 1)&Search=@Model.Search">Next</a>
                </li>
            </ul>
        </nav>
    }
}
