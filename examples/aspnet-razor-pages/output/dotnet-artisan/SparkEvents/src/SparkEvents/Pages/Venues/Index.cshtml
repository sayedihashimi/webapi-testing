@page
@model SparkEvents.Pages.Venues.IndexModel

@{
    ViewData["Title"] = "Venues";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Venues</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Venue
    </a>
</div>

@if (Model.Venues.Count == 0)
{
    <div class="alert alert-info">No venues found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>City / State</th>
                <th>Max Capacity</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var venue in Model.Venues)
            {
                <tr>
                    <td>
                        <a asp-page="Details" asp-route-id="@venue.Id">@venue.Name</a>
                    </td>
                    <td>@venue.City, @venue.State</td>
                    <td>@venue.MaxCapacity.ToString("N0")</td>
                    <td class="text-end">
                        <a asp-page="Edit" asp-route-id="@venue.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-page="Delete" asp-route-id="@venue.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
