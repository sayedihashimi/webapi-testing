@page "/Events/{eventId:int}/Waitlist"
@model SparkEvents.Pages.Events.WaitlistModel

@{
    ViewData["Title"] = $"Waitlist — {Model.Event.Title}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Waitlist</h1>
        <h5 class="text-muted">@Model.Event.Title</h5>
    </div>
    <a asp-page="Roster" asp-route-eventId="@Model.Event.Id" class="btn btn-outline-primary">Back to Roster</a>
</div>

@if (Model.WaitlistedRegistrations.Count == 0)
{
    <div class="alert alert-info">No one is on the waitlist for this event.</div>
}
else
{
    <p class="text-muted">@Model.WaitlistedRegistrations.Count attendee(s) on the waitlist</p>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Position</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Ticket Type</th>
                    <th>Registration Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in Model.WaitlistedRegistrations)
                {
                    <tr>
                        <td>
                            <span class="badge bg-warning text-dark">#@reg.WaitlistPosition</span>
                        </td>
                        <td>
                            <a asp-page="/Registrations/Details" asp-route-id="@reg.Id">
                                @reg.Attendee.FullName
                            </a>
                        </td>
                        <td>@reg.Attendee.Email</td>
                        <td>@reg.TicketType.Name</td>
                        <td>@reg.RegistrationDate.ToString("MMM dd, yyyy h:mm tt")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
