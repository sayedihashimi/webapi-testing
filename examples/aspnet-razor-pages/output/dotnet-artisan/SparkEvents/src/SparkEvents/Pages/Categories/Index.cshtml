@page
@model SparkEvents.Pages.Categories.IndexModel

@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Categories</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Category
    </a>
</div>

@if (Model.Categories.Count == 0)
{
    <div class="alert alert-info">No categories found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Color</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model.Categories)
            {
                <tr>
                    <td>@category.Name</td>
                    <td>@(category.Description ?? "—")</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(category.ColorHex))
                        {
                            <span class="badge" style="background-color: @category.ColorHex;">
                                @category.ColorHex
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-page="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-page="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
