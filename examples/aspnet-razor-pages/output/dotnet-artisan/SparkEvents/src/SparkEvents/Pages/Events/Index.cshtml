@page
@model SparkEvents.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Events";
    var queryString = $"search={Model.Search}&categoryId={Model.CategoryId}&status={Model.Status}&fromDate={Model.FromDate:yyyy-MM-dd}&toDate={Model.ToDate:yyyy-MM-dd}&pageSize={Model.PageSize}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Events</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Create Event
    </a>
</div>

<form method="get" class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label for="Search" class="form-label">Search</label>
                <input type="text" class="form-control" asp-for="Search" placeholder="Search by title..." />
            </div>
            <div class="col-md-2">
                <label for="CategoryId" class="form-label">Category</label>
                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                    <option value="">All Categories</option>
                </select>
            </div>
            <div class="col-md-2">
                <label for="Status" class="form-label">Status</label>
                <select asp-for="Status" asp-items="Model.Statuses" class="form-select">
                    <option value="">All Statuses</option>
                </select>
            </div>
            <div class="col-md-2">
                <label for="FromDate" class="form-label">From</label>
                <input type="date" class="form-control" asp-for="FromDate" />
            </div>
            <div class="col-md-2">
                <label for="ToDate" class="form-label">To</label>
                <input type="date" class="form-control" asp-for="ToDate" />
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
            </div>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Title</th>
                <th>Date</th>
                <th>Venue</th>
                <th>Category</th>
                <th>Status</th>
                <th>Registrations</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Events.Items.Count == 0)
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">No events found.</td>
                </tr>
            }
            @foreach (var evt in Model.Events.Items)
            {
                <tr>
                    <td>
                        <a asp-page="Details" asp-route-id="@evt.Id">@evt.Title</a>
                        @if (evt.IsFeatured)
                        {
                            <span class="badge bg-warning text-dark ms-1">Featured</span>
                        }
                    </td>
                    <td>@evt.StartDate.ToString("MMM dd, yyyy")</td>
                    <td>@evt.Venue.Name</td>
                    <td>@evt.EventCategory.Name</td>
                    <td><partial name="_StatusBadge" model="evt.Status" /></td>
                    <td>@evt.CurrentRegistrations / @evt.TotalCapacity</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-between align-items-center">
    <p class="text-muted mb-0">
        Showing @((Model.Events.PageNumber - 1) * Model.PageSize + 1)–@(Math.Min(Model.Events.PageNumber * Model.PageSize, Model.Events.TotalCount)) of @Model.Events.TotalCount events
    </p>
    @{
        ViewData["QueryString"] = queryString;
    }
    <partial name="_Pagination" model="Model.Events" view-data="ViewData" />
</div>
