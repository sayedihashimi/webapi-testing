@page "{id:int}"
@model HorizonHR.Pages.Leave.DetailsModel
@using HorizonHR.Models
@{ ViewData["Title"] = "Leave Request Details"; }

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="Index">Leave Requests</a></li>
        <li class="breadcrumb-item active" aria-current="page">Details</li>
    </ol>
</nav>

<h1>Leave Request <partial name="/Pages/Shared/_StatusBadge" view-data='@(new ViewDataDictionary(ViewData) { { "Status", Model.Request.Status.ToString() } })' /></h1>

<div class="row">
    <div class="col-md-6">
        <section class="card">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Employee</dt>
                    <dd class="col-sm-8"><a asp-page="/Employees/Details" asp-route-id="@Model.Request.EmployeeId">@Model.Request.Employee.FullName</a></dd>
                    <dt class="col-sm-4">Department</dt>
                    <dd class="col-sm-8">@Model.Request.Employee.Department.Name</dd>
                    <dt class="col-sm-4">Leave Type</dt>
                    <dd class="col-sm-8">@Model.Request.LeaveType.Name</dd>
                    <dt class="col-sm-4">Start Date</dt>
                    <dd class="col-sm-8">@Model.Request.StartDate.ToString("MMM dd, yyyy")</dd>
                    <dt class="col-sm-4">End Date</dt>
                    <dd class="col-sm-8">@Model.Request.EndDate.ToString("MMM dd, yyyy")</dd>
                    <dt class="col-sm-4">Total Days</dt>
                    <dd class="col-sm-8">@Model.Request.TotalDays</dd>
                    <dt class="col-sm-4">Reason</dt>
                    <dd class="col-sm-8">@Model.Request.Reason</dd>
                    <dt class="col-sm-4">Submitted</dt>
                    <dd class="col-sm-8">@Model.Request.SubmittedDate.ToString("MMM dd, yyyy HH:mm")</dd>
                    @if (Model.Request.ReviewedBy is not null)
                    {
                        <dt class="col-sm-4">Reviewed By</dt>
                        <dd class="col-sm-8">@Model.Request.ReviewedBy.FullName</dd>
                        <dt class="col-sm-4">Review Date</dt>
                        <dd class="col-sm-8">@Model.Request.ReviewDate?.ToString("MMM dd, yyyy HH:mm")</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.Request.ReviewNotes))
                    {
                        <dt class="col-sm-4">Review Notes</dt>
                        <dd class="col-sm-8">@Model.Request.ReviewNotes</dd>
                    }
                </dl>
            </div>
        </section>
        <div class="mt-3">
            @if (Model.Request.Status == LeaveRequestStatus.Submitted)
            {
                <a asp-page="Review" asp-route-id="@Model.Request.Id" class="btn btn-success">Review</a>
            }
            @if (Model.Request.Status is LeaveRequestStatus.Submitted or LeaveRequestStatus.Approved)
            {
                <a asp-page="Cancel" asp-route-id="@Model.Request.Id" class="btn btn-outline-danger">Cancel</a>
            }
            <a asp-page="Index" class="btn btn-outline-secondary">Back</a>
        </div>
    </div>
</div>
