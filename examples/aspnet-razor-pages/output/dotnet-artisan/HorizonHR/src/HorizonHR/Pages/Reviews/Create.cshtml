@page
@model HorizonHR.Pages.Reviews.CreateModel
@{ ViewData["Title"] = "Create Review"; }

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="Index">Reviews</a></li>
        <li class="breadcrumb-item active" aria-current="page">Create</li>
    </ol>
</nav>
<h1>Create Performance Review</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Input.EmployeeId" class="form-label">Employee</label>
                <select asp-for="Input.EmployeeId" asp-items="Model.Employees" class="form-select">
                    <option value="">Select Employee...</option>
                </select>
                <span asp-validation-for="Input.EmployeeId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.ReviewerId" class="form-label">Reviewer</label>
                <select asp-for="Input.ReviewerId" asp-items="Model.Employees" class="form-select">
                    <option value="">Select Reviewer...</option>
                </select>
                <span asp-validation-for="Input.ReviewerId" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.ReviewPeriodStart" class="form-label">Period Start</label>
                    <input asp-for="Input.ReviewPeriodStart" class="form-control" type="date" />
                    <span asp-validation-for="Input.ReviewPeriodStart" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.ReviewPeriodEnd" class="form-label">Period End</label>
                    <input asp-for="Input.ReviewPeriodEnd" class="form-control" type="date" />
                    <span asp-validation-for="Input.ReviewPeriodEnd" class="text-danger"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Create Review</button>
            <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
