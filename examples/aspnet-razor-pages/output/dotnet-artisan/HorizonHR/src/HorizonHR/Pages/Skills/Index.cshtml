@page
@model HorizonHR.Pages.Skills.IndexModel
@{ ViewData["Title"] = "Skills"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Skills</h1>
    <div>
        <a asp-page="Search" class="btn btn-outline-primary">Search by Skill</a>
        <a asp-page="Create" class="btn btn-primary">Add Skill</a>
    </div>
</div>

@if (!Model.SkillsByCategory.Any())
{
    <p class="text-muted">No skills defined.</p>
}
else
{
    @foreach (var category in Model.SkillsByCategory)
    {
        <section class="mb-4">
            <h3>@category.Key</h3>
            <table class="table table-striped">
                <thead><tr><th>Skill</th><th>Description</th><th>Employees</th><th>Actions</th></tr></thead>
                <tbody>
                    @foreach (var skill in category.Value)
                    {
                        <tr>
                            <td>@skill.Name</td>
                            <td>@(skill.Description ?? "—")</td>
                            <td><span class="badge bg-primary rounded-pill">@skill.EmployeeSkills.Count</span></td>
                            <td><a asp-page="Edit" asp-route-id="@skill.Id" class="btn btn-sm btn-outline-secondary">Edit</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    }
}
