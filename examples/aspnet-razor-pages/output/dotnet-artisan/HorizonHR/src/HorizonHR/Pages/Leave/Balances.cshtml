@page
@model HorizonHR.Pages.Leave.BalancesModel
@{ ViewData["Title"] = "Leave Balances"; }

<h1>Leave Balances</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <select asp-for="DepartmentId" asp-items="Model.Departments" class="form-select">
            <option value="">All Departments</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary">Filter</button>
    </div>
</form>

@if (!Model.Balances.Any())
{
    <p class="text-muted">No leave balances found.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead><tr><th>Employee</th><th>Department</th><th>Leave Type</th><th>Total</th><th>Used</th><th>Carried Over</th><th>Remaining</th></tr></thead>
        <tbody>
            @foreach (var bal in Model.Balances)
            {
                <tr>
                    <td><a asp-page="/Employees/Details" asp-route-id="@bal.EmployeeId">@bal.Employee.FullName</a></td>
                    <td>@bal.Employee.Department.Name</td>
                    <td>@bal.LeaveType.Name</td>
                    <td>@bal.TotalDays</td>
                    <td>@bal.UsedDays</td>
                    <td>@bal.CarriedOverDays</td>
                    <td><strong>@bal.RemainingDays</strong></td>
                </tr>
            }
        </tbody>
    </table>
}
