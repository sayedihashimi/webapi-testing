@page "{id:int}"
@model HorizonHR.Pages.Leave.EmployeeModel
@{ ViewData["Title"] = $"Leave Summary — {Model.Employee.FullName}"; }

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="Index">Leave</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Employee.FullName</li>
    </ol>
</nav>

<h1>Leave Summary — @Model.Employee.FullName</h1>

<section>
    <h3>Current Year Balances</h3>
    @if (Model.Balances.Any())
    {
        <table class="table table-striped">
            <thead><tr><th>Leave Type</th><th>Total</th><th>Used</th><th>Carried Over</th><th>Remaining</th></tr></thead>
            <tbody>
                @foreach (var bal in Model.Balances)
                {
                    <tr>
                        <td>@bal.LeaveType.Name</td>
                        <td>@bal.TotalDays</td>
                        <td>@bal.UsedDays</td>
                        <td>@bal.CarriedOverDays</td>
                        <td><strong>@bal.RemainingDays</strong></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No leave balances.</p>
    }
</section>

<section class="mt-4">
    <h3>Request History</h3>
    @if (Model.Requests.Any())
    {
        <table class="table table-hover">
            <thead><tr><th>Type</th><th>Start</th><th>End</th><th>Days</th><th>Status</th><th>Submitted</th></tr></thead>
            <tbody>
                @foreach (var req in Model.Requests)
                {
                    <tr>
                        <td>@req.LeaveType.Name</td>
                        <td>@req.StartDate.ToString("MMM dd, yyyy")</td>
                        <td>@req.EndDate.ToString("MMM dd, yyyy")</td>
                        <td>@req.TotalDays</td>
                        <td><partial name="/Pages/Shared/_StatusBadge" view-data='@(new ViewDataDictionary(ViewData) { { "Status", req.Status.ToString() } })' /></td>
                        <td>@req.SubmittedDate.ToString("MMM dd, yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No leave requests.</p>
    }
</section>
