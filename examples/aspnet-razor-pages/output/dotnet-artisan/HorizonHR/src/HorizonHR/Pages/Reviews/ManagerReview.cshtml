@page "{id:int}"
@model HorizonHR.Pages.Reviews.ManagerReviewModel
@using HorizonHR.Models
@{ ViewData["Title"] = "Manager Review"; }

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="Index">Reviews</a></li>
        <li class="breadcrumb-item"><a asp-page="Details" asp-route-id="@Model.Review.Id">Details</a></li>
        <li class="breadcrumb-item active" aria-current="page">Manager Review</li>
    </ol>
</nav>
<h1>Manager Review — @Model.Review.Employee.FullName</h1>

@if (!string.IsNullOrEmpty(Model.Review.SelfAssessment))
{
    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Employee Self-Assessment</h5></div>
        <div class="card-body"><p>@Model.Review.SelfAssessment</p></div>
    </div>
}

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <input type="hidden" asp-for="Input.Id" />
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Input.ManagerAssessment" class="form-label"></label>
                <textarea asp-for="Input.ManagerAssessment" class="form-control" rows="6"></textarea>
                <span asp-validation-for="Input.ManagerAssessment" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.OverallRating" class="form-label"></label>
                <select asp-for="Input.OverallRating" asp-items="Html.GetEnumSelectList<OverallRating>()" class="form-select"></select>
                <span asp-validation-for="Input.OverallRating" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.StrengthsNoted" class="form-label">Strengths</label>
                <textarea asp-for="Input.StrengthsNoted" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="Input.AreasForImprovement" class="form-label">Areas for Improvement</label>
                <textarea asp-for="Input.AreasForImprovement" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Goals" class="form-label">Goals for Next Period</label>
                <textarea asp-for="Input.Goals" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-success">Complete Review</button>
            <a asp-page="Details" asp-route-id="@Model.Review.Id" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
