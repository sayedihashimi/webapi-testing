@page
@model HorizonHR.Pages.Departments.IndexModel
@{ ViewData["Title"] = "Departments"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Departments</h1>
    <a asp-page="Create" class="btn btn-primary">Create Department</a>
</div>

@if (!Model.RootDepartments.Any())
{
    <p class="text-muted">No departments found.</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr><th>Name</th><th>Code</th><th>Manager</th><th>Employees</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var dept in Model.RootDepartments)
            {
                @await Html.PartialAsync("_DepartmentRow", dept, new ViewDataDictionary(ViewData) { { "Level", 0 } })
            }
        </tbody>
    </table>
}
