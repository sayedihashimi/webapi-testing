@page
@model KeystoneProperties.Pages.Units.IndexModel
@{
    ViewData["Title"] = "Units";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Units</h1>
    <a asp-page="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Add Unit
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row g-3">
                <div class="col-md-3">
                    <label for="PropertyId" class="form-label">Property</label>
                    <select asp-for="PropertyId" asp-items="Model.Properties" class="form-select">
                        <option value="">All Properties</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="Status" class="form-label">Status</label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<UnitStatus>()" class="form-select">
                        <option value="">All</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="Bedrooms" class="form-label">Bedrooms</label>
                    <select asp-for="Bedrooms" class="form-select">
                        <option value="">Any</option>
                        @for (int i = 0; i <= 5; i++)
                        {
                            <option value="@i">@i</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="MinRent" class="form-label">Min Rent</label>
                    <input asp-for="MinRent" class="form-control" placeholder="$0" />
                </div>
                <div class="col-md-2">
                    <label for="MaxRent" class="form-label">Max Rent</label>
                    <input asp-for="MaxRent" class="form-control" placeholder="No max" />
                </div>
                <div class="col-md-3">
                    <label for="Search" class="form-label">Unit Number</label>
                    <input asp-for="Search" class="form-control" placeholder="Search by unit number..." />
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-outline-primary">Filter</button>
                    <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>

@{
    var queryParams = new List<string>();
    if (Model.PropertyId.HasValue) { queryParams.Add($"propertyId={Model.PropertyId}"); }
    if (Model.Status.HasValue) { queryParams.Add($"status={Model.Status}"); }
    if (Model.Bedrooms.HasValue) { queryParams.Add($"bedrooms={Model.Bedrooms}"); }
    if (Model.MinRent.HasValue) { queryParams.Add($"minRent={Model.MinRent}"); }
    if (Model.MaxRent.HasValue) { queryParams.Add($"maxRent={Model.MaxRent}"); }
    if (!string.IsNullOrEmpty(Model.Search)) { queryParams.Add($"search={Model.Search}"); }
    queryParams.Add($"pageSize={Model.PageSize}");
    var pageUrl = "/Units?" + string.Join("&", queryParams);
}

@if (!Model.Units.Items.Any())
{
    <div class="alert alert-info">No units found matching your criteria.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Property</th>
                    <th>Unit #</th>
                    <th>Bedrooms</th>
                    <th>Bathrooms</th>
                    <th>Sq Ft</th>
                    <th>Monthly Rent</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var unit in Model.Units.Items)
                {
                    <tr>
                        <td>@unit.Property.Name</td>
                        <td>@unit.UnitNumber</td>
                        <td>@unit.Bedrooms</td>
                        <td>@unit.Bathrooms</td>
                        <td>@unit.SquareFeet.ToString("N0")</td>
                        <td>@unit.MonthlyRent.ToString("C")</td>
                        <td>
                            <partial name="_StatusBadgePartial" model="@(( unit.Status.ToString(), "UnitStatus" ))" />
                        </td>
                        <td>
                            <a asp-page="Details" asp-route-id="@unit.Id" class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-page="Edit" asp-route-id="@unit.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_PaginationPartial" model="@(( Model.Units.PageNumber, Model.Units.TotalPages, pageUrl ))" />
}
