@page "{id:int}"
@model KeystoneProperties.Pages.Leases.RenewModel
@{
    ViewData["Title"] = "Renew Lease";
}

<h1 class="mb-4">Renew Lease #@Model.Lease.Id</h1>

<div class="card mb-4">
    <div class="card-header"><h5 class="mb-0">Current Lease</h5></div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Tenant</dt>
            <dd class="col-sm-9">@Model.Lease.Tenant.FullName</dd>
            <dt class="col-sm-3">Property / Unit</dt>
            <dd class="col-sm-9">@Model.Lease.Unit.Property.Name — @Model.Lease.Unit.UnitNumber</dd>
            <dt class="col-sm-3">Current Period</dt>
            <dd class="col-sm-9">@Model.Lease.StartDate.ToShortDateString() — @Model.Lease.EndDate.ToShortDateString()</dd>
            <dt class="col-sm-3">Current Rent</dt>
            <dd class="col-sm-9">@Model.Lease.MonthlyRentAmount.ToString("C")</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <partial name="_StatusBadgePartial" model='(Model.Lease.Status.ToString(), "LeaseStatus")' />
            </dd>
        </dl>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <input type="hidden" asp-for="Input.LeaseId" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.NewStartDate" class="form-label"></label>
                    <input asp-for="Input.NewStartDate" class="form-control" type="date" readonly />
                    <span class="form-text">Day after current lease ends</span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.NewEndDate" class="form-label"></label>
                    <input asp-for="Input.NewEndDate" class="form-control" type="date" />
                    <span asp-validation-for="Input.NewEndDate" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Input.NewMonthlyRent" class="form-label"></label>
                    <input asp-for="Input.NewMonthlyRent" class="form-control" />
                    <span asp-validation-for="Input.NewMonthlyRent" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Renew Lease</button>
                <a asp-page="Details" asp-route-id="@Model.Lease.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
