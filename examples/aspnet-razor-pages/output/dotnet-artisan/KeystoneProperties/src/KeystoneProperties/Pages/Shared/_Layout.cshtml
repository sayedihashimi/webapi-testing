<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Keystone Properties</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YcnS/1WR6zNg8l3KCBhHIalVl2DK4nB3E7Gb" crossorigin="anonymous" />
    <style>
        body { min-height: 100vh; display: flex; flex-direction: column; }
        main { flex: 1; }
        .badge-status { font-size: 0.85em; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark" aria-label="Main navigation">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-page="/Index">🏠 Keystone Properties</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav">
                        @{
                            var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
                            bool IsCurrent(string prefix) => currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
                            bool IsIndex() => currentPage == "/Index";
                        }
                        <li class="nav-item">
                            <a class="nav-link @(IsIndex() ? "active" : "")" asp-page="/Index" aria-current="@(IsIndex() ? "page" : "false")">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsCurrent("/Properties") ? "active" : "")" asp-page="/Properties/Index" aria-current="@(IsCurrent("/Properties") ? "page" : "false")">Properties</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsCurrent("/Units") ? "active" : "")" asp-page="/Units/Index" aria-current="@(IsCurrent("/Units") ? "page" : "false")">Units</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsCurrent("/Tenants") ? "active" : "")" asp-page="/Tenants/Index" aria-current="@(IsCurrent("/Tenants") ? "page" : "false")">Tenants</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsCurrent("/Leases") ? "active" : "")" asp-page="/Leases/Index" aria-current="@(IsCurrent("/Leases") ? "page" : "false")">Leases</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsCurrent("/Payments") ? "active" : "")" asp-page="/Payments/Index" aria-current="@(IsCurrent("/Payments") ? "page" : "false")">Payments</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsCurrent("/Maintenance") ? "active" : "")" asp-page="/Maintenance/Index" aria-current="@(IsCurrent("/Maintenance") ? "page" : "false")">Maintenance</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsCurrent("/Inspections") ? "active" : "")" asp-page="/Inspections/Index" aria-current="@(IsCurrent("/Inspections") ? "page" : "false")">Inspections</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-3">
        @if (TempData["SuccessMessage"] is string successMsg)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] is string errorMsg)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>

    <main class="container py-3">
        @RenderBody()
    </main>

    <footer class="border-top bg-light py-3 mt-auto">
        <div class="container text-center text-muted">
            &copy; @DateTime.Now.Year Keystone Properties — Property Management System
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
