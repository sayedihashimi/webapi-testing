@page "{id:int}"
@model KeystoneProperties.Pages.Tenants.DeactivateModel
@{
    ViewData["Title"] = "Deactivate Tenant";
}

<h1>Deactivate Tenant</h1>

<div class="alert alert-warning">
    <strong>Are you sure?</strong> You are about to deactivate the following tenant. This action cannot be performed if the tenant has active leases.
</div>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Tenant.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Tenant.Email</dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.Tenant.Phone</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.Tenant.IsActive)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-secondary">Inactive</span>
                }
            </dd>
        </dl>
    </div>
</div>

<form method="post" asp-route-id="@Model.Tenant.Id">
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Confirm Deactivation</button>
        <a asp-page="Details" asp-route-id="@Model.Tenant.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
