@page "{id:int}"
@model KeystoneProperties.Pages.Properties.DetailsModel
@{
    ViewData["Title"] = Model.Property.Name;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@Model.Property.Name</h1>
    <div>
        <a asp-page="Edit" asp-route-id="@Model.Property.Id" class="btn btn-outline-secondary">Edit</a>
        <a asp-page="Index" class="btn btn-outline-dark">Back to List</a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><h5 class="mb-0">Property Information</h5></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Address</dt>
                    <dd class="col-sm-8">@Model.Property.Address</dd>

                    <dt class="col-sm-4">City</dt>
                    <dd class="col-sm-8">@Model.Property.City, @Model.Property.State @Model.Property.ZipCode</dd>

                    <dt class="col-sm-4">Type</dt>
                    <dd class="col-sm-8">@Model.Property.PropertyType</dd>

                    <dt class="col-sm-4">Year Built</dt>
                    <dd class="col-sm-8">@(Model.Property.YearBuilt?.ToString() ?? "N/A")</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.Property.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@(Model.Property.Description ?? "—")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><h5 class="mb-0">Occupancy Summary</h5></div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-4">
                        <h3 class="fw-bold">@Model.Property.TotalUnits</h3>
                        <p class="text-muted">Total Units</p>
                    </div>
                    <div class="col-4">
                        <h3 class="fw-bold text-primary">@Model.OccupiedCount</h3>
                        <p class="text-muted">Occupied</p>
                    </div>
                    <div class="col-4">
                        <h3 class="fw-bold text-success">@Model.OccupancyRate.ToString("P0")</h3>
                        <p class="text-muted">Occupancy Rate</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Units (@Model.Property.Units.Count)</h5>
    </div>
    <div class="card-body">
        @if (Model.Property.Units.Count == 0)
        {
            <p class="text-muted mb-0">No units have been added to this property yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Unit #</th>
                            <th>Beds</th>
                            <th>Baths</th>
                            <th>Sq Ft</th>
                            <th>Rent</th>
                            <th>Status</th>
                            <th>Current Tenant</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var unit in Model.Property.Units.OrderBy(u => u.UnitNumber))
                        {
                            var activeLease = unit.Leases.FirstOrDefault(l => l.Status == LeaseStatus.Active);

                            <tr>
                                <td>@unit.UnitNumber</td>
                                <td>@unit.Bedrooms</td>
                                <td>@unit.Bathrooms</td>
                                <td>@unit.SquareFeet.ToString("N0")</td>
                                <td>@unit.MonthlyRent.ToString("C")</td>
                                <td>
                                    <partial name="_StatusBadgePartial" model='(unit.Status.ToString(), "UnitStatus")' />
                                </td>
                                <td>@(activeLease?.Tenant.FullName ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
