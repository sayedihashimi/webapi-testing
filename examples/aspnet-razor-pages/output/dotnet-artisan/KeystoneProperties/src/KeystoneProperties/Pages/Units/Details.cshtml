@page "{id:int}"
@model KeystoneProperties.Pages.Units.DetailsModel
@{
    ViewData["Title"] = $"Unit {Model.Unit.UnitNumber}";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="Index">Units</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Unit.UnitNumber</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Unit @Model.Unit.UnitNumber</h1>
    <a asp-page="Edit" asp-route-id="@Model.Unit.Id" class="btn btn-outline-secondary">Edit</a>
</div>

<!-- Unit Info Card -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Unit Information</h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Property</dt>
                    <dd class="col-sm-8">@Model.Unit.Property.Name</dd>

                    <dt class="col-sm-4">Unit Number</dt>
                    <dd class="col-sm-8">@Model.Unit.UnitNumber</dd>

                    <dt class="col-sm-4">Floor</dt>
                    <dd class="col-sm-8">@(Model.Unit.Floor?.ToString() ?? "N/A")</dd>

                    <dt class="col-sm-4">Bedrooms</dt>
                    <dd class="col-sm-8">@Model.Unit.Bedrooms</dd>

                    <dt class="col-sm-4">Bathrooms</dt>
                    <dd class="col-sm-8">@Model.Unit.Bathrooms</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Square Feet</dt>
                    <dd class="col-sm-8">@Model.Unit.SquareFeet.ToString("N0")</dd>

                    <dt class="col-sm-4">Monthly Rent</dt>
                    <dd class="col-sm-8">@Model.Unit.MonthlyRent.ToString("C")</dd>

                    <dt class="col-sm-4">Deposit</dt>
                    <dd class="col-sm-8">@Model.Unit.DepositAmount.ToString("C")</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <partial name="_StatusBadgePartial" model="@(( Model.Unit.Status.ToString(), "UnitStatus" ))" />
                    </dd>

                    <dt class="col-sm-4">Amenities</dt>
                    <dd class="col-sm-8">@(Model.Unit.Amenities ?? "None listed")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<!-- Current Active Lease -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Current Lease</h5>
    </div>
    <div class="card-body">
        @if (Model.ActiveLease is not null)
        {
            <dl class="row mb-0">
                <dt class="col-sm-3">Tenant</dt>
                <dd class="col-sm-9">@Model.ActiveLease.Tenant.FullName</dd>

                <dt class="col-sm-3">Lease Period</dt>
                <dd class="col-sm-9">@Model.ActiveLease.StartDate.ToString("MMM d, yyyy") &ndash; @Model.ActiveLease.EndDate.ToString("MMM d, yyyy")</dd>

                <dt class="col-sm-3">Monthly Rent</dt>
                <dd class="col-sm-9">@Model.ActiveLease.MonthlyRentAmount.ToString("C")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    <partial name="_StatusBadgePartial" model="@(( Model.ActiveLease.Status.ToString(), "LeaseStatus" ))" />
                </dd>
            </dl>
        }
        else
        {
            <p class="text-muted mb-0">No active lease for this unit.</p>
        }
    </div>
</div>

<!-- Lease History -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Lease History</h5>
    </div>
    <div class="card-body">
        @if (Model.LeaseHistory.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Tenant</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Monthly Rent</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lease in Model.LeaseHistory)
                        {
                            <tr>
                                <td>@lease.Tenant.FullName</td>
                                <td>@lease.StartDate.ToString("MMM d, yyyy")</td>
                                <td>@lease.EndDate.ToString("MMM d, yyyy")</td>
                                <td>@lease.MonthlyRentAmount.ToString("C")</td>
                                <td>
                                    <partial name="_StatusBadgePartial" model="@(( lease.Status.ToString(), "LeaseStatus" ))" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No lease history for this unit.</p>
        }
    </div>
</div>

<!-- Maintenance History -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Maintenance History</h5>
    </div>
    <div class="card-body">
        @if (Model.MaintenanceHistory.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Submitted</th>
                            <th>Completed</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in Model.MaintenanceHistory)
                        {
                            <tr>
                                <td>@request.Title</td>
                                <td>@request.Category</td>
                                <td>
                                    <partial name="_StatusBadgePartial" model="@(( request.Priority.ToString(), "MaintenancePriority" ))" />
                                </td>
                                <td>
                                    <partial name="_StatusBadgePartial" model="@(( request.Status.ToString(), "MaintenanceStatus" ))" />
                                </td>
                                <td>@request.SubmittedDate.ToString("MMM d, yyyy")</td>
                                <td>@(request.CompletedDate?.ToString("MMM d, yyyy") ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No maintenance requests for this unit.</p>
        }
    </div>
</div>

<!-- Inspections -->
<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Inspections</h5>
    </div>
    <div class="card-body">
        @if (Model.Inspections.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Scheduled</th>
                            <th>Completed</th>
                            <th>Inspector</th>
                            <th>Condition</th>
                            <th>Follow-Up</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inspection in Model.Inspections)
                        {
                            <tr>
                                <td>@inspection.InspectionType</td>
                                <td>@inspection.ScheduledDate.ToString("MMM d, yyyy")</td>
                                <td>@(inspection.CompletedDate?.ToString("MMM d, yyyy") ?? "—")</td>
                                <td>@inspection.InspectorName</td>
                                <td>
                                    @if (inspection.OverallCondition.HasValue)
                                    {
                                        <partial name="_StatusBadgePartial" model="@(( inspection.OverallCondition.Value.ToString(), "OverallCondition" ))" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (inspection.FollowUpRequired)
                                    {
                                        <span class="badge bg-warning text-dark">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No inspections for this unit.</p>
        }
    </div>
</div>
