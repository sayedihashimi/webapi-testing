@page "{id:int}"
@model KeystoneProperties.Pages.Leases.TerminateModel
@{
    ViewData["Title"] = "Terminate Lease";
}

<h1 class="mb-4">Terminate Lease #@Model.Lease.Id</h1>

<div class="card mb-4">
    <div class="card-header"><h5 class="mb-0">Lease Information</h5></div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Tenant</dt>
            <dd class="col-sm-9">@Model.Lease.Tenant.FullName</dd>
            <dt class="col-sm-3">Property / Unit</dt>
            <dd class="col-sm-9">@Model.Lease.Unit.Property.Name — @Model.Lease.Unit.UnitNumber</dd>
            <dt class="col-sm-3">Lease Period</dt>
            <dd class="col-sm-9">@Model.Lease.StartDate.ToShortDateString() — @Model.Lease.EndDate.ToShortDateString()</dd>
            <dt class="col-sm-3">Monthly Rent</dt>
            <dd class="col-sm-9">@Model.Lease.MonthlyRentAmount.ToString("C")</dd>
            <dt class="col-sm-3">Deposit</dt>
            <dd class="col-sm-9">@Model.Lease.DepositAmount.ToString("C")</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <partial name="_StatusBadgePartial" model='(Model.Lease.Status.ToString(), "LeaseStatus")' />
            </dd>
        </dl>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <input type="hidden" asp-for="Input.LeaseId" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.TerminationDate" class="form-label"></label>
                <input asp-for="Input.TerminationDate" class="form-control" type="date" />
                <span asp-validation-for="Input.TerminationDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.TerminationReason" class="form-label"></label>
                <textarea asp-for="Input.TerminationReason" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.TerminationReason" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.DepositStatus" class="form-label"></label>
                    <select asp-for="Input.DepositStatus" asp-items="Html.GetEnumSelectList<DepositStatus>()"
                            class="form-select"></select>
                    <span asp-validation-for="Input.DepositStatus" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.DepositReturnAmount" class="form-label"></label>
                    <input asp-for="Input.DepositReturnAmount" class="form-control" />
                    <span asp-validation-for="Input.DepositReturnAmount" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Terminate Lease</button>
                <a asp-page="Details" asp-route-id="@Model.Lease.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
