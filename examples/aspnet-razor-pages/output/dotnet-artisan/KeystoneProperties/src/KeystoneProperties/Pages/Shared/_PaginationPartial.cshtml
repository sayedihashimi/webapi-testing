@model (int PageNumber, int TotalPages, string PageUrl)

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                <a class="page-link" href="@Model.PageUrl&pageNumber=@(Model.PageNumber - 1)">Previous</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" href="@Model.PageUrl&pageNumber=@i">@i</a>
                </li>
            }
            <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" href="@Model.PageUrl&pageNumber=@(Model.PageNumber + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
