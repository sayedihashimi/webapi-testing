@page "{id:int}"
@model KeystoneProperties.Pages.Maintenance.UpdateStatusModel
@{
    ViewData["Title"] = "Update Maintenance Status";
}

<h1 class="mb-4">Update Maintenance Status</h1>

<div class="row">
    <div class="col-lg-4 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Current Request</h5>
            </div>
            <div class="card-body">
                <dl class="mb-0">
                    <dt>Title</dt>
                    <dd>@Model.Request.Title</dd>
                    <dt>Unit</dt>
                    <dd>@Model.Request.Unit.Property.Name - Unit #@Model.Request.Unit.UnitNumber</dd>
                    <dt>Tenant</dt>
                    <dd>@Model.Request.Tenant.FullName</dd>
                    <dt>Priority</dt>
                    <dd>
                        <partial name="_StatusBadgePartial" model="@(Model.Request.Priority.ToString(), "MaintenancePriority")" />
                    </dd>
                    <dt>Current Status</dt>
                    <dd>
                        <partial name="_StatusBadgePartial" model="@(Model.Request.Status.ToString(), "MaintenanceStatus")" />
                    </dd>
                    <dt>Submitted</dt>
                    <dd>@Model.Request.SubmittedDate.ToString("g")</dd>
                    @if (Model.Request.AssignedTo is not null)
                    {
                        <dt>Assigned To</dt>
                        <dd>@Model.Request.AssignedTo</dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <form method="post">
            <input type="hidden" asp-for="Input.Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Status Update</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Input.NewStatus" class="form-label"></label>
                            <select asp-for="Input.NewStatus" asp-items="Model.ValidStatuses" class="form-select" id="statusSelect">
                                <option value="">-- Select Status --</option>
                            </select>
                            <span asp-validation-for="Input.NewStatus" class="text-danger"></span>
                        </div>
                        <div class="col-md-6" id="assignedToGroup" style="display: none;">
                            <label asp-for="Input.AssignedTo" class="form-label"></label>
                            <input asp-for="Input.AssignedTo" class="form-control" />
                            <span asp-validation-for="Input.AssignedTo" class="text-danger"></span>
                        </div>
                        <div class="col-12" id="completionNotesGroup" style="display: none;">
                            <label asp-for="Input.CompletionNotes" class="form-label"></label>
                            <textarea asp-for="Input.CompletionNotes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Input.CompletionNotes" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.EstimatedCost" class="form-label"></label>
                            <input asp-for="Input.EstimatedCost" class="form-control" />
                            <span asp-validation-for="Input.EstimatedCost" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.ActualCost" class="form-label"></label>
                            <input asp-for="Input.ActualCost" class="form-control" />
                            <span asp-validation-for="Input.ActualCost" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Update Status</button>
                <a asp-page="Details" asp-route-id="@Model.Request.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var statusSelect = document.getElementById('statusSelect');
            var assignedToGroup = document.getElementById('assignedToGroup');
            var completionNotesGroup = document.getElementById('completionNotesGroup');
            var assignedValue = '@((int)MaintenanceStatus.Assigned)';
            var completedValue = '@((int)MaintenanceStatus.Completed)';

            function toggleFields() {
                assignedToGroup.style.display = statusSelect.value === assignedValue ? '' : 'none';
                completionNotesGroup.style.display = statusSelect.value === completedValue ? '' : 'none';
            }

            statusSelect.addEventListener('change', toggleFields);
            toggleFields();
        });
    </script>
}
