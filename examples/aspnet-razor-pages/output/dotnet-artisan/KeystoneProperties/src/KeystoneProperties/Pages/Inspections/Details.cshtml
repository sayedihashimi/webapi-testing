@page "{id:int}"
@model KeystoneProperties.Pages.Inspections.DetailsModel
@{
    ViewData["Title"] = "Inspection Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Inspection Details</h1>
    <div>
        @if (!Model.Inspection.CompletedDate.HasValue)
        {
            <a asp-page="Complete" asp-route-id="@Model.Inspection.Id" class="btn btn-success">Complete Inspection</a>
        }
        <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0">Inspection Information</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Type</dt>
                    <dd class="col-sm-7">@Model.Inspection.InspectionType</dd>

                    <dt class="col-sm-5">Scheduled Date</dt>
                    <dd class="col-sm-7">@Model.Inspection.ScheduledDate.ToShortDateString()</dd>

                    <dt class="col-sm-5">Completed Date</dt>
                    <dd class="col-sm-7">
                        @if (Model.Inspection.CompletedDate.HasValue)
                        {
                            @Model.Inspection.CompletedDate.Value.ToShortDateString()
                        }
                        else
                        {
                            <span class="text-muted">Not yet completed</span>
                        }
                    </dd>

                    <dt class="col-sm-5">Inspector</dt>
                    <dd class="col-sm-7">@Model.Inspection.InspectorName</dd>

                    <dt class="col-sm-5">Condition</dt>
                    <dd class="col-sm-7">
                        @if (Model.Inspection.OverallCondition.HasValue)
                        {
                            @await Html.PartialAsync("_StatusBadgePartial", (Model.Inspection.OverallCondition.Value.ToString(), "OverallCondition"))
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </dd>

                    <dt class="col-sm-5">Follow-Up</dt>
                    <dd class="col-sm-7">
                        @if (Model.Inspection.FollowUpRequired)
                        {
                            <span class="badge bg-warning text-dark">Follow-Up Required</span>
                        }
                        else
                        {
                            <span class="text-muted">Not required</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h5 class="mb-0">Unit Information</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Property</dt>
                    <dd class="col-sm-7">@Model.Inspection.Unit.Property.Name</dd>

                    <dt class="col-sm-5">Unit Number</dt>
                    <dd class="col-sm-7">@Model.Inspection.Unit.UnitNumber</dd>
                </dl>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Inspection.Notes))
    {
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Notes</h5>
                </div>
                <div class="card-body">
                    <p class="mb-0" style="white-space: pre-wrap;">@Model.Inspection.Notes</p>
                </div>
            </div>
        </div>
    }

    @if (Model.Inspection.Lease is not null)
    {
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Linked Lease</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Tenant</dt>
                        <dd class="col-sm-9">@Model.Inspection.Lease.Tenant.FullName</dd>

                        <dt class="col-sm-3">Lease Period</dt>
                        <dd class="col-sm-9">@Model.Inspection.Lease.StartDate.ToShortDateString() — @Model.Inspection.Lease.EndDate.ToShortDateString()</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            @await Html.PartialAsync("_StatusBadgePartial", (Model.Inspection.Lease.Status.ToString(), "LeaseStatus"))
                        </dd>
                    </dl>
                    <a asp-page="/Leases/Details" asp-route-id="@Model.Inspection.Lease.Id" class="btn btn-sm btn-outline-primary mt-2">View Lease</a>
                </div>
            </div>
        </div>
    }
</div>
