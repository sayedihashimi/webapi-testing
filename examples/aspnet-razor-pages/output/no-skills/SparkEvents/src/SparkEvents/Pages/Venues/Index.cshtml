@page
@model SparkEvents.Pages.Venues.IndexModel
@{
    ViewData["Title"] = "Venues";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Venues</h1>
        <a asp-page="Create" class="btn btn-primary">Add Venue</a>
    </div>

    @if (Model.Venues.Any())
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Address</th>
                    <th>City</th>
                    <th>State</th>
                    <th>Max Capacity</th>
                    <th>Contact</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var venue in Model.Venues)
                {
                    <tr>
                        <td><a asp-page="Details" asp-route-id="@venue.Id">@venue.Name</a></td>
                        <td>@venue.Address</td>
                        <td>@venue.City</td>
                        <td>@venue.State</td>
                        <td>@venue.MaxCapacity</td>
                        <td>@venue.ContactEmail</td>
                        <td>
                            <a asp-page="Edit" asp-route-id="@venue.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-page="Delete" asp-route-id="@venue.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No venues found. Add one to get started.</p>
    }
</section>
