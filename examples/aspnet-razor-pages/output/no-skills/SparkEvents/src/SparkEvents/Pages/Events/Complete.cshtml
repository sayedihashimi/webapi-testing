@page "{id:int}"
@model SparkEvents.Pages.Events.CompleteModel
@{
    ViewData["Title"] = "Complete Event";
}

<section>
    <h1>Mark Event as Completed</h1>
    <hr />

    <div class="card">
        <div class="card-body">
            <h5 class="card-title">@Model.Event.Title</h5>
            <p>@Model.Event.StartDate.ToString("MMM dd, yyyy") — @Model.Event.EndDate.ToString("MMM dd, yyyy")</p>
            <p>@Model.Event.CurrentRegistrations registrations</p>

            @if (Model.Event.EndDate > DateTime.UtcNow)
            {
                <div class="alert alert-warning" role="alert">
                    This event has not ended yet. It can only be completed after the end date.
                </div>
                <a asp-page="Details" asp-route-id="@Model.Event.Id" class="btn btn-secondary">Go Back</a>
            }
            else
            {
                <p>Are you sure you want to mark this event as completed?</p>
                <form method="post">
                    <input type="hidden" name="id" value="@Model.Event.Id" />
                    <button type="submit" class="btn btn-info">Confirm Completion</button>
                    <a asp-page="Details" asp-route-id="@Model.Event.Id" class="btn btn-secondary">Cancel</a>
                </form>
            }
        </div>
    </div>
</section>
