@page
@model SparkEvents.Pages.Attendees.IndexModel
@{
    ViewData["Title"] = "Attendees";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Attendees</h1>
        <a asp-page="Create" class="btn btn-primary">Add Attendee</a>
    </div>

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search by name or email..." />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-secondary">Search</button>
        </div>
    </form>

    @if (Model.Attendees.Any())
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Organization</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.Attendees)
                {
                    <tr>
                        <td><a asp-page="Details" asp-route-id="@a.Id">@a.FullName</a></td>
                        <td>@a.Email</td>
                        <td>@(a.Phone ?? "—")</td>
                        <td>@(a.Organization ?? "—")</td>
                        <td>
                            <a asp-page="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <partial name="_Pagination" model="@(new { Model.Attendees.PageIndex, Model.Attendees.TotalPages, Model.Attendees.HasPreviousPage, Model.Attendees.HasNextPage, PageUrl = $"?search={Model.Search}" })" />
    }
    else
    {
        <p class="text-muted">No attendees found.</p>
    }
</section>
