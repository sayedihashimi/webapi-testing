@page
@model SparkEvents.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Event Categories</h1>
        <a asp-page="Create" class="btn btn-primary">Create Category</a>
    </div>

    @if (Model.Categories.Any())
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Color</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model.Categories)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(cat.ColorHex))
                            {
                                <span class="badge" style="background-color: @cat.ColorHex">@cat.Name</span>
                            }
                            else
                            {
                                @cat.Name
                            }
                        </td>
                        <td>@cat.Description</td>
                        <td>@cat.ColorHex</td>
                        <td>
                            <a asp-page="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-page="Delete" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No categories found. Create one to get started.</p>
    }
</section>
