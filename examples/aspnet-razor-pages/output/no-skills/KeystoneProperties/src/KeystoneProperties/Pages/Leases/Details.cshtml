@page "{id:int}"
@model KeystoneProperties.Pages.Leases.DetailsModel
@{
    ViewData["Title"] = $"Lease #{Model.Lease.Id}";
}
<h1>Lease #@Model.Lease.Id</h1>
<section class="mb-4">
    <div class="card"><div class="card-body"><div class="row">
        <div class="col-md-6">
            <p><strong>Tenant:</strong> <a asp-page="/Tenants/Details" asp-route-id="@Model.Lease.TenantId">@Model.Lease.Tenant.FullName</a></p>
            <p><strong>Unit:</strong> <a asp-page="/Units/Details" asp-route-id="@Model.Lease.UnitId">@Model.Lease.Unit.UnitNumber</a> — @Model.Lease.Unit.Property.Name</p>
            <p><strong>Start Date:</strong> @Model.Lease.StartDate.ToString("MMM dd, yyyy")</p>
            <p><strong>End Date:</strong> @Model.Lease.EndDate.ToString("MMM dd, yyyy")</p>
            <p><strong>Monthly Rent:</strong> @Model.Lease.MonthlyRentAmount.ToString("C")</p>
        </div>
        <div class="col-md-6">
            <p><strong>Deposit:</strong> @Model.Lease.DepositAmount.ToString("C")</p>
            <p><strong>Deposit Status:</strong> <partial name="_StatusBadge" model="@(Model.Lease.DepositStatus.ToString(), "deposit")" /></p>
            <p><strong>Lease Status:</strong> <partial name="_StatusBadge" model="@(Model.Lease.Status.ToString(), "lease")" /></p>
            @if (Model.Lease.TerminationDate.HasValue)
            {
                <p><strong>Termination Date:</strong> @Model.Lease.TerminationDate.Value.ToString("MMM dd, yyyy")</p>
                <p><strong>Reason:</strong> @Model.Lease.TerminationReason</p>
            }
            @if (Model.Lease.RenewalOfLease != null)
            {
                <p><strong>Renewed from:</strong> <a asp-page="Details" asp-route-id="@Model.Lease.RenewalOfLeaseId">Lease #@Model.Lease.RenewalOfLeaseId</a></p>
            }
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Model.Lease.Notes)) { <p><strong>Notes:</strong> @Model.Lease.Notes</p> }
    </div></div>
</section>
<div class="d-flex gap-2 mb-4">
    @if (Model.Lease.Status == LeaseStatus.Active)
    {
        <a asp-page="Renew" asp-route-id="@Model.Lease.Id" class="btn btn-success">Renew</a>
        <a asp-page="Terminate" asp-route-id="@Model.Lease.Id" class="btn btn-danger">Terminate</a>
        <a asp-page="Edit" asp-route-id="@Model.Lease.Id" class="btn btn-primary">Edit</a>
    }
    else if (Model.Lease.Status == LeaseStatus.Pending)
    {
        <a asp-page="Edit" asp-route-id="@Model.Lease.Id" class="btn btn-primary">Edit</a>
    }
    <a asp-page="Index" class="btn btn-outline-secondary">Back to List</a>
</div>
<section class="mb-4">
    <h3>Payment History</h3>
    @if (Model.Lease.Payments.Any())
    {
        <table class="table table-striped">
            <thead><tr><th>Date</th><th>Due Date</th><th>Amount</th><th>Type</th><th>Method</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @foreach (var p in Model.Lease.Payments)
                {
                    <tr>
                        <td>@p.PaymentDate.ToString("MMM dd, yyyy")</td>
                        <td>@p.DueDate.ToString("MMM dd, yyyy")</td>
                        <td>@p.Amount.ToString("C")</td>
                        <td>@p.PaymentType</td>
                        <td>@p.PaymentMethod</td>
                        <td><partial name="_StatusBadge" model="@(p.Status.ToString(), "payment")" /></td>
                        <td><a asp-page="/Payments/Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else { <p class="text-muted">No payments recorded.</p> }
</section>
<section>
    <h3>Inspections</h3>
    @if (Model.Lease.Inspections.Any())
    {
        <table class="table table-striped">
            <thead><tr><th>Type</th><th>Scheduled</th><th>Completed</th><th>Condition</th></tr></thead>
            <tbody>
                @foreach (var i in Model.Lease.Inspections)
                {
                    <tr>
                        <td>@i.InspectionType</td>
                        <td>@i.ScheduledDate.ToString("MMM dd, yyyy")</td>
                        <td>@(i.CompletedDate?.ToString("MMM dd, yyyy") ?? "Pending")</td>
                        <td>@(i.OverallCondition?.ToString() ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else { <p class="text-muted">No inspections linked.</p> }
</section>
