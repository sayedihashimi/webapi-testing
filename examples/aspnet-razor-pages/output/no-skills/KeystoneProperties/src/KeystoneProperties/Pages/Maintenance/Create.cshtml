@page
@model KeystoneProperties.Pages.Maintenance.CreateModel
@{ ViewData["Title"] = "New Maintenance Request"; }
<h1>New Maintenance Request</h1>
<div class="row"><div class="col-md-8">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Input.UnitId" class="form-label">Unit</label>
            <select asp-for="Input.UnitId" class="form-select">
                <option value="">Select unit...</option>
                @foreach (var u in Model.UnitList) { <option value="@u.Id">@u.Property.Name — Unit @u.UnitNumber</option> }
            </select>
            <span asp-validation-for="Input.UnitId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Input.TenantId" class="form-label">Tenant</label>
            <select asp-for="Input.TenantId" class="form-select">
                <option value="">Select tenant...</option>
                @foreach (var t in Model.TenantList) { <option value="@t.Id">@t.FullName</option> }
            </select>
            <span asp-validation-for="Input.TenantId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Input.Title" class="form-label"></label>
            <input asp-for="Input.Title" class="form-control" />
            <span asp-validation-for="Input.Title" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Input.Description" class="form-label"></label>
            <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Input.Description" class="text-danger"></span>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Input.Priority" class="form-label"></label>
                <select asp-for="Input.Priority" asp-items="@Html.GetEnumSelectList<MaintenancePriority>()" class="form-select"></select>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Input.Category" class="form-label"></label>
                <select asp-for="Input.Category" asp-items="@Html.GetEnumSelectList<MaintenanceCategory>()" class="form-select"></select>
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="Input.AssignedTo" class="form-label"></label>
            <input asp-for="Input.AssignedTo" class="form-control" />
            <span asp-validation-for="Input.AssignedTo" class="text-danger"></span>
            <span class="form-text">Required for Emergency priority requests.</span>
        </div>
        <div class="mb-3">
            <label asp-for="Input.EstimatedCost" class="form-label"></label>
            <input asp-for="Input.EstimatedCost" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Submit Request</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
