@page
@model KeystoneProperties.Pages.Units.IndexModel
@{
    ViewData["Title"] = "Units";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Units</h1>
    <a asp-page="Create" class="btn btn-primary">Add Unit</a>
</div>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-2">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Unit number..." />
    </div>
    <div class="col-md-2">
        <select name="propertyId" class="form-select">
            <option value="">All Properties</option>
            @foreach (var p in Model.PropertyList)
            {
                <option value="@p.Id" selected="@(Model.PropertyId == p.Id)">@p.Name</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="status" class="form-select">
            <option value="">All Status</option>
            @foreach (var s in Enum.GetValues<UnitStatus>())
            {
                <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="bedrooms" class="form-select">
            <option value="">Bedrooms</option>
            <option value="0" selected="@(Model.Bedrooms == 0)">Studio</option>
            @for (int i = 1; i <= 5; i++)
            {
                <option value="@i" selected="@(Model.Bedrooms == i)">@i BR</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <input type="number" name="minRent" value="@Model.MinRent" class="form-control" placeholder="Min rent" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary w-100">Filter</button>
    </div>
</form>

@if (Model.Units.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Property</th>
                <th>Unit #</th>
                <th>Bedrooms</th>
                <th>Bath</th>
                <th>Sq Ft</th>
                <th>Rent</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model.Units)
            {
                <tr>
                    <td>@u.Property.Name</td>
                    <td>@u.UnitNumber</td>
                    <td>@(u.Bedrooms == 0 ? "Studio" : u.Bedrooms.ToString())</td>
                    <td>@u.Bathrooms</td>
                    <td>@u.SquareFeet.ToString("N0")</td>
                    <td>@u.MonthlyRent.ToString("C")</td>
                    <td><partial name="_StatusBadge" model="@(u.Status.ToString(), "unit")" /></td>
                    <td>
                        <a asp-page="Details" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">View</a>
                        <a asp-page="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <partial name="_PaginationPartial" model="@(Model.CurrentPage, Model.TotalPages, $"?search={Model.Search}&propertyId={Model.PropertyId}&status={Model.StatusFilter}&bedrooms={Model.Bedrooms}&minRent={Model.MinRent}")" />
}
else
{
    <p class="text-muted">No units found.</p>
}
