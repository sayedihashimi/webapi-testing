@model (int CurrentPage, int TotalPages, string PageUrl)
@{
    var (currentPage, totalPages, pageUrl) = Model;
}

@if (totalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link" href="@(pageUrl)&pageNumber=@(currentPage - 1)">Previous</a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="@(pageUrl)&pageNumber=@i">@i</a>
                </li>
            }
            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                <a class="page-link" href="@(pageUrl)&pageNumber=@(currentPage + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
