@page "{id:int}"
@model HorizonHR.Pages.Departments.DetailsModel
@{
    ViewData["Title"] = Model.Department?.Name ?? "Department Details";
}

<section>
    @if (Model.Department == null)
    {
        <p class="text-muted">Department not found.</p>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1>@Model.Department.Name <small class="text-muted">(@Model.Department.Code)</small></h1>
            <a asp-page="Edit" asp-route-id="@Model.Department.Id" class="btn btn-outline-secondary">Edit</a>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">@(Model.Department.Description ?? "—")</dd>
                    <dt class="col-sm-3">Manager</dt>
                    <dd class="col-sm-9">
                        @if (Model.Department.Manager != null)
                        {
                            <a asp-page="/Employees/Details" asp-route-id="@Model.Department.Manager.Id">@Model.Department.Manager.FullName</a>
                        }
                        else
                        {
                            <span class="text-muted">Not assigned</span>
                        }
                    </dd>
                    <dt class="col-sm-3">Parent Department</dt>
                    <dd class="col-sm-9">
                        @if (Model.Department.ParentDepartment != null)
                        {
                            <a asp-page="Details" asp-route-id="@Model.Department.ParentDepartment.Id">@Model.Department.ParentDepartment.Name</a>
                        }
                        else
                        {
                            <span class="text-muted">None (top-level)</span>
                        }
                    </dd>
                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        @{ ViewData["StatusText"] = Model.Department.IsActive ? "Active" : "Terminated"; }
                        <partial name="Shared/_StatusBadge" />
                    </dd>
                </dl>
            </div>
        </div>

        @if (Model.Department.ChildDepartments.Any())
        {
            <h4>Child Departments</h4>
            <table class="table">
                <thead><tr><th>Name</th><th>Code</th></tr></thead>
                <tbody>
                    @foreach (var child in Model.Department.ChildDepartments)
                    {
                        <tr>
                            <td><a asp-page="Details" asp-route-id="@child.Id">@child.Name</a></td>
                            <td>@child.Code</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <h4>Employees</h4>
        @if (Model.Department.Employees.Any())
        {
            <table class="table">
                <thead><tr><th>Name</th><th>Title</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach (var emp in Model.Department.Employees)
                    {
                        <tr>
                            <td><a asp-page="/Employees/Details" asp-route-id="@emp.Id">@emp.FullName</a></td>
                            <td>@emp.JobTitle</td>
                            <td>
                                @{ ViewData["StatusText"] = emp.Status.ToString(); }
                                <partial name="Shared/_StatusBadge" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No employees in this department.</p>
        }
    }

    <a asp-page="Index" class="btn btn-outline-secondary mt-3">Back to Departments</a>
</section>
