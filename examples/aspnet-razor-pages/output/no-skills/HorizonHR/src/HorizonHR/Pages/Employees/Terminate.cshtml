@page "{id:int}"
@model HorizonHR.Pages.Employees.TerminateModel
@{
    ViewData["Title"] = "Terminate Employee";
}

<section>
    @if (Model.Employee == null)
    {
        <p class="text-muted">Employee not found.</p>
    }
    else
    {
        <h1>Terminate Employee</h1>
        <div class="alert alert-warning" role="alert">
            <strong>Warning:</strong> This will terminate <strong>@Model.Employee.FullName</strong> (@Model.Employee.EmployeeNumber).
            The following actions will be performed:
            <ul class="mt-2 mb-0">
                <li>Employee status set to Terminated</li>
                <li>All pending leave requests will be cancelled</li>
                <li>Employee will be removed as manager from any departments</li>
                <li>Employee will be removed as manager from any direct reports</li>
            </ul>
        </div>

        <form method="post" class="mt-3">
            <div class="mb-3">
                <label asp-for="TerminationDate" class="form-label">Termination Date</label>
                <input asp-for="TerminationDate" class="form-control" type="date" style="max-width: 300px;" />
                <span asp-validation-for="TerminationDate" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-danger">Confirm Termination</button>
            <a asp-page="Details" asp-route-id="@Model.Employee.Id" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    }
</section>
