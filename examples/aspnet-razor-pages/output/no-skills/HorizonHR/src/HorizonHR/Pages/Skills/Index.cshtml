@page
@model HorizonHR.Pages.Skills.IndexModel
@{
    ViewData["Title"] = "Skills";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Skills Catalog</h1>
        <div>
            <a asp-page="Search" class="btn btn-outline-primary me-2">Search by Skill</a>
            <a asp-page="Create" class="btn btn-primary">Add Skill</a>
        </div>
    </div>

    @if (!Model.SkillsByCategory.Any())
    {
        <p class="text-muted">No skills found.</p>
    }
    else
    {
        @foreach (var category in Model.SkillsByCategory)
        {
            <div class="card mb-3">
                <div class="card-header"><h5 class="mb-0">@category.Key</h5></div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Skill</th><th>Description</th><th>Employees</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var skill in category.Value)
                            {
                                <tr>
                                    <td>@skill.Name</td>
                                    <td>@(skill.Description ?? "—")</td>
                                    <td><span class="badge bg-info text-dark">@skill.EmployeeSkills.Count</span></td>
                                    <td><a asp-page="Edit" asp-route-id="@skill.Id" class="btn btn-sm btn-outline-secondary">Edit</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</section>
