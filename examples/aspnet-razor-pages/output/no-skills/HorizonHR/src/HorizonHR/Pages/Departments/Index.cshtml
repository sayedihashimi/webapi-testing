@page
@model HorizonHR.Pages.Departments.IndexModel
@{
    ViewData["Title"] = "Departments";
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Departments</h1>
        <a asp-page="Create" class="btn btn-primary">Create Department</a>
    </div>

    @if (!Model.Departments.Any())
    {
        <p class="text-muted">No departments found.</p>
    }
    else
    {
        @foreach (var dept in Model.Departments)
        {
            <div class="card mb-2">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1">
                                <a asp-page="Details" asp-route-id="@dept.Id">@dept.Name</a>
                                <small class="text-muted">(@dept.Code)</small>
                            </h5>
                            @if (dept.Manager != null)
                            {
                                <small class="text-muted">Manager: @dept.Manager.FullName</small>
                            }
                            <span class="badge bg-info text-dark ms-2">@dept.Employees.Count employees</span>
                        </div>
                        <div>
                            <a asp-page="Edit" asp-route-id="@dept.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        </div>
                    </div>
                    @if (dept.ChildDepartments.Any())
                    {
                        <div class="ms-4 mt-2">
                            @foreach (var child in dept.ChildDepartments)
                            {
                                <div class="d-flex justify-content-between align-items-center py-1">
                                    <div>
                                        <a asp-page="Details" asp-route-id="@child.Id">@child.Name</a>
                                        <small class="text-muted">(@child.Code)</small>
                                        @if (child.Manager != null)
                                        {
                                            <small class="text-muted ms-2">Manager: @child.Manager.FullName</small>
                                        }
                                        <span class="badge bg-info text-dark ms-2">@child.Employees.Count employees</span>
                                    </div>
                                    <a asp-page="Edit" asp-route-id="@child.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
</section>
