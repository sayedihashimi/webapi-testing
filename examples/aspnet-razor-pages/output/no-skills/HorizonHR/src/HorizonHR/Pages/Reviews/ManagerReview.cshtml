@page "{id:int}"
@model HorizonHR.Pages.Reviews.ManagerReviewModel
@{
    ViewData["Title"] = "Manager Review";
}

<section>
    @if (Model.Review == null)
    {
        <p class="text-muted">Review not found.</p>
    }
    else
    {
        <h1>Manager Review — @Model.Review.Employee.FullName</h1>
        <p class="text-muted">Period: @Model.Review.ReviewPeriodStart.ToString("MMM dd, yyyy") – @Model.Review.ReviewPeriodEnd.ToString("MMM dd, yyyy")</p>

        @if (!string.IsNullOrEmpty(Model.Review.SelfAssessment))
        {
            <div class="card mb-3">
                <div class="card-header"><h5 class="mb-0">Employee's Self-Assessment</h5></div>
                <div class="card-body"><p>@Model.Review.SelfAssessment</p></div>
            </div>
        }

        <form method="post" class="mt-3">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Input.ManagerAssessment" class="form-label">Manager Assessment</label>
                <textarea asp-for="Input.ManagerAssessment" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Input.ManagerAssessment" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.OverallRating" class="form-label">Overall Rating</label>
                <select asp-for="Input.OverallRating" class="form-select" asp-items="@(new SelectList(Enum.GetValues<OverallRating>()))"></select>
                <span asp-validation-for="Input.OverallRating" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Input.StrengthsNoted" class="form-label">Strengths</label>
                        <textarea asp-for="Input.StrengthsNoted" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Input.AreasForImprovement" class="form-label">Areas for Improvement</label>
                        <textarea asp-for="Input.AreasForImprovement" class="form-control" rows="3"></textarea>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Goals" class="form-label">Goals for Next Period</label>
                <textarea asp-for="Input.Goals" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Complete Review</button>
            <a asp-page="Details" asp-route-id="@Model.Review.Id" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    }
</section>
