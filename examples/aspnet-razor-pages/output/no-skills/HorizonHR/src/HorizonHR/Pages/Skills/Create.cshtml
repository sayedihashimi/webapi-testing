@page
@model HorizonHR.Pages.Skills.CreateModel
@{
    ViewData["Title"] = "Add Skill";
}

<section>
    <h1>Add Skill</h1>

    <form method="post" class="mt-3">
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Input.Name" class="form-label"></label>
            <input asp-for="Input.Name" class="form-control" />
            <span asp-validation-for="Input.Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Input.Category" class="form-label"></label>
            <input asp-for="Input.Category" class="form-control" placeholder="e.g., Programming Language, Framework, Soft Skill, Tool" />
            <span asp-validation-for="Input.Category" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Input.Description" class="form-label"></label>
            <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-page="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</section>
