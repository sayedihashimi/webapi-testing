@page "{id:int}"
@model HorizonHR.Pages.Leave.DetailsModel
@{
    ViewData["Title"] = "Leave Request Details";
}

<section>
    @if (Model.LeaveRequest == null)
    {
        <p class="text-muted">Leave request not found.</p>
    }
    else
    {
        var lr = Model.LeaveRequest;
        <h1>Leave Request #@lr.Id</h1>

        <div class="card mb-3">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Employee</dt>
                    <dd class="col-sm-9"><a asp-page="/Employees/Details" asp-route-id="@lr.EmployeeId">@lr.Employee.FullName</a></dd>
                    <dt class="col-sm-3">Department</dt>
                    <dd class="col-sm-9">@lr.Employee.Department.Name</dd>
                    <dt class="col-sm-3">Leave Type</dt>
                    <dd class="col-sm-9">@lr.LeaveType.Name</dd>
                    <dt class="col-sm-3">Dates</dt>
                    <dd class="col-sm-9">@lr.StartDate.ToString("MMM dd, yyyy") – @lr.EndDate.ToString("MMM dd, yyyy")</dd>
                    <dt class="col-sm-3">Total Days</dt>
                    <dd class="col-sm-9">@lr.TotalDays</dd>
                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        @{ ViewData["StatusText"] = lr.Status.ToString(); }
                        <partial name="Shared/_StatusBadge" />
                    </dd>
                    <dt class="col-sm-3">Reason</dt>
                    <dd class="col-sm-9">@lr.Reason</dd>
                    <dt class="col-sm-3">Submitted</dt>
                    <dd class="col-sm-9">@lr.SubmittedDate.ToString("MMM dd, yyyy HH:mm")</dd>
                    @if (lr.ReviewedBy != null)
                    {
                        <dt class="col-sm-3">Reviewed By</dt>
                        <dd class="col-sm-9">@lr.ReviewedBy.FullName</dd>
                        <dt class="col-sm-3">Review Date</dt>
                        <dd class="col-sm-9">@lr.ReviewDate?.ToString("MMM dd, yyyy HH:mm")</dd>
                        <dt class="col-sm-3">Review Notes</dt>
                        <dd class="col-sm-9">@(lr.ReviewNotes ?? "—")</dd>
                    }
                </dl>
            </div>
        </div>

        <div class="d-flex gap-2">
            @if (lr.Status == LeaveRequestStatus.Submitted)
            {
                <a asp-page="Review" asp-route-id="@lr.Id" class="btn btn-primary">Review</a>
                <a asp-page="Cancel" asp-route-id="@lr.Id" class="btn btn-outline-warning">Cancel</a>
            }
            @if (lr.Status == LeaveRequestStatus.Approved)
            {
                <a asp-page="Cancel" asp-route-id="@lr.Id" class="btn btn-outline-warning">Cancel</a>
            }
            <a asp-page="Index" class="btn btn-outline-secondary">Back to Leave Requests</a>
        </div>
    }
</section>
