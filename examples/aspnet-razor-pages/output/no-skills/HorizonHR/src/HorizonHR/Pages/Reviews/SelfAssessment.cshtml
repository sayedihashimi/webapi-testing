@page "{id:int}"
@model HorizonHR.Pages.Reviews.SelfAssessmentModel
@{
    ViewData["Title"] = "Self Assessment";
}

<section>
    @if (Model.Review == null)
    {
        <p class="text-muted">Review not found.</p>
    }
    else
    {
        <h1>Self-Assessment — @Model.Review.Employee.FullName</h1>
        <p class="text-muted">Period: @Model.Review.ReviewPeriodStart.ToString("MMM dd, yyyy") – @Model.Review.ReviewPeriodEnd.ToString("MMM dd, yyyy")</p>

        <form method="post" class="mt-3">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="SelfAssessmentText" class="form-label">Self Assessment</label>
                <textarea asp-for="SelfAssessmentText" class="form-control" rows="8" placeholder="Describe your accomplishments, challenges, and growth during this period..."></textarea>
                <span asp-validation-for="SelfAssessmentText" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Submit Self-Assessment</button>
            <a asp-page="Details" asp-route-id="@Model.Review.Id" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    }
</section>
